# This repository intentionally tracks the application, its tests,
# root project documents, and design specifications.
/*
!/.gitignore
!/LICENSE
!/README.md
!/README.zh-CN.md
!/todo.md
!/app/
!/app.Tests/
!/docs/
!/docs/**
!/public/
!/public/docs/
!/public/docs/**
!/scripts/
!/scripts/**
!/virtual-micro/
!/virtual-micro/**

# Build and IDE output
**/bin/
**/obj/
**/.artifacts/
.vs/
*.user
*.suo

# Local configuration and diagnostics
*.log
.env
.env.*
appsettings.local.json

# Editor / operating-system files
.idea/
.vscode/
.DS_Store
Thumbs.db
Desktop.ini
