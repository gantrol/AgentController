<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows10.0.19041.0</TargetFramework>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <ApplicationHighDpiMode>PerMonitorV2</ApplicationHighDpiMode>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <AssemblyName>AgentController</AssemblyName>
    <RootNamespace>CodexController</RootNamespace>
    <AssemblyTitle>Agent Controller</AssemblyTitle>
    <Product>Agent Controller</Product>
    <Description>Windows desktop gamepad controller for AI agents; the current integration targets Codex.</Description>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <ApplicationIcon>Assets\AgentController.ico</ApplicationIcon>
    <Version>0.7.0-hotfix</Version>
    <AssemblyVersion>0.7.0.0</AssemblyVersion>
    <FileVersion>0.7.0.0</FileVersion>
    <InformationalVersion>0.7.0-hotfix</InformationalVersion>
  </PropertyGroup>

  <ItemGroup>
    <Resource Include="Assets\controller.png" />
    <Resource Include="Assets\AgentController.ico" />
    <Resource Include="Assets\AgentController.png" />
    <Content Include="ThirdParty\CREATRBOI-White-XBOX-Controller\ATTRIBUTION.md"
             Link="THIRD-PARTY\CREATRBOI-White-XBOX-Controller-ATTRIBUTION.md">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
    </Content>
    <Content Include="ThirdParty\CREATRBOI-White-XBOX-Controller\LICENSE.txt"
             Link="THIRD-PARTY\CREATRBOI-White-XBOX-Controller-LICENSE.txt">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Data.Sqlite" />
    <!-- Override Microsoft.Data.Sqlite's vulnerable native SQLite payload while
         retaining its tested managed provider/bundle surface. -->
    <PackageReference Include="SQLitePCLRaw.lib.e_sqlite3" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\src\AgentController.Application\AgentController.Application.csproj" />
  </ItemGroup>

</Project>
