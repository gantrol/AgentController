<UserControl x:Class="CodexController.Views.AgentKeypadView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:CodexController.Models"
             mc:Ignorable="d"
             d:DesignHeight="460"
             d:DesignWidth="660"
             Width="660"
             Height="460"
             IsHitTestVisible="False"
             SnapsToDevicePixels="True">
    <UserControl.Resources>
        <Style x:Key="AgentKeypad.GlyphBadge"
               TargetType="Border">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Background"
                    Value="{StaticResource Brush.Bg.Surface}" />
            <Setter Property="BorderBrush"
                    Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="7" />
        </Style>

        <Style x:Key="AgentKeypad.Progress"
               TargetType="ProgressBar">
            <Setter Property="Height" Value="3" />
            <Setter Property="Foreground"
                    Value="{StaticResource Brush.Accent}" />
            <Setter Property="Background"
                    Value="{StaticResource Brush.Bg.Sunken}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid Height="{TemplateBinding Height}"
                              ClipToBounds="True">
                            <Rectangle Fill="{TemplateBinding Background}"
                                       RadiusX="1.5"
                                       RadiusY="1.5" />
                            <Rectangle x:Name="PART_Indicator"
                                       HorizontalAlignment="Left"
                                       Fill="{TemplateBinding Foreground}"
                                       RadiusX="1.5"
                                       RadiusY="1.5" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AgentKeypad.Key"
               TargetType="ContentControl">
            <Setter Property="Height" Value="128" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContentControl">
                        <Border x:Name="KeyRoot"
                                Background="{StaticResource Brush.Bg.Surface}"
                                BorderBrush="{StaticResource Brush.Border.Subtle}"
                                BorderThickness="1"
                                CornerRadius="14"
                                AutomationProperties.Name="{Binding AccessibleName}">
                            <Grid Margin="14,12,14,9">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="30" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="20" />
                                    <RowDefinition Height="3" />
                                </Grid.RowDefinitions>

                                <Border x:Name="GlyphBadge"
                                        Style="{StaticResource AgentKeypad.GlyphBadge}">
                                    <TextBlock Text="{Binding InputGlyph}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource Brush.Text.Primary}"
                                               FontFamily="{StaticResource Font.Mono}"
                                               FontSize="13"
                                               FontWeight="{StaticResource Font.Weight.Medium}" />
                                </Border>

                                <Rectangle x:Name="StatusLed"
                                           Width="38"
                                           Height="6"
                                           Margin="0,7,0,0"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Top"
                                           Fill="{StaticResource Brush.Led.Unknown}"
                                           RadiusX="3"
                                           RadiusY="3" />

                                <TextBlock x:Name="SlotTitle"
                                           Grid.Row="1"
                                           Margin="0,7,0,2"
                                           Text="{Binding Title}"
                                           Foreground="{StaticResource Brush.Text.Primary}"
                                           FontSize="14"
                                           FontWeight="{StaticResource Font.Weight.Semibold}"
                                           LineHeight="18"
                                           MaxHeight="40"
                                           TextWrapping="Wrap"
                                           TextTrimming="CharacterEllipsis" />

                                <TextBlock x:Name="SlotSubtitle"
                                           Grid.Row="2"
                                           Text="{Binding Subtitle}"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource Brush.Text.Tertiary}"
                                           FontSize="11"
                                           TextTrimming="CharacterEllipsis" />

                                <ProgressBar Grid.Row="3"
                                             Minimum="0"
                                             Maximum="1"
                                             Value="{Binding ConfirmationProgress, Mode=OneWay}">
                                    <ProgressBar.Style>
                                        <Style TargetType="ProgressBar"
                                               BasedOn="{StaticResource AgentKeypad.Progress}">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasConfirmationProgress}"
                                                             Value="False">
                                                    <Setter Property="Visibility"
                                                            Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ProgressBar.Style>
                                </ProgressBar>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding Status}"
                                         Value="{x:Static models:ThreadStatus.Unassigned}">
                                <Setter TargetName="KeyRoot"
                                        Property="Opacity"
                                        Value="0.34" />
                                <Setter TargetName="StatusLed"
                                        Property="Fill"
                                        Value="{StaticResource Brush.Led.Off}" />
                                <Setter TargetName="StatusLed"
                                        Property="Stroke"
                                        Value="{StaticResource Brush.Border.Strong}" />
                                <Setter TargetName="StatusLed"
                                        Property="StrokeThickness"
                                        Value="1" />
                                <Setter TargetName="StatusLed"
                                        Property="StrokeDashArray"
                                        Value="2 2" />
                                <Setter TargetName="SlotTitle"
                                        Property="Foreground"
                                        Value="{StaticResource Brush.Text.Tertiary}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}"
                                         Value="{x:Static models:ThreadStatus.Idle}">
                                <Setter TargetName="StatusLed"
                                        Property="Fill"
                                        Value="{StaticResource Brush.Led.Idle}" />
                                <Setter TargetName="SlotSubtitle"
                                        Property="Foreground"
                                        Value="{StaticResource Brush.Text.Secondary}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}"
                                         Value="{x:Static models:ThreadStatus.Thinking}">
                                <Setter TargetName="StatusLed"
                                        Property="Fill"
                                        Value="{StaticResource Brush.Led.Working}" />
                                <Setter TargetName="SlotSubtitle"
                                        Property="Foreground"
                                        Value="{StaticResource Brush.Led.Working}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}"
                                         Value="{x:Static models:ThreadStatus.CompleteUnread}">
                                <Setter TargetName="StatusLed"
                                        Property="Fill"
                                        Value="{StaticResource Brush.Led.CompleteUnread}" />
                                <Setter TargetName="SlotSubtitle"
                                        Property="Foreground"
                                        Value="{StaticResource Brush.Status.Success}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}"
                                         Value="{x:Static models:ThreadStatus.RequiresInput}">
                                <Setter TargetName="StatusLed"
                                        Property="Fill"
                                        Value="{StaticResource Brush.Led.RequiresInput}" />
                                <Setter TargetName="SlotSubtitle"
                                        Property="Foreground"
                                        Value="{StaticResource Brush.Status.Warning}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}"
                                         Value="{x:Static models:ThreadStatus.Error}">
                                <Setter TargetName="StatusLed"
                                        Property="Fill"
                                        Value="{StaticResource Brush.Led.Error}" />
                                <Setter TargetName="SlotSubtitle"
                                        Property="Foreground"
                                        Value="{StaticResource Brush.Status.Danger}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsHighlighted}"
                                         Value="True">
                                <Setter TargetName="KeyRoot"
                                        Property="Background"
                                        Value="{StaticResource Brush.Accent.Soft}" />
                                <Setter TargetName="KeyRoot"
                                        Property="BorderBrush"
                                        Value="{StaticResource Brush.Accent}" />
                                <Setter TargetName="KeyRoot"
                                        Property="BorderThickness"
                                        Value="2" />
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard x:Name="SelectedPulseStoryboard">
                                        <Storyboard RepeatBehavior="Forever"
                                                    AutoReverse="True">
                                            <DoubleAnimation Storyboard.TargetName="StatusLed"
                                                             Storyboard.TargetProperty="Opacity"
                                                             From="1"
                                                             To="0.36"
                                                             Duration="0:0:0.8" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <RemoveStoryboard BeginStoryboardName="SelectedPulseStoryboard" />
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPresent}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Width="660" Height="460">
        <Grid.RowDefinitions>
            <RowDefinition Height="68" />
            <RowDefinition Height="392" />
        </Grid.RowDefinitions>

        <Border Width="640"
                Height="60"
                Margin="0,0,0,8"
                VerticalAlignment="Bottom"
                Background="{StaticResource Brush.Overlay.Surface.Frosted}"
                BorderBrush="{StaticResource Brush.Border.Subtle}"
                BorderThickness="1"
                CornerRadius="14">
            <Grid Margin="10,0,12,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Width="42"
                    Height="30"
                    Margin="0,0,12,0"
                    VerticalAlignment="Center"
                    Background="{StaticResource Brush.Bg.Surface}"
                    BorderBrush="{StaticResource Brush.Border.Strong}"
                    BorderThickness="1"
                    CornerRadius="7">
                <TextBlock Text="{Binding ModifierGlyph}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource Brush.Text.Primary}"
                           FontFamily="{StaticResource Font.Mono}"
                           FontSize="12"
                           FontWeight="{StaticResource Font.Weight.Medium}" />
            </Border>

            <StackPanel Grid.Column="1"
                        VerticalAlignment="Center">
                <TextBlock Text="{Binding Title}"
                           Foreground="{StaticResource Brush.Text.Primary}"
                           FontSize="18"
                           FontWeight="{StaticResource Font.Weight.Semibold}"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Text="{Binding AgentKeypad.Instruction}"
                           Margin="0,2,0,0"
                           Foreground="{StaticResource Brush.Text.Secondary}"
                           FontSize="11"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <StackPanel Grid.Column="2"
                        Margin="14,0,0,0"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                <Border Width="34"
                        Height="30"
                        Background="{StaticResource Brush.Bg.Surface}"
                        BorderBrush="{StaticResource Brush.Border.Subtle}"
                        BorderThickness="1"
                        CornerRadius="7">
                    <TextBlock Text="{Binding AgentKeypad.DismissGlyph}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource Brush.Text.Primary}"
                               FontFamily="{StaticResource Font.Mono}"
                               FontSize="12" />
                </Border>
                <TextBlock Text="{Binding AgentKeypad.DismissHint}"
                           Margin="8,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource Brush.Text.Secondary}"
                           FontSize="12" />
            </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Width="640"
                Background="{StaticResource Brush.Overlay.Surface.Frosted}"
                BorderBrush="{StaticResource Brush.Border.Subtle}"
                BorderThickness="1"
                CornerRadius="20"
                Effect="{StaticResource Shadow.Overlay}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="302" />
                    <RowDefinition Height="1" />
                    <RowDefinition Height="89" />
                </Grid.RowDefinitions>

                <Grid Margin="18,17">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="128" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="128" />
                    </Grid.RowDefinitions>

                    <!-- Physical layout: View / Up / Menu, then Left / Down / Right. -->
                    <ContentControl Grid.Row="0"
                                    Grid.Column="0"
                                    DataContext="{Binding Left}"
                                    Style="{StaticResource AgentKeypad.Key}" />
                    <ContentControl Grid.Row="0"
                                    Grid.Column="2"
                                    DataContext="{Binding Top}"
                                    Style="{StaticResource AgentKeypad.Key}" />
                    <ContentControl Grid.Row="0"
                                    Grid.Column="4"
                                    DataContext="{Binding Right}"
                                    Style="{StaticResource AgentKeypad.Key}" />
                    <ContentControl Grid.Row="2"
                                    Grid.Column="0"
                                    DataContext="{Binding CenterLeft}"
                                    Style="{StaticResource AgentKeypad.Key}" />
                    <ContentControl Grid.Row="2"
                                    Grid.Column="2"
                                    DataContext="{Binding Bottom}"
                                    Style="{StaticResource AgentKeypad.Key}" />
                    <ContentControl Grid.Row="2"
                                    Grid.Column="4"
                                    DataContext="{Binding CenterRight}"
                                    Style="{StaticResource AgentKeypad.Key}" />
                </Grid>

                <Border Grid.Row="1"
                        Margin="18,0"
                        Background="{StaticResource Brush.Border.Subtle}" />

                <Grid Grid.Row="2"
                      Margin="18,9,18,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="26" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <WrapPanel HorizontalAlignment="Center"
                               VerticalAlignment="Center">
                        <StackPanel Margin="0,0,14,0"
                                    Orientation="Horizontal">
                            <Ellipse Width="10"
                                     Height="10"
                                     Fill="{StaticResource Brush.Led.Idle}" />
                            <TextBlock Margin="5,0,0,0"
                                       Text="{Binding AgentKeypad.IdleLabel}"
                                       Foreground="{StaticResource Brush.Text.Secondary}"
                                       FontSize="10" />
                        </StackPanel>
                        <StackPanel Margin="0,0,14,0"
                                    Orientation="Horizontal">
                            <Ellipse Width="10"
                                     Height="10"
                                     Fill="{StaticResource Brush.Led.Working}" />
                            <TextBlock Margin="5,0,0,0"
                                       Text="{Binding AgentKeypad.ThinkingLabel}"
                                       Foreground="{StaticResource Brush.Text.Secondary}"
                                       FontSize="10" />
                        </StackPanel>
                        <StackPanel Margin="0,0,14,0"
                                    Orientation="Horizontal">
                            <Ellipse Width="10"
                                     Height="10"
                                     Fill="{StaticResource Brush.Led.CompleteUnread}" />
                            <TextBlock Margin="5,0,0,0"
                                       Text="{Binding AgentKeypad.CompleteUnreadLabel}"
                                       Foreground="{StaticResource Brush.Text.Secondary}"
                                       FontSize="10" />
                        </StackPanel>
                        <StackPanel Margin="0,0,14,0"
                                    Orientation="Horizontal">
                            <Ellipse Width="10"
                                     Height="10"
                                     Fill="{StaticResource Brush.Led.RequiresInput}" />
                            <TextBlock Margin="5,0,0,0"
                                       Text="{Binding AgentKeypad.RequiresInputLabel}"
                                       Foreground="{StaticResource Brush.Text.Secondary}"
                                       FontSize="10" />
                        </StackPanel>
                        <StackPanel Margin="0,0,14,0"
                                    Orientation="Horizontal">
                            <Ellipse Width="10"
                                     Height="10"
                                     Fill="{StaticResource Brush.Led.Error}" />
                            <TextBlock Margin="5,0,0,0"
                                       Text="{Binding AgentKeypad.ErrorLabel}"
                                       Foreground="{StaticResource Brush.Text.Secondary}"
                                       FontSize="10" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10"
                                     Height="10"
                                     Fill="{StaticResource Brush.Led.Off}"
                                     Stroke="{StaticResource Brush.Border.Strong}"
                                     StrokeThickness="1"
                                     StrokeDashArray="2 2" />
                            <TextBlock Margin="5,0,0,0"
                                       Text="{Binding AgentKeypad.UnassignedLabel}"
                                       Foreground="{StaticResource Brush.Text.Secondary}"
                                       FontSize="10" />
                        </StackPanel>
                    </WrapPanel>

                    <TextBlock Grid.Row="1"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Bottom"
                               Text="{Binding AgentKeypad.SelectionHint}"
                               Foreground="{StaticResource Brush.Text.Secondary}"
                               FontSize="11" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
