<UserControl x:Class="CodexController.Views.AgentKeypadView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:CodexController.Models"
             xmlns:sys="clr-namespace:System.Windows;assembly=PresentationFramework"
             xmlns:views="clr-namespace:CodexController.Views"
             mc:Ignorable="d"
             d:DesignHeight="360"
             d:DesignWidth="820"
             Width="820"
             Height="360"
             IsHitTestVisible="False"
             SnapsToDevicePixels="True">
    <UserControl.Resources>
        <Style x:Key="AgentKeypad.Key"
               TargetType="ContentControl">
            <Setter Property="Height" Value="78" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContentControl">
                        <Border x:Name="RowRoot"
                                Background="{StaticResource Brush.Agent.Row.Fill}"
                                BorderBrush="{StaticResource Brush.Border.Subtle}"
                                BorderThickness="1"
                                CornerRadius="16"
                                AutomationProperties.Name="{Binding AccessibleName}">
                            <Grid Margin="10,7,14,7">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="72" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border x:Name="Keycap"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource Overlay.PhysicalKey}">
                                    <Grid>
                                        <Ellipse x:Name="LedField"
                                                 Width="50"
                                                 Height="50"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"
                                                 Fill="{StaticResource Brush.Led.Unknown}"
                                                 Opacity="0.16">
                                            <Ellipse.OpacityMask>
                                                <RadialGradientBrush>
                                                    <GradientStop Color="#FFFFFFFF" Offset="0" />
                                                    <GradientStop Color="#7FFFFFFF" Offset="0.46" />
                                                    <GradientStop Color="#00FFFFFF" Offset="1" />
                                                </RadialGradientBrush>
                                            </Ellipse.OpacityMask>
                                        </Ellipse>
                                        <views:ControllerGlyphView x:Name="GlyphView"
                                                                   Width="36"
                                                                   Height="34"
                                                                   Glyph="{Binding InputGlyph}"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{StaticResource Brush.Text.Secondary}"
                                                                   FontFamily="{StaticResource Font.Mono}"
                                                                   FontSize="12"
                                                                   FontWeight="{StaticResource Font.Weight.Medium}" />
                                        <Ellipse x:Name="LedHalo"
                                                 Width="18"
                                                 Height="18"
                                                 Margin="0,0,1,1"
                                                 HorizontalAlignment="Right"
                                                 VerticalAlignment="Bottom"
                                                 Fill="{StaticResource Brush.Led.Unknown}"
                                                 Opacity="0.16">
                                            <Ellipse.Effect>
                                                <BlurEffect Radius="5" />
                                            </Ellipse.Effect>
                                        </Ellipse>
                                        <Ellipse x:Name="StatusLed"
                                                 Width="10"
                                                 Height="10"
                                                 Margin="0,0,4,4"
                                                 HorizontalAlignment="Right"
                                                 VerticalAlignment="Bottom"
                                                 Fill="{StaticResource Brush.Led.Unknown}"
                                                 Stroke="#77FFFFFF"
                                                 StrokeThickness="1" />
                                        <Ellipse x:Name="LedHighlight"
                                                 Width="3"
                                                 Height="2"
                                                 Margin="0,0,10,11"
                                                 HorizontalAlignment="Right"
                                                 VerticalAlignment="Bottom"
                                                 Fill="#BFFFFFFF" />
                                    </Grid>
                                </Border>

                                <TextBlock x:Name="SlotTitle"
                                           Grid.Column="1"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"
                                           Text="{Binding Title}"
                                           Foreground="{StaticResource Brush.Text.Primary}"
                                           FontSize="15"
                                           FontWeight="{StaticResource Font.Weight.Semibold}"
                                           TextTrimming="CharacterEllipsis" />

                                <ProgressBar Grid.ColumnSpan="2"
                                             Margin="3,0,3,-3"
                                             VerticalAlignment="Bottom"
                                             Minimum="0"
                                             Maximum="1"
                                             Value="{Binding ConfirmationProgress, Mode=OneWay}">
                                    <ProgressBar.Style>
                                        <Style TargetType="ProgressBar"
                                               BasedOn="{StaticResource Overlay.Progress}">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasConfirmationProgress}"
                                                             Value="False">
                                                    <Setter Property="Visibility"
                                                            Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ProgressBar.Style>
                                </ProgressBar>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding Status}"
                                         Value="{x:Static models:ThreadStatus.Unassigned}">
                                <Setter TargetName="RowRoot"
                                        Property="Opacity"
                                        Value="0.58" />
                                <Setter TargetName="StatusLed"
                                        Property="Fill"
                                        Value="{StaticResource Brush.Led.Off}" />
                                <Setter TargetName="StatusLed"
                                        Property="Stroke"
                                        Value="{StaticResource Brush.Border.Strong}" />
                                <Setter TargetName="LedHalo"
                                        Property="Opacity"
                                        Value="0" />
                                <Setter TargetName="LedField"
                                        Property="Opacity"
                                        Value="0" />
                                <Setter TargetName="LedHighlight"
                                        Property="Visibility"
                                        Value="Collapsed" />
                                <Setter TargetName="SlotTitle"
                                        Property="Foreground"
                                        Value="{StaticResource Brush.Text.Tertiary}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}"
                                         Value="{x:Static models:ThreadStatus.Idle}">
                                <Setter TargetName="StatusLed"
                                        Property="Fill"
                                        Value="{StaticResource Brush.Led.Idle}" />
                                <Setter TargetName="LedHalo"
                                        Property="Fill"
                                        Value="{StaticResource Brush.Led.Idle}" />
                                <Setter TargetName="LedField"
                                        Property="Fill"
                                        Value="{StaticResource Brush.Led.Idle}" />
                                <Setter TargetName="LedField"
                                        Property="Opacity"
                                        Value="0.1" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}"
                                         Value="{x:Static models:ThreadStatus.Thinking}">
                                <Setter TargetName="StatusLed"
                                        Property="Fill"
                                        Value="{StaticResource Brush.Led.Working}" />
                                <Setter TargetName="LedHalo"
                                        Property="Fill"
                                        Value="{StaticResource Brush.Led.Working}" />
                                <Setter TargetName="LedField"
                                        Property="Fill"
                                        Value="{StaticResource Brush.Led.Working}" />
                                <Setter TargetName="LedField"
                                        Property="Opacity"
                                        Value="0.28" />
                                <Setter TargetName="LedHalo"
                                        Property="Opacity"
                                        Value="0.24" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}"
                                         Value="{x:Static models:ThreadStatus.CompleteUnread}">
                                <Setter TargetName="StatusLed"
                                        Property="Fill"
                                        Value="{StaticResource Brush.Led.CompleteUnread}" />
                                <Setter TargetName="LedHalo"
                                        Property="Fill"
                                        Value="{StaticResource Brush.Led.CompleteUnread}" />
                                <Setter TargetName="LedField"
                                        Property="Fill"
                                        Value="{StaticResource Brush.Led.CompleteUnread}" />
                                <Setter TargetName="LedField"
                                        Property="Opacity"
                                        Value="0.2" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}"
                                         Value="{x:Static models:ThreadStatus.RequiresInput}">
                                <Setter TargetName="StatusLed"
                                        Property="Fill"
                                        Value="{StaticResource Brush.Led.RequiresInput}" />
                                <Setter TargetName="LedHalo"
                                        Property="Fill"
                                        Value="{StaticResource Brush.Led.RequiresInput}" />
                                <Setter TargetName="LedField"
                                        Property="Fill"
                                        Value="{StaticResource Brush.Led.RequiresInput}" />
                                <Setter TargetName="LedField"
                                        Property="Opacity"
                                        Value="0.26" />
                                <Setter TargetName="LedHalo"
                                        Property="Opacity"
                                        Value="0.24" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}"
                                         Value="{x:Static models:ThreadStatus.Error}">
                                <Setter TargetName="StatusLed"
                                        Property="Fill"
                                        Value="{StaticResource Brush.Led.Error}" />
                                <Setter TargetName="LedHalo"
                                        Property="Fill"
                                        Value="{StaticResource Brush.Led.Error}" />
                                <Setter TargetName="LedField"
                                        Property="Fill"
                                        Value="{StaticResource Brush.Led.Error}" />
                                <Setter TargetName="LedField"
                                        Property="Opacity"
                                        Value="0.26" />
                                <Setter TargetName="LedHalo"
                                        Property="Opacity"
                                        Value="0.24" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsActionEnabled}"
                                         Value="False">
                                <Setter TargetName="RowRoot"
                                        Property="Opacity"
                                        Value="0.52" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsHighlighted}"
                                         Value="True">
                                <Setter TargetName="RowRoot"
                                        Property="Background"
                                        Value="{StaticResource Brush.Agent.Row.Selected}" />
                                <Setter TargetName="RowRoot"
                                        Property="BorderBrush"
                                        Value="{StaticResource Brush.Agent.Row.SelectedBorder}" />
                                <Setter TargetName="RowRoot"
                                        Property="BorderThickness"
                                        Value="2" />
                                <Setter TargetName="Keycap"
                                        Property="BorderBrush"
                                        Value="{StaticResource Brush.Agent.Row.SelectedBorder}" />
                                <Setter TargetName="GlyphView"
                                        Property="Foreground"
                                        Value="{StaticResource Brush.Agent.Glyph}" />
                            </DataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding Status}"
                                               Value="{x:Static models:ThreadStatus.Thinking}" />
                                    <Condition Binding="{Binding Source={x:Static sys:SystemParameters.ClientAreaAnimation}}"
                                               Value="True" />
                                </MultiDataTrigger.Conditions>
                                <MultiDataTrigger.EnterActions>
                                    <BeginStoryboard x:Name="WorkingPulseStoryboard">
                                        <Storyboard RepeatBehavior="Forever"
                                                    AutoReverse="True">
                                            <DoubleAnimation Storyboard.TargetName="LedField"
                                                             Storyboard.TargetProperty="Opacity"
                                                             From="0.28"
                                                             To="0.2"
                                                             Duration="0:0:0.8" />
                                            <DoubleAnimation Storyboard.TargetName="LedHalo"
                                                             Storyboard.TargetProperty="Opacity"
                                                             From="0.24"
                                                             To="0.14"
                                                             Duration="0:0:0.8" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </MultiDataTrigger.EnterActions>
                                <MultiDataTrigger.ExitActions>
                                    <RemoveStoryboard BeginStoryboardName="WorkingPulseStoryboard" />
                                </MultiDataTrigger.ExitActions>
                            </MultiDataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Width="820"
          Height="360"
          Background="Transparent">
        <Border x:Name="AgentPanelShell"
                Width="804"
                Height="344"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Style="{StaticResource Overlay.MicroPanel}">
            <Grid Margin="20,14,20,14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Border Style="{StaticResource Overlay.ModifierBadge}"
                                Margin="0,0,10,0">
                            <TextBlock Text="{Binding ModifierGlyph}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource Brush.Agent.Glyph}"
                                       FontFamily="{StaticResource Font.Mono}"
                                       FontSize="12"
                                       FontWeight="{StaticResource Font.Weight.Bold}" />
                        </Border>
                        <TextBlock Text="{Binding Title}"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource Brush.Text.Secondary}"
                                   FontSize="15"
                                   FontWeight="{StaticResource Font.Weight.Medium}"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <!-- The two center buttons vary most between controller
                         families. Pair the live profile glyph with its
                         standard name instead of asking users to recognize a
                         tiny symbol in the slot grid. -->
                    <StackPanel x:Name="MetaButtonLegend"
                                Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                AutomationProperties.Name="View and Menu button guide">
                        <Border Padding="7,3"
                                Style="{StaticResource Overlay.PhysicalKey.Compact}">
                            <StackPanel Orientation="Horizontal">
                                <views:ControllerGlyphView Width="28"
                                                           Glyph="{Binding Left.InputGlyph}"
                                                           Foreground="{StaticResource Brush.Text.Secondary}"
                                                           FontFamily="{StaticResource Font.Mono}"
                                                           FontSize="10"
                                                           FontWeight="{StaticResource Font.Weight.Semibold}" />
                                <TextBlock Margin="4,0,0,0"
                                           Text="View"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource Brush.Text.Tertiary}"
                                           FontSize="10" />
                            </StackPanel>
                        </Border>
                        <Border Margin="8,0,0,0"
                                Padding="7,3"
                                Style="{StaticResource Overlay.PhysicalKey.Compact}">
                            <StackPanel Orientation="Horizontal">
                                <views:ControllerGlyphView Width="28"
                                                           Glyph="{Binding Right.InputGlyph}"
                                                           Foreground="{StaticResource Brush.Text.Secondary}"
                                                           FontFamily="{StaticResource Font.Mono}"
                                                           FontSize="10"
                                                           FontWeight="{StaticResource Font.Weight.Semibold}" />
                                <TextBlock Margin="4,0,0,0"
                                           Text="Menu"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource Brush.Text.Tertiary}"
                                           FontSize="10" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="78" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="78" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="78" />
                    </Grid.RowDefinitions>

                    <!-- Micro order: Up/Right, Down/Left, View/Menu. -->
                    <ContentControl x:Name="AgentUpKey"
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    DataContext="{Binding Top}"
                                    Style="{StaticResource AgentKeypad.Key}" />
                    <ContentControl x:Name="AgentRightKey"
                                    Grid.Row="0"
                                    Grid.Column="2"
                                    DataContext="{Binding CenterRight}"
                                    Style="{StaticResource AgentKeypad.Key}" />
                    <ContentControl x:Name="AgentDownKey"
                                    Grid.Row="2"
                                    Grid.Column="0"
                                    DataContext="{Binding Bottom}"
                                    Style="{StaticResource AgentKeypad.Key}" />
                    <ContentControl x:Name="AgentLeftKey"
                                    Grid.Row="2"
                                    Grid.Column="2"
                                    DataContext="{Binding CenterLeft}"
                                    Style="{StaticResource AgentKeypad.Key}" />
                    <ContentControl x:Name="AgentViewKey"
                                    Grid.Row="4"
                                    Grid.Column="0"
                                    DataContext="{Binding Left}"
                                    Style="{StaticResource AgentKeypad.Key}" />
                    <ContentControl x:Name="AgentMenuKey"
                                    Grid.Row="4"
                                    Grid.Column="2"
                                    DataContext="{Binding Right}"
                                    Style="{StaticResource AgentKeypad.Key}" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
