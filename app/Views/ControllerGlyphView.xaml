<UserControl x:Class="CodexController.Views.ControllerGlyphView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             MinWidth="36"
             MinHeight="20"
             IsHitTestVisible="False"
             SnapsToDevicePixels="True">
    <UserControl.Resources>
        <!-- SVG path data for one shared D-pad silhouette and its four arms. -->
        <Geometry x:Key="Geometry.DPad.Silhouette">M 9,1 C 9,0.45 9.45,0 10,0 L 14,0 C 14.55,0 15,0.45 15,1 L 15,9 L 23,9 C 23.55,9 24,9.45 24,10 L 24,14 C 24,14.55 23.55,15 23,15 L 15,15 L 15,23 C 15,23.55 14.55,24 14,24 L 10,24 C 9.45,24 9,23.55 9,23 L 9,15 L 1,15 C 0.45,15 0,14.55 0,14 L 0,10 C 0,9.45 0.45,9 1,9 L 9,9 Z</Geometry>
        <Geometry x:Key="Geometry.DPad.Up">M 10,1 L 14,1 L 14,9 L 12,11 L 10,9 Z</Geometry>
        <Geometry x:Key="Geometry.DPad.Right">M 15,10 L 23,10 L 23,14 L 15,14 L 13,12 Z</Geometry>
        <Geometry x:Key="Geometry.DPad.Down">M 14,15 L 14,23 L 10,23 L 10,15 L 12,13 Z</Geometry>
        <Geometry x:Key="Geometry.DPad.Left">M 9,14 L 1,14 L 1,10 L 9,10 L 11,12 Z</Geometry>
    </UserControl.Resources>
    <Grid>
        <TextBlock x:Name="FallbackGlyphText"
                   Text="{Binding Glyph, ElementName=Root}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Foreground="{Binding Foreground, ElementName=Root}"
                   FontFamily="{Binding FontFamily, ElementName=Root}"
                   FontSize="{Binding FontSize, ElementName=Root}"
                   FontWeight="{Binding FontWeight, ElementName=Root}">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Glyph, ElementName=Root}"
                                     Value="⧉">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Glyph, ElementName=Root}"
                                     Value="☰">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Glyph, ElementName=Root}"
                                     Value="View">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Glyph, ElementName=Root}"
                                     Value="VIEW">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Glyph, ElementName=Root}"
                                     Value="Menu">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Glyph, ElementName=Root}"
                                     Value="MENU">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsDPadGlyph, ElementName=Root}"
                                     Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <Viewbox x:Name="DPadIcon"
                 Width="25"
                 Height="25"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center">
            <Viewbox.Style>
                <Style TargetType="Viewbox">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsDPadGlyph, ElementName=Root}"
                                     Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Viewbox.Style>
            <Grid Width="24" Height="24">
                <Path Data="{StaticResource Geometry.DPad.Silhouette}"
                      Fill="{Binding Foreground, ElementName=Root}"
                      Stroke="{Binding Foreground, ElementName=Root}"
                      StrokeThickness="0.8"
                      StrokeLineJoin="Round"
                      Opacity="0.3" />

                <Path x:Name="DPadUpArm"
                      Data="{StaticResource Geometry.DPad.Up}"
                      Fill="{StaticResource Brush.Agent.Glyph}">
                    <Path.Style>
                        <Style TargetType="Path">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDPadUpHighlighted, ElementName=Root}"
                                             Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Path.Style>
                    <Path.Effect>
                        <DropShadowEffect Color="#53675A"
                                          BlurRadius="3"
                                          ShadowDepth="0"
                                          Opacity="0.25" />
                    </Path.Effect>
                </Path>
                <Path x:Name="DPadRightArm"
                      Data="{StaticResource Geometry.DPad.Right}"
                      Fill="{StaticResource Brush.Agent.Glyph}">
                    <Path.Style>
                        <Style TargetType="Path">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDPadRightHighlighted, ElementName=Root}"
                                             Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Path.Style>
                    <Path.Effect>
                        <DropShadowEffect Color="#53675A"
                                          BlurRadius="3"
                                          ShadowDepth="0"
                                          Opacity="0.25" />
                    </Path.Effect>
                </Path>
                <Path x:Name="DPadDownArm"
                      Data="{StaticResource Geometry.DPad.Down}"
                      Fill="{StaticResource Brush.Agent.Glyph}">
                    <Path.Style>
                        <Style TargetType="Path">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDPadDownHighlighted, ElementName=Root}"
                                             Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Path.Style>
                    <Path.Effect>
                        <DropShadowEffect Color="#53675A"
                                          BlurRadius="3"
                                          ShadowDepth="0"
                                          Opacity="0.25" />
                    </Path.Effect>
                </Path>
                <Path x:Name="DPadLeftArm"
                      Data="{StaticResource Geometry.DPad.Left}"
                      Fill="{StaticResource Brush.Agent.Glyph}">
                    <Path.Style>
                        <Style TargetType="Path">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDPadLeftHighlighted, ElementName=Root}"
                                             Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Path.Style>
                    <Path.Effect>
                        <DropShadowEffect Color="#53675A"
                                          BlurRadius="3"
                                          ShadowDepth="0"
                                          Opacity="0.25" />
                    </Path.Effect>
                </Path>

                <Ellipse Width="4.5"
                         Height="4.5"
                         Fill="#EFFFFFFF"
                         Stroke="{StaticResource Brush.Agent.Glyph}"
                         StrokeThickness="0.8"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />
            </Grid>
        </Viewbox>

        <!-- Xbox View: two offset windows, drawn instead of relying on a
             font-dependent Unicode approximation. -->
        <Grid x:Name="ViewIcon"
              Width="18"
              Height="14"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Glyph, ElementName=Root}"
                                     Value="⧉">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Glyph, ElementName=Root}"
                                     Value="View">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Glyph, ElementName=Root}"
                                     Value="VIEW">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Border Width="11"
                    Height="8"
                    Margin="1,1,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    BorderBrush="{Binding Foreground, ElementName=Root}"
                    BorderThickness="1.5"
                    CornerRadius="1" />
            <Border Width="11"
                    Height="8"
                    Margin="0,0,1,1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Background="{StaticResource Brush.Overlay.MicroKey}"
                    BorderBrush="{Binding Foreground, ElementName=Root}"
                    BorderThickness="1.5"
                    CornerRadius="1" />
        </Grid>

        <!-- Xbox Menu: the physical three-line mark. -->
        <Grid x:Name="MenuIcon"
              Width="16"
              Height="14"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Glyph, ElementName=Root}"
                                     Value="☰">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Glyph, ElementName=Root}"
                                     Value="Menu">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Glyph, ElementName=Root}"
                                     Value="MENU">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>
            <Border Grid.Row="0"
                    Height="1.5"
                    VerticalAlignment="Center"
                    Background="{Binding Foreground, ElementName=Root}"
                    CornerRadius="1" />
            <Border Grid.Row="1"
                    Height="1.5"
                    VerticalAlignment="Center"
                    Background="{Binding Foreground, ElementName=Root}"
                    CornerRadius="1" />
            <Border Grid.Row="2"
                    Height="1.5"
                    VerticalAlignment="Center"
                    Background="{Binding Foreground, ElementName=Root}"
                    CornerRadius="1" />
        </Grid>
    </Grid>
</UserControl>
