<UserControl x:Class="CodexController.Views.ControllerGlyphView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             MinWidth="36"
             MinHeight="20"
             IsHitTestVisible="False"
             SnapsToDevicePixels="True">
    <Grid>
        <TextBlock x:Name="FallbackGlyphText"
                   Text="{Binding Glyph, ElementName=Root}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Foreground="{Binding Foreground, ElementName=Root}"
                   FontFamily="{Binding FontFamily, ElementName=Root}"
                   FontSize="{Binding FontSize, ElementName=Root}"
                   FontWeight="{Binding FontWeight, ElementName=Root}">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Glyph, ElementName=Root}"
                                     Value="⧉">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Glyph, ElementName=Root}"
                                     Value="☰">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Xbox View: two offset windows, drawn instead of relying on a
             font-dependent Unicode approximation. -->
        <Grid x:Name="ViewIcon"
              Width="18"
              Height="14"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Glyph, ElementName=Root}"
                                     Value="⧉">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Border Width="11"
                    Height="8"
                    Margin="1,1,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    BorderBrush="{Binding Foreground, ElementName=Root}"
                    BorderThickness="1.5"
                    CornerRadius="1" />
            <Border Width="11"
                    Height="8"
                    Margin="0,0,1,1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Background="{StaticResource Brush.Overlay.MicroKey}"
                    BorderBrush="{Binding Foreground, ElementName=Root}"
                    BorderThickness="1.5"
                    CornerRadius="1" />
        </Grid>

        <!-- Xbox Menu: the physical three-line mark. -->
        <Grid x:Name="MenuIcon"
              Width="16"
              Height="14"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Glyph, ElementName=Root}"
                                     Value="☰">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>
            <Border Grid.Row="0"
                    Height="1.5"
                    VerticalAlignment="Center"
                    Background="{Binding Foreground, ElementName=Root}"
                    CornerRadius="1" />
            <Border Grid.Row="1"
                    Height="1.5"
                    VerticalAlignment="Center"
                    Background="{Binding Foreground, ElementName=Root}"
                    CornerRadius="1" />
            <Border Grid.Row="2"
                    Height="1.5"
                    VerticalAlignment="Center"
                    Background="{Binding Foreground, ElementName=Root}"
                    CornerRadius="1" />
        </Grid>
    </Grid>
</UserControl>
