<UserControl x:Class="CodexController.Views.DevicePageView"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:loc="clr-namespace:CodexController.Localization"
             mc:Ignorable="d"
             d:DesignHeight="660"
             d:DesignWidth="1184">
<Grid x:Name="DevicePage">
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="375" />
    </Grid.ColumnDefinitions>

    <Grid Grid.Column="0" Margin="0,0,14,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="132" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{loc:Loc device.gamepad-bridge}"
                                   Foreground="{StaticResource Brush.Text.Secondary}"
                                   FontSize="{StaticResource Font.Size.Caption}"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{loc:Loc device.live-input}"
                                   Margin="0,3,0,0"
                                   FontSize="{StaticResource Font.Size.Display}"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                    <Border Grid.Column="1"
                            Padding="9,5"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="1"
                            CornerRadius="7"
                            VerticalAlignment="Top">
                        <TextBlock x:Name="ControllerLiveBadge"
                                   Text="{Binding ControllerLiveBadge}"
                                   FontFamily="{StaticResource Font.Mono}"
                                   FontSize="{StaticResource Font.Size.Caption}"
                                   FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground"
                                            Value="{StaticResource Brush.Status.Idle}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsControllerConnected}"
                                                     Value="True">
                                            <Setter Property="Foreground"
                                                    Value="{StaticResource Brush.Status.Success}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </Grid>

                <Viewbox Grid.Row="1"
                         Stretch="Uniform"
                         Margin="12,2">
                    <Grid Width="600" Height="380">
                        <Image Source="/Assets/controller.png"
                               Width="600"
                               Height="380"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                        <Canvas Width="600"
                                Height="380"
                                IsHitTestVisible="False">
                            <Border x:Name="LeftTriggerHalo"
                                    Canvas.Left="171"
                                    Canvas.Top="58"
                                    Width="54"
                                    Height="34"
                                    Background="{StaticResource Brush.Accent.Halo}"
                                    BorderBrush="{StaticResource Brush.Accent}"
                                    BorderThickness="2"
                                    CornerRadius="17"
                                    Opacity="0" />
                            <Border x:Name="LeftShoulderHalo"
                                    Canvas.Left="176"
                                    Canvas.Top="82"
                                    Width="100"
                                    Height="25"
                                    Background="{StaticResource Brush.Accent.Halo}"
                                    BorderBrush="{StaticResource Brush.Accent}"
                                    BorderThickness="2"
                                    CornerRadius="12"
                                    Opacity="0" />
                            <Border x:Name="RightShoulderHalo"
                                    Canvas.Left="324"
                                    Canvas.Top="82"
                                    Width="100"
                                    Height="25"
                                    Background="{StaticResource Brush.Accent.Halo}"
                                    BorderBrush="{StaticResource Brush.Accent}"
                                    BorderThickness="2"
                                    CornerRadius="12"
                                    Opacity="0" />
                            <Border x:Name="RightTriggerHalo"
                                    Canvas.Left="375"
                                    Canvas.Top="58"
                                    Width="54"
                                    Height="34"
                                    Background="{StaticResource Brush.Accent.Halo}"
                                    BorderBrush="{StaticResource Brush.Accent}"
                                    BorderThickness="2"
                                    CornerRadius="17"
                                    Opacity="0" />
                            <Ellipse x:Name="LeftStickHalo"
                                     Canvas.Left="178"
                                     Canvas.Top="138"
                                     Width="46"
                                     Height="46"
                                     Stroke="{StaticResource SageBrush}"
                                     StrokeThickness="2"
                                     Opacity="0.0">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform x:Name="LeftStickTransform" />
                                </Ellipse.RenderTransform>
                            </Ellipse>
                            <Ellipse x:Name="RightStickHalo"
                                     Canvas.Left="326"
                                     Canvas.Top="196"
                                     Width="46"
                                     Height="46"
                                     Stroke="{StaticResource SageBrush}"
                                     StrokeThickness="2"
                                     Opacity="0.0">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform x:Name="RightStickTransform" />
                                </Ellipse.RenderTransform>
                            </Ellipse>
                            <Ellipse x:Name="ButtonAHalo"
                                     Canvas.Left="384"
                                     Canvas.Top="172"
                                     Width="28"
                                     Height="28"
                                     Fill="{StaticResource Brush.Accent.Halo}"
                                     Stroke="{StaticResource Brush.Accent}"
                                     StrokeThickness="2"
                                     Opacity="0" />
                            <Ellipse x:Name="ButtonXHalo"
                                     Canvas.Left="359"
                                     Canvas.Top="146"
                                     Width="28"
                                     Height="28"
                                     Fill="{StaticResource Brush.Accent.Halo}"
                                     Stroke="{StaticResource Brush.Accent}"
                                     StrokeThickness="2"
                                     Opacity="0" />
                            <Ellipse x:Name="ButtonBHalo"
                                     Canvas.Left="411"
                                     Canvas.Top="146"
                                     Width="28"
                                     Height="28"
                                     Fill="{StaticResource Brush.Status.Danger.Halo}"
                                     Stroke="{StaticResource Brush.Status.Danger}"
                                     StrokeThickness="2"
                                     Opacity="0" />
                            <Ellipse x:Name="ButtonYHalo"
                                     Canvas.Left="385"
                                     Canvas.Top="120"
                                     Width="28"
                                     Height="28"
                                     Fill="{StaticResource Brush.Accent.Halo}"
                                     Stroke="{StaticResource Brush.Accent}"
                                     StrokeThickness="2"
                                     Opacity="0" />
                            <Ellipse x:Name="MenuButtonHalo"
                                     Canvas.Left="316"
                                     Canvas.Top="150"
                                     Width="24"
                                     Height="24"
                                     Fill="{StaticResource Brush.Accent.Halo}"
                                     Stroke="{StaticResource Brush.Accent}"
                                     StrokeThickness="2"
                                     Opacity="0" />
                            <Border Canvas.Left="158"
                                    Canvas.Top="46"
                                    Padding="6,2"
                                    Background="{StaticResource Brush.Bg.Inverse}"
                                    CornerRadius="8">
                                <TextBlock x:Name="LeftTriggerGlyphText"
                                           Text="{Binding LeftTriggerGlyph}"
                                           Foreground="{StaticResource Brush.Text.Inverse}"
                                           FontFamily="{StaticResource Font.Mono}"
                                           FontSize="{StaticResource Font.Size.Caption}"
                                           FontWeight="Bold" />
                            </Border>
                            <Border Canvas.Left="238"
                                    Canvas.Top="72"
                                    Padding="6,2"
                                    Background="{StaticResource Brush.Bg.Inverse}"
                                    CornerRadius="8">
                                <TextBlock x:Name="LeftShoulderGlyphText"
                                           Text="{Binding LeftShoulderGlyph}"
                                           Foreground="{StaticResource Brush.Text.Inverse}"
                                           FontFamily="{StaticResource Font.Mono}"
                                           FontSize="{StaticResource Font.Size.Caption}"
                                           FontWeight="Bold" />
                            </Border>
                            <Border Canvas.Left="338"
                                    Canvas.Top="72"
                                    Padding="6,2"
                                    Background="{StaticResource Brush.Bg.Inverse}"
                                    CornerRadius="8">
                                <TextBlock x:Name="RightShoulderGlyphText"
                                           Text="{Binding RightShoulderGlyph}"
                                           Foreground="{StaticResource Brush.Text.Inverse}"
                                           FontFamily="{StaticResource Font.Mono}"
                                           FontSize="{StaticResource Font.Size.Caption}"
                                           FontWeight="Bold" />
                            </Border>
                            <Border Canvas.Left="414"
                                    Canvas.Top="46"
                                    Padding="6,2"
                                    Background="{StaticResource Brush.Bg.Inverse}"
                                    CornerRadius="8">
                                <TextBlock x:Name="RightTriggerGlyphText"
                                           Text="{Binding RightTriggerGlyph}"
                                           Foreground="{StaticResource Brush.Text.Inverse}"
                                           FontFamily="{StaticResource Font.Mono}"
                                           FontSize="{StaticResource Font.Size.Caption}"
                                           FontWeight="Bold" />
                            </Border>
                        </Canvas>
                    </Grid>
                </Viewbox>

                <Grid Grid.Row="2" Margin="2,2,2,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{loc:Loc control.left-stick}"
                                   FontSize="{StaticResource Font.Size.Label}"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="LeftStickHintText"
                                   Text="{Binding LeftStickHint}"
                                   Margin="0,4,0,0"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="{StaticResource Font.Size.Caption}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{loc:Loc control.right-stick}"
                                   FontSize="{StaticResource Font.Size.Label}"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="RightStickHintText"
                                   Text="{Binding RightStickHint}"
                                   Margin="0,4,0,0"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="{StaticResource Font.Size.Caption}" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0"
                    Style="{StaticResource Card.Dense}"
                    Margin="0,0,5,0">
                <StackPanel>
                    <TextBlock x:Name="VoiceGlyphText"
                               Text="{Binding VoiceGlyph}"
                               Foreground="{StaticResource Brush.Text.Accent}"
                               FontSize="{StaticResource Font.Size.TitleLg}"
                               FontWeight="Bold" />
                    <TextBlock x:Name="VoiceActionTitle"
                               Text="{Binding VoiceActionTitle}"
                               Margin="0,4,0,0"
                               FontSize="{StaticResource Font.Size.Body}"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{loc:Loc control.hold-to-talk-description}"
                               Margin="0,3,0,0"
                               Foreground="{StaticResource Brush.Text.Secondary}"
                               FontSize="{StaticResource Font.Size.Caption}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <Border Grid.Column="1"
                    Style="{StaticResource Card.Dense}"
                    Margin="3,0">
                <StackPanel>
                    <TextBlock x:Name="SendGlyphText"
                               Text="{Binding SendGlyph}"
                               FontSize="{StaticResource Font.Size.TitleLg}"
                               FontWeight="Bold" />
                    <TextBlock x:Name="SendActionTitle"
                               Text="{Binding SendActionTitle}"
                               Margin="0,4,0,0"
                               FontSize="{StaticResource Font.Size.Body}"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{loc:Loc control.send-description}"
                               Margin="0,3,0,0"
                               Foreground="{StaticResource Brush.Text.Secondary}"
                               FontSize="{StaticResource Font.Size.Caption}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <Border Grid.Column="2"
                    Style="{StaticResource Card.Dense}"
                    Margin="3,0">
                <StackPanel>
                    <TextBlock x:Name="CancelGlyphText"
                               Text="{Binding CancelGlyph}"
                               Foreground="{StaticResource Brush.Status.Danger}"
                               FontSize="{StaticResource Font.Size.TitleLg}"
                               FontWeight="Bold" />
                    <TextBlock x:Name="CancelActionTitle"
                               Text="{Binding CancelActionTitle}"
                               Margin="0,4,0,0"
                               FontSize="{StaticResource Font.Size.Body}"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{loc:Loc control.cancel-undo-description}"
                               Margin="0,3,0,0"
                               Foreground="{StaticResource Brush.Text.Secondary}"
                               FontSize="{StaticResource Font.Size.Caption}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <Border Grid.Column="3"
                    Style="{StaticResource Card.Dense}"
                    Margin="3,0">
                <StackPanel>
                    <TextBlock x:Name="ProjectGlyphText"
                               Text="{Binding ProjectGlyph}"
                               Foreground="{StaticResource Brush.Text.Accent}"
                               FontSize="{StaticResource Font.Size.TitleLg}"
                               FontWeight="Bold" />
                    <TextBlock x:Name="ProjectActionTitle"
                               Text="{Binding ProjectActionTitle}"
                               Margin="0,4,0,0"
                               FontSize="{StaticResource Font.Size.Body}"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{loc:Loc control.project-context-description}"
                               Margin="0,3,0,0"
                               Foreground="{StaticResource Brush.Text.Secondary}"
                               FontSize="{StaticResource Font.Size.Caption}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <Border Grid.Column="4"
                    Style="{StaticResource Card.Dense}"
                    Margin="5,0,0,0">
                <StackPanel>
                    <TextBlock x:Name="WakeGlyphText"
                               Text="{Binding WakeGlyph}"
                               Foreground="{StaticResource Brush.Text.Accent}"
                               FontSize="{StaticResource Font.Size.Title}"
                               FontWeight="Bold" />
                    <TextBlock x:Name="WakeActionTitle"
                               Text="{Binding WakeActionTitle}"
                               Margin="0,4,0,0"
                               FontSize="{StaticResource Font.Size.Body}"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="WakeActionDescription"
                               Text="{Binding WakeActionDescription}"
                               Margin="0,3,0,0"
                               Foreground="{StaticResource Brush.Text.Secondary}"
                               FontSize="{StaticResource Font.Size.Caption}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>

    <Grid Grid.Column="1">
        <Grid.RowDefinitions>
            <RowDefinition Height="205" />
            <RowDefinition Height="*" />
            <RowDefinition Height="132" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid>
                    <TextBlock Text="{loc:Loc composer.right-stick-adjustment}"
                               FontSize="{StaticResource Font.Size.BodyLg}"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="CodexForegroundText"
                               Text="{Binding AgentStatusText}"
                               HorizontalAlignment="Right"
                               FontSize="{StaticResource Font.Size.Caption}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground"
                                        Value="{StaticResource Brush.Text.Secondary}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAgentStatusActive}"
                                                 Value="True">
                                        <Setter Property="Foreground"
                                                Value="{StaticResource Brush.Status.Success}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
                <Grid Grid.Row="1" Margin="0,13,0,11">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <RadioButton x:Name="ReasoningModeTab"
                                 Grid.Column="0"
                                 GroupName="ComposerMode"
                                 IsChecked="{Binding IsReasoningMode,
                                                     Mode=OneWay}"
                                 IsHitTestVisible="False"
                                 Style="{StaticResource Tab.Segment}"
                                 Content="{loc:Loc term.reasoning-effort}"
                                 Margin="0,0,3,0" />
                    <RadioButton x:Name="ModelModeTab"
                                 Grid.Column="1"
                                 GroupName="ComposerMode"
                                 IsChecked="{Binding IsModelMode,
                                                     Mode=OneWay}"
                                 IsHitTestVisible="False"
                                 Style="{StaticResource Tab.Segment}"
                                 Content="{loc:Loc term.model}"
                                 Margin="2,0" />
                    <RadioButton x:Name="SpeedModeTab"
                                 Grid.Column="2"
                                 GroupName="ComposerMode"
                                 IsChecked="{Binding IsSpeedMode,
                                                     Mode=OneWay}"
                                 IsHitTestVisible="False"
                                 Style="{StaticResource Tab.Segment}"
                                 Content="{loc:Loc term.speed}"
                                 Margin="3,0,0,0" />
                </Grid>
                <Border Grid.Row="2"
                        Background="{StaticResource Brush.Bg.Panel}"
                        BorderBrush="{StaticResource Brush.Border.Subtle}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource Radius.MD}"
                        Padding="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="30" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="↓"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="{StaticResource Font.Size.Title}" />
                        <StackPanel Grid.Column="1"
                                    HorizontalAlignment="Center">
                            <TextBlock x:Name="RightModeLabel"
                                       Text="{Binding RightModeLabel}"
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource Brush.Text.Secondary}"
                                       FontSize="{StaticResource Font.Size.Caption}" />
                            <TextBlock x:Name="RightModeValue"
                                       Text="{Binding RightModeValue}"
                                       Margin="0,4,0,0"
                                       HorizontalAlignment="Center"
                                       FontSize="{StaticResource Font.Size.TitleLg}"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                        <TextBlock Grid.Column="2"
                                   Text="↑"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="{StaticResource Font.Size.Title}" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource CardStyle}"
                Margin="0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid>
                    <StackPanel>
                        <TextBlock x:Name="SidebarTitleText"
                                   Text="{Binding SidebarTitle}"
                                   FontSize="{StaticResource Font.Size.BodyLg}"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="SelectedProjectText"
                                   Text="{Binding SidebarContextText}"
                                   Margin="0,3,0,0"
                                   Foreground="{StaticResource Brush.Text.Secondary}"
                                   FontSize="{StaticResource Font.Size.Caption}" />
                    </StackPanel>
                     <Button HorizontalAlignment="Right"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Height="28"
                             Padding="9,0"
                             Content="{loc:Loc sidebar.refresh}"
                             Command="{Binding RefreshCommand}" />
                </Grid>
                <Grid Grid.Row="1" Margin="0,12,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <RadioButton x:Name="PinnedLayerButton"
                                 Grid.Column="0"
                                 GroupName="SidebarRoot"
                                 Style="{StaticResource Tab.Segment}"
                                 Content="{loc:Loc sidebar.pinned-tasks}"
                                 IsChecked="{Binding IsPinnedTasksRootActive,
                                                     Mode=OneWay}"
                                 Command="{Binding SelectPinnedTasksCommand}" />
                    <RadioButton x:Name="PinnedProjectsLayerButton"
                                 Grid.Column="1"
                                 GroupName="SidebarRoot"
                                 Style="{StaticResource Tab.Segment}"
                                 Content="{loc:Loc sidebar.pinned-projects}"
                                 IsChecked="{Binding IsPinnedProjectsRootActive,
                                                     Mode=OneWay}"
                                 Command="{Binding SelectPinnedProjectsCommand}" />
                    <RadioButton x:Name="ProjectsLayerButton"
                                 Grid.Column="2"
                                 GroupName="SidebarRoot"
                                 Style="{StaticResource Tab.Segment}"
                                 Content="{loc:Loc sidebar.projects}"
                                 IsChecked="{Binding IsProjectsRootActive,
                                                     Mode=OneWay}"
                                 Command="{Binding SelectProjectsCommand}" />
                    <RadioButton x:Name="TasksLayerButton"
                                 Grid.Column="3"
                                 GroupName="SidebarRoot"
                                 Style="{StaticResource Tab.Segment}"
                                 Content="{loc:Loc sidebar.projectless-tasks}"
                                 IsChecked="{Binding IsProjectlessTasksRootActive,
                                                     Mode=OneWay}"
                                 Command="{Binding SelectProjectlessTasksCommand}" />
                </Grid>
                <ListBox x:Name="SidebarList"
                         Grid.Row="2"
                         Style="{StaticResource ListBox.Sidebar}"
                         ItemsSource="{Binding SidebarEntries}"
                         SelectionChanged="SidebarList_SelectionChanged"
                         MouseDoubleClick="SidebarList_MouseDoubleClick"
                         PreviewKeyDown="SidebarList_PreviewKeyDown">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding KindGlyph}"
                                           Foreground="{StaticResource Brush.Text.Accent}"
                                           FontSize="{StaticResource Font.Size.Title}"
                                           VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1"
                                            Margin="8,0,8,0">
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="{StaticResource Font.Size.Body}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Subtitle}"
                                               Margin="0,3,0,0"
                                               Foreground="{StaticResource Brush.Text.Secondary}"
                                               FontSize="{StaticResource Font.Size.Caption}" />
                                </StackPanel>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding PinBadge}"
                                           Margin="0,0,8,0"
                                           Foreground="{StaticResource Brush.Text.Accent}"
                                           FontSize="{StaticResource Font.Size.Caption}"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Column="3"
                                           Text="{Binding ActionHint}"
                                           Foreground="{StaticResource Brush.Text.Secondary}"
                                           FontSize="{StaticResource Font.Size.Caption}"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid>
                    <TextBlock Text="{loc:Loc sidebar.recent-events}"
                               FontSize="{StaticResource Font.Size.Body}"
                               FontWeight="SemiBold" />
                    <Ellipse x:Name="EventPulse"
                             Width="6"
                             Height="6"
                             HorizontalAlignment="Right"
                             Fill="{StaticResource SageBrush}" />
                </Grid>
                <ItemsControl x:Name="EventList"
                              Grid.Row="1"
                              ItemsSource="{Binding RecentEvents}"
                              Margin="0,8,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Time}"
                                           Foreground="{StaticResource Brush.Text.Secondary}"
                                           FontFamily="{StaticResource Font.Mono}"
                                           FontSize="{StaticResource Font.Size.Caption}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Text}"
                                           Foreground="{StaticResource Brush.Text.Secondary}"
                                           FontSize="{StaticResource Font.Size.Caption}"
                                           TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>
    </Grid>
</Grid>
</UserControl>
