<UserControl x:Class="CodexController.Views.DevicePageView"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:loc="clr-namespace:CodexController.Localization"
             xmlns:views="clr-namespace:CodexController.Views"
             mc:Ignorable="d"
             d:DesignHeight="660"
             d:DesignWidth="1184">
<Grid x:Name="DevicePage">
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="375" />
    </Grid.ColumnDefinitions>

    <Grid Grid.Column="0" Margin="0,0,14,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="132" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding Tutorial.Heading}"
                                   Foreground="{StaticResource Brush.Text.Primary}"
                                   FontSize="{StaticResource Font.Size.Display}"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Tutorial.Subheading}"
                                   Margin="0,3,0,0"
                                   Foreground="{StaticResource Brush.Text.Secondary}"
                                   FontSize="{StaticResource Font.Size.Caption}" />
                    </StackPanel>
                    <Border Grid.Column="1"
                            Padding="9,5"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="1"
                            CornerRadius="7"
                            VerticalAlignment="Top">
                        <TextBlock x:Name="ControllerLiveBadge"
                                   Text="{Binding ControllerLiveBadge}"
                                   FontFamily="{StaticResource Font.Mono}"
                                   FontSize="{StaticResource Font.Size.Caption}"
                                   FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground"
                                            Value="{StaticResource Brush.Status.Idle}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsControllerConnected}"
                                                     Value="True">
                                            <Setter Property="Foreground"
                                                    Value="{StaticResource Brush.Status.Success}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </Grid>

                <views:ControllerTutorialView x:Name="ControllerTutorial"
                                              Grid.Row="1"
                                              Margin="0,10,0,0"
                                              DataContext="{Binding Tutorial}" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0"
                    Style="{StaticResource Card.Dense}"
                    Margin="0,0,5,0">
                <StackPanel>
                    <TextBlock x:Name="PrimaryGlyphText"
                               Text="{Binding PrimaryGlyph}"
                               Foreground="{StaticResource Brush.Text.Accent}"
                               FontSize="{StaticResource Font.Size.TitleLg}"
                               FontWeight="Bold" />
                    <TextBlock x:Name="PrimaryActionTitle"
                               Text="{Binding PrimaryActionTitle}"
                               Margin="0,4,0,0"
                               FontSize="{StaticResource Font.Size.Body}"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{loc:Loc control.primary-description}"
                               Margin="0,3,0,0"
                               Foreground="{StaticResource Brush.Text.Secondary}"
                               FontSize="{StaticResource Font.Size.Caption}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <Border Grid.Column="1"
                    Style="{StaticResource Card.Dense}"
                    Margin="3,0">
                <StackPanel>
                    <TextBlock x:Name="VoiceGlyphText"
                               Text="{Binding VoiceGlyph}"
                               Foreground="{StaticResource Brush.Text.Accent}"
                               FontSize="{StaticResource Font.Size.TitleLg}"
                               FontWeight="Bold" />
                    <TextBlock x:Name="VoiceActionTitle"
                               Text="{Binding VoiceActionTitle}"
                               Margin="0,4,0,0"
                               FontSize="{StaticResource Font.Size.Body}"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{loc:Loc control.hold-to-talk-description}"
                               Margin="0,3,0,0"
                               Foreground="{StaticResource Brush.Text.Secondary}"
                               FontSize="{StaticResource Font.Size.Caption}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <Border Grid.Column="2"
                    Style="{StaticResource Card.Dense}"
                    Margin="3,0">
                <StackPanel>
                    <TextBlock x:Name="SendGlyphText"
                               Text="{Binding SendGlyph}"
                               FontSize="{StaticResource Font.Size.TitleLg}"
                               FontWeight="Bold" />
                    <TextBlock x:Name="SendActionTitle"
                               Text="{Binding SendActionTitle}"
                               Margin="0,4,0,0"
                               FontSize="{StaticResource Font.Size.Body}"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{loc:Loc control.send-description}"
                               Margin="0,3,0,0"
                               Foreground="{StaticResource Brush.Text.Secondary}"
                               FontSize="{StaticResource Font.Size.Caption}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <Border Grid.Column="3"
                    Style="{StaticResource Card.Dense}"
                    Margin="3,0">
                <StackPanel>
                    <TextBlock x:Name="CancelGlyphText"
                               Text="{Binding CancelGlyph}"
                               Foreground="{StaticResource Brush.Status.Danger}"
                               FontSize="{StaticResource Font.Size.TitleLg}"
                               FontWeight="Bold" />
                    <TextBlock x:Name="CancelActionTitle"
                               Text="{Binding CancelActionTitle}"
                               Margin="0,4,0,0"
                               FontSize="{StaticResource Font.Size.Body}"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{loc:Loc control.cancel-undo-description}"
                               Margin="0,3,0,0"
                               Foreground="{StaticResource Brush.Text.Secondary}"
                               FontSize="{StaticResource Font.Size.Caption}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <Border Grid.Column="4"
                    Style="{StaticResource Card.Dense}"
                    Margin="3,0">
                <StackPanel>
                    <TextBlock x:Name="ProjectGlyphText"
                               Text="{Binding ProjectGlyph}"
                               Foreground="{StaticResource Brush.Text.Accent}"
                               FontSize="{StaticResource Font.Size.TitleLg}"
                               FontWeight="Bold" />
                    <TextBlock x:Name="ProjectActionTitle"
                               Text="{Binding ProjectActionTitle}"
                               Margin="0,4,0,0"
                               FontSize="{StaticResource Font.Size.Body}"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{loc:Loc control.project-context-description}"
                               Margin="0,3,0,0"
                               Foreground="{StaticResource Brush.Text.Secondary}"
                               FontSize="{StaticResource Font.Size.Caption}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <Border Grid.Column="5"
                    Style="{StaticResource Card.Dense}"
                    Margin="5,0,0,0">
                <StackPanel>
                    <TextBlock x:Name="WakeGlyphText"
                               Text="{Binding WakeGlyph}"
                               Foreground="{StaticResource Brush.Text.Accent}"
                               FontSize="{StaticResource Font.Size.Title}"
                               FontWeight="Bold" />
                    <TextBlock x:Name="WakeActionTitle"
                               Text="{Binding WakeActionTitle}"
                               Margin="0,4,0,0"
                               FontSize="{StaticResource Font.Size.Body}"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="WakeActionDescription"
                               Text="{Binding WakeActionDescription}"
                               Margin="0,3,0,0"
                               Foreground="{StaticResource Brush.Text.Secondary}"
                               FontSize="{StaticResource Font.Size.Caption}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>

    <Grid Grid.Column="1">
        <Grid.RowDefinitions>
            <RowDefinition Height="205" />
            <RowDefinition Height="*" />
            <RowDefinition Height="132" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid>
                    <TextBlock Text="{loc:Loc composer.right-stick-adjustment}"
                               FontSize="{StaticResource Font.Size.BodyLg}"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="CodexForegroundText"
                               Text="{Binding AgentStatusText}"
                               HorizontalAlignment="Right"
                               FontSize="{StaticResource Font.Size.Caption}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground"
                                        Value="{StaticResource Brush.Text.Secondary}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAgentStatusActive}"
                                                 Value="True">
                                        <Setter Property="Foreground"
                                                Value="{StaticResource Brush.Status.Success}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
                <Border Grid.Row="1"
                        Margin="0,13,0,11"
                        Padding="12,8"
                        Background="{StaticResource Brush.Bg.Sunken}"
                        CornerRadius="{StaticResource Radius.MD}">
                    <TextBlock Text="{Binding RightStickHint}"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource Brush.Text.Secondary}"
                               FontSize="{StaticResource Font.Size.Label}"
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                </Border>
                <Border Grid.Row="2"
                        Background="{StaticResource Brush.Bg.Panel}"
                        BorderBrush="{StaticResource Brush.Border.Subtle}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource Radius.MD}"
                        Padding="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="30" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="←"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="{StaticResource Font.Size.Title}" />
                        <StackPanel Grid.Column="1"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center">
                            <TextBlock x:Name="RightModeLabel"
                                       Text="{Binding RightModeLabel}"
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource Brush.Text.Secondary}"
                                       FontSize="{StaticResource Font.Size.Caption}" />
                            <TextBlock x:Name="RightModeValue"
                                       Text="{Binding RightModeValue}"
                                       Margin="0,4,0,0"
                                       HorizontalAlignment="Stretch"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       TextTrimming="CharacterEllipsis"
                                       MaxHeight="42"
                                       LineHeight="20"
                                       FontSize="{StaticResource Font.Size.Title}"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                        <TextBlock Grid.Column="2"
                                   Text="→"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="{StaticResource Font.Size.Title}" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource CardStyle}"
                Margin="0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid>
                    <StackPanel Margin="0,0,82,0">
                        <TextBlock x:Name="SidebarTitleText"
                                   Text="{Binding SidebarTitle}"
                                   FontSize="{StaticResource Font.Size.BodyLg}"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="SelectedProjectText"
                                   Text="{Binding SidebarContextText}"
                                   Margin="0,3,0,0"
                                   Foreground="{StaticResource Brush.Text.Secondary}"
                                   FontSize="{StaticResource Font.Size.Caption}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility"
                                            Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsProjectDirectory}"
                                                     Value="True">
                                            <Setter Property="Visibility"
                                                    Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <StackPanel Margin="0,5,0,0"
                                    Orientation="Horizontal">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility"
                                            Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsProjectDirectory}"
                                                     Value="True">
                                            <Setter Property="Visibility"
                                                    Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Border Padding="7,3"
                                    Background="{StaticResource Brush.Bg.Sunken}"
                                    BorderBrush="{StaticResource Brush.Border.Subtle}"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <TextBlock Text="{Binding SidebarProjectName}"
                                           Foreground="{StaticResource Brush.Text.Primary}"
                                           FontSize="{StaticResource Font.Size.Caption}"
                                           FontWeight="SemiBold"
                                           MaxWidth="150"
                                           TextTrimming="CharacterEllipsis" />
                            </Border>
                            <TextBlock Margin="7,0"
                                       Text="›"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource Brush.Text.Tertiary}"
                                       FontSize="{StaticResource Font.Size.Caption}" />
                            <Border Padding="7,3"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background"
                                                Value="{StaticResource Brush.Bg.Surface}" />
                                        <Setter Property="BorderBrush"
                                                Value="{StaticResource Brush.Border.Subtle}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsProjectTasksPinnedOnly}"
                                                         Value="True">
                                                <Setter Property="Background"
                                                        Value="{StaticResource Brush.Accent.Soft}" />
                                                <Setter Property="BorderBrush"
                                                        Value="{StaticResource Brush.Border.Accent}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding SidebarProjectFilterText}"
                                           FontSize="{StaticResource Font.Size.Caption}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground"
                                                    Value="{StaticResource Brush.Text.Secondary}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsProjectTasksPinnedOnly}"
                                                             Value="True">
                                                    <Setter Property="Foreground"
                                                            Value="{StaticResource Brush.Text.Accent}" />
                                                    <Setter Property="FontWeight"
                                                            Value="SemiBold" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                    <Button HorizontalAlignment="Right"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Height="28"
                            Padding="9,0"
                            Content="{loc:Loc sidebar.refresh}"
                            Command="{Binding RefreshCommand}" />
                </Grid>
                <Grid Grid.Row="1" Margin="0,12,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <RadioButton x:Name="PinnedLayerButton"
                                 Grid.Column="0"
                                 GroupName="SidebarRoot"
                                 Style="{StaticResource Tab.Segment}"
                                 Content="{loc:Loc sidebar.pinned-tasks}"
                                 IsChecked="{Binding IsPinnedTasksRootActive,
                                                     Mode=OneWay}"
                                 Command="{Binding SelectPinnedTasksCommand}" />
                    <RadioButton x:Name="PinnedProjectsLayerButton"
                                 Grid.Column="1"
                                 GroupName="SidebarRoot"
                                 Style="{StaticResource Tab.Segment}"
                                 Content="{loc:Loc sidebar.pinned-projects}"
                                 IsChecked="{Binding IsPinnedProjectsRootActive,
                                                     Mode=OneWay}"
                                 Command="{Binding SelectPinnedProjectsCommand}" />
                    <RadioButton x:Name="ProjectsLayerButton"
                                 Grid.Column="2"
                                 GroupName="SidebarRoot"
                                 Style="{StaticResource Tab.Segment}"
                                 Content="{loc:Loc sidebar.projects}"
                                 IsChecked="{Binding IsProjectsRootActive,
                                                     Mode=OneWay}"
                                 Command="{Binding SelectProjectsCommand}" />
                    <RadioButton x:Name="TasksLayerButton"
                                 Grid.Column="3"
                                 GroupName="SidebarRoot"
                                 Style="{StaticResource Tab.Segment}"
                                 Content="{loc:Loc sidebar.projectless-tasks}"
                                 IsChecked="{Binding IsProjectlessTasksRootActive,
                                                     Mode=OneWay}"
                                 Command="{Binding SelectProjectlessTasksCommand}" />
                </Grid>
                <ListBox x:Name="SidebarList"
                         Grid.Row="2"
                         Style="{StaticResource ListBox.Sidebar}"
                         ItemsSource="{Binding SidebarEntries}"
                         SelectionChanged="SidebarList_SelectionChanged"
                         MouseDoubleClick="SidebarList_MouseDoubleClick"
                         PreviewKeyDown="SidebarList_PreviewKeyDown">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding KindGlyph}"
                                           Foreground="{StaticResource Brush.Text.Accent}"
                                           FontSize="{StaticResource Font.Size.Title}"
                                           VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1"
                                            Margin="8,0,8,0">
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="{StaticResource Font.Size.Body}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Subtitle}"
                                               Margin="0,3,0,0"
                                               Foreground="{StaticResource Brush.Text.Secondary}"
                                               FontSize="{StaticResource Font.Size.Caption}" />
                                </StackPanel>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding PinBadge}"
                                           Margin="0,0,8,0"
                                           Foreground="{StaticResource Brush.Text.Accent}"
                                           FontSize="{StaticResource Font.Size.Caption}"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Column="3"
                                           Text="{Binding ActionHint}"
                                           Foreground="{StaticResource Brush.Text.Secondary}"
                                           FontSize="{StaticResource Font.Size.Caption}"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid>
                    <TextBlock Text="{loc:Loc sidebar.recent-events}"
                               FontSize="{StaticResource Font.Size.Body}"
                               FontWeight="SemiBold" />
                    <Ellipse x:Name="EventPulse"
                             Width="6"
                             Height="6"
                             HorizontalAlignment="Right"
                             Fill="{StaticResource SageBrush}" />
                </Grid>
                <ItemsControl x:Name="EventList"
                              Grid.Row="1"
                              ItemsSource="{Binding RecentEvents}"
                              Margin="0,8,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Time}"
                                           Foreground="{StaticResource Brush.Text.Secondary}"
                                           FontFamily="{StaticResource Font.Mono}"
                                           FontSize="{StaticResource Font.Size.Caption}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Text}"
                                           Foreground="{StaticResource Brush.Text.Secondary}"
                                           FontSize="{StaticResource Font.Size.Caption}"
                                           TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>
    </Grid>
</Grid>
</UserControl>
