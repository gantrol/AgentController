<UserControl x:Class="CodexController.Views.DevicePageView"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:loc="clr-namespace:CodexController.Localization"
             xmlns:views="clr-namespace:CodexController.Views"
             mc:Ignorable="d"
             d:DesignHeight="660"
             d:DesignWidth="1184">
    <UserControl.Resources>
        <Style x:Key="Sidebar.ScopeGlyph"
               TargetType="ContentControl">
            <Setter Property="Width" Value="21" />
            <Setter Property="Height" Value="21" />
            <Setter Property="IsHitTestVisible" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContentControl">
                        <Viewbox Stretch="Uniform"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Stretch">
                            <Grid Width="24" Height="24">
                                <Grid x:Name="PinnedTasksGlyph"
                                      Visibility="Collapsed">
                                    <Path Data="M 4,2 H 12 L 11,7 L 14,10 V 12 H 9.5 V 18 L 8,20 L 6.5,18 V 12 H 2 V 10 L 5,7 Z"
                                          Fill="Transparent"
                                          Stroke="{TemplateBinding Foreground}"
                                          StrokeThickness="1.45"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round" />
                                    <Path Data="M 14.5,14 H 21.5 V 22 H 14.5 Z M 16.5,17 H 19.7 M 16.5,19.5 H 19.7"
                                          Fill="Transparent"
                                          Stroke="{TemplateBinding Foreground}"
                                          StrokeThickness="1.35"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round" />
                                </Grid>

                                <Grid x:Name="PinnedProjectsGlyph"
                                      Visibility="Collapsed">
                                    <Path Data="M 4,2 H 12 L 11,7 L 14,10 V 12 H 9.5 V 18 L 8,20 L 6.5,18 V 12 H 2 V 10 L 5,7 Z"
                                          Fill="Transparent"
                                          Stroke="{TemplateBinding Foreground}"
                                          StrokeThickness="1.45"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round" />
                                    <Path Data="M 13.5,15 H 17 L 18.5,16.5 H 22 V 21.5 H 13.5 Z"
                                          Fill="Transparent"
                                          Stroke="{TemplateBinding Foreground}"
                                          StrokeThickness="1.35"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round" />
                                </Grid>

                                <Grid x:Name="ProjectsGlyph"
                                      Visibility="Collapsed">
                                    <Path Data="M 2.5,6.5 H 9 L 11,9 H 21.5 V 18.5 H 2.5 Z"
                                          Fill="Transparent"
                                          Stroke="{TemplateBinding Foreground}"
                                          StrokeThickness="1.55"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round" />
                                </Grid>

                                <Grid x:Name="ProjectlessTasksGlyph"
                                      Visibility="Collapsed">
                                    <Ellipse Width="3.5"
                                             Height="3.5"
                                             Margin="1.5,0,0,0"
                                             HorizontalAlignment="Left"
                                             VerticalAlignment="Center"
                                             Stroke="{TemplateBinding Foreground}"
                                             StrokeThickness="1.4" />
                                    <Path Data="M 7,3 H 15 L 19,7 V 21 H 7 Z M 15,3 V 7 H 19 M 10,11 H 16 M 10,15 H 16"
                                          Fill="Transparent"
                                          Stroke="{TemplateBinding Foreground}"
                                          StrokeThickness="1.45"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round" />
                                </Grid>
                            </Grid>
                        </Viewbox>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag" Value="PinnedTasks">
                                <Setter TargetName="PinnedTasksGlyph"
                                        Property="Visibility"
                                        Value="Visible" />
                            </Trigger>
                            <Trigger Property="Tag" Value="PinnedProjects">
                                <Setter TargetName="PinnedProjectsGlyph"
                                        Property="Visibility"
                                        Value="Visible" />
                            </Trigger>
                            <Trigger Property="Tag" Value="Projects">
                                <Setter TargetName="ProjectsGlyph"
                                        Property="Visibility"
                                        Value="Visible" />
                            </Trigger>
                            <Trigger Property="Tag" Value="ProjectlessTasks">
                                <Setter TargetName="ProjectlessTasksGlyph"
                                        Property="Visibility"
                                        Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
<Grid x:Name="DevicePage">
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="375" />
    </Grid.ColumnDefinitions>

    <Grid Grid.Column="0" Margin="0,0,14,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="108" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource Card.Plain}">
            <views:ControllerTutorialView x:Name="ControllerTutorial"
                                          DataContext="{Binding Tutorial}" />
        </Border>

        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0"
                    Style="{StaticResource Card.ActionSlot}"
                    ToolTip="{loc:Loc control.primary-description}">
                <StackPanel>
                    <Border HorizontalAlignment="Left"
                            Style="{StaticResource Overlay.PhysicalKey.Chip}">
                        <TextBlock x:Name="PrimaryGlyphText"
                                   Text="{Binding PrimaryGlyph}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource Brush.Text.Accent}"
                                   FontSize="{StaticResource Font.Size.TitleLg}"
                                   FontWeight="Bold" />
                    </Border>
                    <TextBlock x:Name="PrimaryActionTitle"
                               Text="{Binding PrimaryActionTitle}"
                               Margin="0,4,0,0"
                               FontSize="{StaticResource Font.Size.Body}"
                               FontWeight="SemiBold" />
                </StackPanel>
            </Border>
            <Border Grid.Column="1"
                    Style="{StaticResource Card.ActionSlot}"
                    ToolTip="{loc:Loc control.hold-to-talk-description}">
                <StackPanel>
                    <Border HorizontalAlignment="Left"
                            Style="{StaticResource Overlay.PhysicalKey.Chip}">
                        <TextBlock x:Name="VoiceGlyphText"
                                   Text="{Binding VoiceGlyph}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource Brush.Text.Accent}"
                                   FontSize="{StaticResource Font.Size.TitleLg}"
                                   FontWeight="Bold" />
                    </Border>
                    <TextBlock x:Name="VoiceActionTitle"
                               Text="{Binding VoiceActionTitle}"
                               Margin="0,4,0,0"
                               FontSize="{StaticResource Font.Size.Body}"
                               FontWeight="SemiBold" />
                </StackPanel>
            </Border>
            <Border Grid.Column="2"
                    Style="{StaticResource Card.ActionSlot}"
                    ToolTip="{loc:Loc control.send-description}">
                <StackPanel>
                    <Border HorizontalAlignment="Left"
                            Style="{StaticResource Overlay.PhysicalKey.Chip}">
                        <TextBlock x:Name="SendGlyphText"
                                   Text="{Binding SendGlyph}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="{StaticResource Font.Size.TitleLg}"
                                   FontWeight="Bold" />
                    </Border>
                    <TextBlock x:Name="SendActionTitle"
                               Text="{Binding SendActionTitle}"
                               Margin="0,4,0,0"
                               FontSize="{StaticResource Font.Size.Body}"
                               FontWeight="SemiBold" />
                </StackPanel>
            </Border>
            <Border Grid.Column="3"
                    Style="{StaticResource Card.ActionSlot}"
                    ToolTip="{loc:Loc control.cancel-undo-description}">
                <StackPanel>
                    <Border HorizontalAlignment="Left"
                            Style="{StaticResource Overlay.PhysicalKey.Chip}">
                        <TextBlock x:Name="CancelGlyphText"
                                   Text="{Binding CancelGlyph}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource Brush.Status.Danger}"
                                   FontSize="{StaticResource Font.Size.TitleLg}"
                                   FontWeight="Bold" />
                    </Border>
                    <TextBlock x:Name="CancelActionTitle"
                               Text="{Binding CancelActionTitle}"
                               Margin="0,4,0,0"
                               FontSize="{StaticResource Font.Size.Body}"
                               FontWeight="SemiBold" />
                </StackPanel>
            </Border>
            <Border Grid.Column="4"
                    Style="{StaticResource Card.ActionSlot}"
                    ToolTip="{loc:Loc control.project-context-description}">
                <StackPanel>
                    <Border HorizontalAlignment="Left"
                            Style="{StaticResource Overlay.PhysicalKey.Chip}">
                        <TextBlock x:Name="ProjectGlyphText"
                                   Text="{Binding ProjectGlyph}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource Brush.Text.Accent}"
                                   FontSize="{StaticResource Font.Size.TitleLg}"
                                   FontWeight="Bold" />
                    </Border>
                    <TextBlock x:Name="ProjectActionTitle"
                               Text="{Binding ProjectActionTitle}"
                               Margin="0,4,0,0"
                               FontSize="{StaticResource Font.Size.Body}"
                               FontWeight="SemiBold" />
                </StackPanel>
            </Border>
            <Border Grid.Column="5"
                    Style="{StaticResource Card.ActionSlot.Last}"
                    ToolTip="{Binding WakeActionDescription}">
                <StackPanel>
                    <Border HorizontalAlignment="Left"
                            Style="{StaticResource Overlay.PhysicalKey.Chip}">
                        <views:ControllerGlyphView x:Name="WakeGlyphText"
                                                   Width="30"
                                                   Height="28"
                                                   Glyph="{Binding WakeGlyph}"
                                                   Foreground="{StaticResource Brush.Text.Accent}"
                                                   FontSize="{StaticResource Font.Size.Title}"
                                                   FontWeight="Bold" />
                    </Border>
                    <TextBlock x:Name="WakeActionTitle"
                               Text="{Binding WakeActionTitle}"
                               Margin="0,4,0,0"
                               FontSize="{StaticResource Font.Size.Body}"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="WakeActionDescription"
                               Text="{Binding WakeActionDescription}"
                               Visibility="Collapsed" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>

    <Grid Grid.Column="1">
        <Grid.RowDefinitions>
            <RowDefinition Height="174" />
            <RowDefinition Height="*" />
            <RowDefinition Height="108" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource Card.Plain}"
                ToolTip="{Binding RightStickHint}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid>
                    <TextBlock Text="{loc:Loc composer.right-stick-adjustment}"
                               FontSize="{StaticResource Font.Size.BodyLg}"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="CodexForegroundText"
                               Text="{Binding AgentStatusText}"
                               HorizontalAlignment="Right"
                               FontSize="{StaticResource Font.Size.Caption}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground"
                                        Value="{StaticResource Brush.Text.Secondary}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAgentStatusActive}"
                                                 Value="True">
                                        <Setter Property="Foreground"
                                                Value="{StaticResource Brush.Status.Success}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
                <Border Grid.Row="1"
                        Visibility="Collapsed">
                    <TextBlock Text="{Binding RightStickHint}"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource Brush.Text.Secondary}"
                               FontSize="{StaticResource Font.Size.Label}"
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                </Border>
                <Border Grid.Row="2"
                        Background="#38FFFFFF"
                        BorderThickness="0"
                        CornerRadius="0"
                        Padding="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="30" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="←"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="{StaticResource Font.Size.Title}" />
                        <StackPanel Grid.Column="1"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center">
                            <TextBlock x:Name="RightModeLabel"
                                       Text="{Binding RightModeLabel}"
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource Brush.Text.Secondary}"
                                       FontSize="{StaticResource Font.Size.Caption}" />
                            <TextBlock x:Name="RightModeValue"
                                       Text="{Binding RightModeValue}"
                                       Margin="0,4,0,0"
                                       HorizontalAlignment="Stretch"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       TextTrimming="CharacterEllipsis"
                                       MaxHeight="42"
                                       LineHeight="20"
                                       FontSize="{StaticResource Font.Size.Title}"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                        <TextBlock Grid.Column="2"
                                   Text="→"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="{StaticResource Font.Size.Title}" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource CardStyle}"
                Margin="0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid>
                    <StackPanel Margin="0,0,82,0">
                        <TextBlock x:Name="SidebarTitleText"
                                   Text="{Binding SidebarTitle}"
                                   FontSize="{StaticResource Font.Size.BodyLg}"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="SelectedProjectText"
                                   Text="{Binding SidebarContextText}"
                                   Margin="0,3,0,0"
                                   Foreground="{StaticResource Brush.Text.Secondary}"
                                   FontSize="{StaticResource Font.Size.Caption}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility"
                                            Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsProjectDirectory}"
                                                     Value="True">
                                            <Setter Property="Visibility"
                                                    Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <StackPanel Margin="0,5,0,0"
                                    Orientation="Horizontal">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility"
                                            Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsProjectDirectory}"
                                                     Value="True">
                                            <Setter Property="Visibility"
                                                    Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="{Binding SidebarProjectName}"
                                       Foreground="{StaticResource Brush.Text.Primary}"
                                       FontSize="{StaticResource Font.Size.Caption}"
                                       FontWeight="SemiBold"
                                       MaxWidth="150"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Margin="7,0"
                                       Text="›"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource Brush.Text.Tertiary}"
                                       FontSize="{StaticResource Font.Size.Caption}" />
                            <TextBlock Text="{Binding SidebarProjectFilterText}"
                                       FontSize="{StaticResource Font.Size.Caption}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground"
                                                Value="{StaticResource Brush.Text.Secondary}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsProjectTasksPinnedOnly}"
                                                         Value="True">
                                                <Setter Property="Foreground"
                                                        Value="{StaticResource Brush.Text.Accent}" />
                                                <Setter Property="FontWeight"
                                                        Value="SemiBold" />
                                                <Setter Property="TextDecorations"
                                                        Value="Underline" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                    <Button HorizontalAlignment="Right"
                            Style="{StaticResource Shell.IconButton}"
                            Content="↻"
                            ToolTip="{loc:Loc sidebar.refresh}"
                            AutomationProperties.Name="{loc:Loc sidebar.refresh}"
                            Command="{Binding RefreshCommand}" />
                </Grid>
                <Grid Grid.Row="1"
                      Margin="20,12,20,0"
                      Panel.ZIndex="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <RadioButton x:Name="PinnedLayerButton"
                                 Grid.Column="0"
                                 GroupName="SidebarRoot"
                                 Style="{StaticResource Tab.SidebarScope}"
                                 ToolTip="{loc:Loc sidebar.pinned-tasks}"
                                 AutomationProperties.Name="{loc:Loc sidebar.pinned-tasks}"
                                 IsChecked="{Binding IsPinnedTasksRootActive,
                                                     Mode=OneWay}"
                                 Command="{Binding SelectPinnedTasksCommand}">
                        <ContentControl x:Name="PinnedTasksScopeGlyph"
                                        Tag="PinnedTasks"
                                        Style="{StaticResource Sidebar.ScopeGlyph}" />
                    </RadioButton>
                    <RadioButton x:Name="PinnedProjectsLayerButton"
                                 Grid.Column="1"
                                 GroupName="SidebarRoot"
                                 Style="{StaticResource Tab.SidebarScope}"
                                 ToolTip="{loc:Loc sidebar.pinned-projects}"
                                 AutomationProperties.Name="{loc:Loc sidebar.pinned-projects}"
                                 IsChecked="{Binding IsPinnedProjectsRootActive,
                                                     Mode=OneWay}"
                                 Command="{Binding SelectPinnedProjectsCommand}">
                        <ContentControl x:Name="PinnedProjectsScopeGlyph"
                                        Tag="PinnedProjects"
                                        Style="{StaticResource Sidebar.ScopeGlyph}" />
                    </RadioButton>
                    <RadioButton x:Name="ProjectsLayerButton"
                                 Grid.Column="2"
                                 GroupName="SidebarRoot"
                                 Style="{StaticResource Tab.SidebarScope}"
                                 ToolTip="{loc:Loc sidebar.projects}"
                                 AutomationProperties.Name="{loc:Loc sidebar.projects}"
                                 IsChecked="{Binding IsProjectsRootActive,
                                                     Mode=OneWay}"
                                 Command="{Binding SelectProjectsCommand}">
                        <ContentControl x:Name="ProjectsScopeGlyph"
                                        Tag="Projects"
                                        Style="{StaticResource Sidebar.ScopeGlyph}" />
                    </RadioButton>
                    <RadioButton x:Name="TasksLayerButton"
                                 Grid.Column="3"
                                 GroupName="SidebarRoot"
                                 Style="{StaticResource Tab.SidebarScope}"
                                 ToolTip="{loc:Loc sidebar.projectless-tasks}"
                                 AutomationProperties.Name="{loc:Loc sidebar.projectless-tasks}"
                                 IsChecked="{Binding IsProjectlessTasksRootActive,
                                                     Mode=OneWay}"
                                 Command="{Binding SelectProjectlessTasksCommand}">
                        <ContentControl x:Name="ProjectlessTasksScopeGlyph"
                                        Tag="ProjectlessTasks"
                                        Style="{StaticResource Sidebar.ScopeGlyph}" />
                    </RadioButton>
                </Grid>
                <Border Grid.Row="2"
                        Margin="0,0,0,0"
                        Padding="4"
                        Style="{StaticResource Panel.ConnectedTab}">
                <ListBox x:Name="SidebarList"
                         Style="{StaticResource ListBox.Sidebar}"
                         ItemsSource="{Binding SidebarEntries}"
                         SelectionChanged="SidebarList_SelectionChanged"
                         MouseDoubleClick="SidebarList_MouseDoubleClick"
                         PreviewKeyDown="SidebarList_PreviewKeyDown">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="22" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0"
                                      Width="22"
                                      VerticalAlignment="Center">
                                    <TextBlock Text="{Binding KindGlyph}"
                                               HorizontalAlignment="Center"
                                               Foreground="{StaticResource Brush.Text.Accent}"
                                               FontSize="{StaticResource Font.Size.Title}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsProject}"
                                                                 Value="True">
                                                        <Setter Property="Visibility"
                                                                Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <ContentControl Tag="Projects"
                                                    Foreground="{StaticResource Brush.Text.Accent}">
                                        <ContentControl.Style>
                                            <Style TargetType="ContentControl"
                                                   BasedOn="{StaticResource Sidebar.ScopeGlyph}">
                                                <Setter Property="Width" Value="19" />
                                                <Setter Property="Height" Value="19" />
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsProject}"
                                                                 Value="True">
                                                        <Setter Property="Visibility"
                                                                Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ContentControl.Style>
                                    </ContentControl>
                                </Grid>
                                <StackPanel Grid.Column="1"
                                            Margin="8,0,8,0">
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="{StaticResource Font.Size.Body}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Subtitle}"
                                               Margin="0,3,0,0"
                                               Foreground="{StaticResource Brush.Text.Secondary}"
                                               FontSize="{StaticResource Font.Size.Caption}" />
                                </StackPanel>
                                <Viewbox Grid.Column="2"
                                         Width="14"
                                         Height="14"
                                         Margin="0,0,8,0"
                                         VerticalAlignment="Center"
                                         ToolTip="{Binding PinBadge}"
                                         AutomationProperties.Name="{Binding PinBadge}">
                                    <Viewbox.Style>
                                        <Style TargetType="Viewbox">
                                            <Setter Property="Visibility"
                                                    Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPinned}"
                                                             Value="True">
                                                    <Setter Property="Visibility"
                                                            Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Viewbox.Style>
                                    <Path Data="M 7,2 H 17 L 15.5,9 L 19,12 V 14 H 13 V 21 L 12,23 L 11,21 V 14 H 5 V 12 L 8.5,9 Z"
                                          Fill="Transparent"
                                          Stroke="{StaticResource Brush.Text.Accent}"
                                          StrokeThickness="1.5"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round" />
                                </Viewbox>
                                <TextBlock Grid.Column="3"
                                           Text="{Binding ActionHint}"
                                           Foreground="{StaticResource Brush.Text.Secondary}"
                                           FontSize="{StaticResource Font.Size.Caption}"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Card.Plain}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid>
                    <TextBlock Text="{loc:Loc sidebar.recent-events}"
                               FontSize="{StaticResource Font.Size.Body}"
                               FontWeight="SemiBold" />
                    <Ellipse x:Name="EventPulse"
                             Width="6"
                             Height="6"
                             HorizontalAlignment="Right"
                             Fill="{StaticResource SageBrush}" />
                </Grid>
                <ItemsControl x:Name="EventList"
                              Grid.Row="1"
                              ItemsSource="{Binding RecentEvents}"
                              Margin="0,8,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,3"
                                  Background="Transparent"
                                  Style="{StaticResource Tooltip.HitRegion}">
                                <Grid.ToolTip>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Time}"
                                                   FontFamily="{StaticResource Font.Mono}"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Text="{Binding Text}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid.ToolTip>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="64" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Time}"
                                           IsHitTestVisible="False"
                                           Foreground="{StaticResource Brush.Text.Secondary}"
                                           FontFamily="{StaticResource Font.Mono}"
                                           FontSize="{StaticResource Font.Size.Caption}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Text}"
                                           IsHitTestVisible="False"
                                           Foreground="{StaticResource Brush.Text.Secondary}"
                                           FontSize="{StaticResource Font.Size.Caption}"
                                           TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>
    </Grid>
</Grid>
</UserControl>
