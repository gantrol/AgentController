<UserControl x:Class="CodexController.Views.RadialMenuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="300"
             d:DesignWidth="680"
             IsHitTestVisible="False"
             SnapsToDevicePixels="True">
    <UserControl.Resources>
        <Style x:Key="RadialMenu.Progress"
               TargetType="ProgressBar">
            <Setter Property="Height" Value="3" />
            <Setter Property="Foreground"
                    Value="{StaticResource Brush.Accent}" />
            <Setter Property="Background"
                    Value="{StaticResource Brush.Bg.Sunken}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid Height="{TemplateBinding Height}"
                              ClipToBounds="True">
                            <Rectangle x:Name="PART_Track"
                                       Fill="{TemplateBinding Background}" />
                            <Rectangle x:Name="PART_Indicator"
                                       HorizontalAlignment="Left"
                                       Fill="{TemplateBinding Foreground}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RadialMenu.Slot"
               TargetType="ContentControl">
            <Setter Property="Width" Value="162" />
            <Setter Property="Height" Value="58" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContentControl">
                        <Border x:Name="SlotCard"
                                Padding="8,7"
                                Background="{StaticResource Brush.Bg.Surface}"
                                BorderBrush="{StaticResource Brush.Border.Subtle}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource Radius.MD}"
                                Effect="{StaticResource Shadow.Overlay}"
                                AutomationProperties.Name="{Binding AccessibleName}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="34" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="GlyphBadge"
                                        Width="28"
                                        Height="28"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Background="{StaticResource Brush.Bg.Sunken}"
                                        BorderBrush="{StaticResource Brush.Border.Subtle}"
                                        BorderThickness="1"
                                        CornerRadius="14">
                                    <TextBlock Text="{Binding InputGlyph}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource Brush.Text.Primary}"
                                               FontFamily="{StaticResource Font.Mono}"
                                               FontSize="{StaticResource Font.Size.Caption}"
                                               FontWeight="{StaticResource Font.Weight.Bold}" />
                                </Border>
                                <StackPanel Grid.Column="1"
                                            VerticalAlignment="Center">
                                    <TextBlock x:Name="SlotTitle"
                                               Text="{Binding Title}"
                                               Foreground="{StaticResource Brush.Text.Primary}"
                                               FontSize="{StaticResource Font.Size.Body}"
                                               FontWeight="{StaticResource Font.Weight.Semibold}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock x:Name="SlotSubtitle"
                                               Text="{Binding Subtitle}"
                                               Margin="0,2,0,0"
                                               Foreground="{StaticResource Brush.Text.Secondary}"
                                               FontSize="{StaticResource Font.Size.Caption}"
                                               TextTrimming="CharacterEllipsis">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility"
                                                        Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasSubtitle}"
                                                                 Value="False">
                                                        <Setter Property="Visibility"
                                                                Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                                <ProgressBar x:Name="ConfirmationProgress"
                                             Grid.ColumnSpan="2"
                                             Margin="0,0,0,-7"
                                             VerticalAlignment="Bottom"
                                             Minimum="0"
                                             Maximum="1"
                                             Value="{Binding ConfirmationProgress, Mode=OneWay}">
                                    <ProgressBar.Style>
                                        <Style TargetType="ProgressBar"
                                               BasedOn="{StaticResource RadialMenu.Progress}">
                                            <Setter Property="Visibility"
                                                    Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasConfirmationProgress}"
                                                             Value="False">
                                                    <Setter Property="Visibility"
                                                            Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ProgressBar.Style>
                                </ProgressBar>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsActionEnabled}"
                                         Value="False">
                                <Setter TargetName="SlotCard"
                                        Property="Opacity"
                                        Value="0.46" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsHighlighted}"
                                         Value="True">
                                <Setter TargetName="SlotCard"
                                        Property="Background"
                                        Value="{StaticResource Brush.Accent.Soft}" />
                                <Setter TargetName="SlotCard"
                                        Property="BorderBrush"
                                        Value="{StaticResource Brush.Accent}" />
                                <Setter TargetName="SlotCard"
                                        Property="BorderThickness"
                                        Value="2" />
                                <Setter TargetName="GlyphBadge"
                                        Property="Background"
                                        Value="{StaticResource Brush.Bg.Surface}" />
                                <Setter TargetName="GlyphBadge"
                                        Property="BorderBrush"
                                        Value="{StaticResource Brush.Accent}" />
                                <Setter TargetName="SlotTitle"
                                        Property="Foreground"
                                        Value="{StaticResource Brush.Text.Accent}" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPresent}"
                             Value="False">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Width="680"
          Height="300"
          Background="Transparent">
        <Grid.Style>
            <Style TargetType="Grid">
                <Setter Property="Visibility" Value="Visible" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsVisible}"
                                 Value="False">
                        <Setter Property="Visibility"
                                Value="Collapsed" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>

        <Canvas>
            <Ellipse Canvas.Left="220"
                     Canvas.Top="38"
                     Width="240"
                     Height="190"
                     Fill="#26FFFFFF"
                     Stroke="{StaticResource Brush.Border.Subtle}"
                     StrokeThickness="1" />
            <Line X1="340"
                  Y1="132"
                  X2="340"
                  Y2="38"
                  Stroke="{StaticResource Brush.Border.Subtle}"
                  StrokeThickness="1" />
            <Line X1="340"
                  Y1="132"
                  X2="154"
                  Y2="121"
                  Stroke="{StaticResource Brush.Border.Subtle}"
                  StrokeThickness="1" />
            <Line X1="340"
                  Y1="132"
                  X2="526"
                  Y2="121"
                  Stroke="{StaticResource Brush.Border.Subtle}"
                  StrokeThickness="1" />
            <Line X1="340"
                  Y1="132"
                  X2="340"
                  Y2="263"
                  Stroke="{StaticResource Brush.Border.Subtle}"
                  StrokeThickness="1" />

            <Border Canvas.Left="225"
                    Canvas.Top="91"
                    Width="230"
                    Height="78"
                    Padding="12,10"
                    Background="{StaticResource Brush.Bg.Panel}"
                    BorderBrush="{StaticResource Brush.Border.Strong}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Radius.LG}"
                    Effect="{StaticResource Shadow.Overlay}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="42" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Width="34"
                            Height="34"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Background="{StaticResource Brush.Bg.Inverse}"
                            CornerRadius="17">
                        <TextBlock Text="{Binding ModifierGlyph}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource Brush.Text.Inverse}"
                                   FontFamily="{StaticResource Font.Mono}"
                                   FontSize="{StaticResource Font.Size.Label}"
                                   FontWeight="{StaticResource Font.Weight.Bold}" />
                    </Border>
                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Binding Title}"
                                   Foreground="{StaticResource Brush.Text.Primary}"
                                   FontSize="{StaticResource Font.Size.Title}"
                                   FontWeight="{StaticResource Font.Weight.Semibold}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding Subtitle}"
                                   Margin="0,3,0,0"
                                   Foreground="{StaticResource Brush.Text.Secondary}"
                                   FontSize="{StaticResource Font.Size.Caption}"
                                   TextTrimming="CharacterEllipsis">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility"
                                            Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasSubtitle}"
                                                     Value="False">
                                            <Setter Property="Visibility"
                                                    Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>

            <ContentControl Canvas.Left="259"
                            Canvas.Top="4"
                            DataContext="{Binding Top}"
                            Style="{StaticResource RadialMenu.Slot}" />
            <ContentControl Canvas.Left="506"
                            Canvas.Top="92"
                            DataContext="{Binding Right}"
                            Style="{StaticResource RadialMenu.Slot}" />
            <ContentControl Canvas.Left="259"
                            Canvas.Top="238"
                            DataContext="{Binding Bottom}"
                            Style="{StaticResource RadialMenu.Slot}" />
            <ContentControl Canvas.Left="12"
                            Canvas.Top="92"
                            DataContext="{Binding Left}"
                            Style="{StaticResource RadialMenu.Slot}" />
            <ContentControl Canvas.Left="151"
                            Canvas.Top="176"
                            DataContext="{Binding CenterLeft}"
                            Style="{StaticResource RadialMenu.Slot}" />
            <ContentControl Canvas.Left="367"
                            Canvas.Top="176"
                            DataContext="{Binding CenterRight}"
                            Style="{StaticResource RadialMenu.Slot}" />
        </Canvas>
    </Grid>
</UserControl>
