<UserControl x:Class="CodexController.Views.RadialMenuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="clr-namespace:CodexController.Views"
             mc:Ignorable="d"
             d:DesignHeight="560"
             d:DesignWidth="980"
             IsHitTestVisible="False"
             SnapsToDevicePixels="True"
             Loaded="RadialMenuView_Loaded"
             Unloaded="RadialMenuView_Unloaded"
             SizeChanged="RadialMenuView_SizeChanged">
    <UserControl.Resources>
        <LinearGradientBrush x:Key="RadialDial.SectorBrush"
                             StartPoint="0,0"
                             EndPoint="0,1">
            <GradientStop Offset="0"
                          Color="{StaticResource Color.Sand.50}" />
            <GradientStop Offset="1"
                          Color="{StaticResource Color.Sand.200}" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="RadialDial.SelectedBrush"
                             StartPoint="0,0"
                             EndPoint="0,1">
            <GradientStop Offset="0"
                          Color="{StaticResource Color.Sage.300}" />
            <GradientStop Offset="1"
                          Color="{StaticResource Color.Sage.600}" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="RadialDial.LineBrush"
                         Color="{StaticResource Color.Sage.600}" />
        <DropShadowEffect x:Key="RadialDial.SectorShadow"
                          BlurRadius="18"
                          ShadowDepth="4"
                          Opacity="0.13"
                          Color="{StaticResource Color.Ink.500}" />
        <DropShadowEffect x:Key="RadialDial.SelectedGlow"
                          BlurRadius="24"
                          ShadowDepth="0"
                          Opacity="0.42"
                          Color="{StaticResource Color.Sage.300}" />

        <Style x:Key="RadialDial.Progress"
               TargetType="ProgressBar">
            <Setter Property="Height" Value="3" />
            <Setter Property="Foreground"
                    Value="{StaticResource Brush.Overlay.OnAccent}" />
            <Setter Property="Background"
                    Value="{StaticResource Brush.Overlay.Progress.Track}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid Height="{TemplateBinding Height}"
                              ClipToBounds="True">
                            <Rectangle Fill="{TemplateBinding Background}" />
                            <Rectangle x:Name="PART_Indicator"
                                       HorizontalAlignment="Left"
                                       Fill="{TemplateBinding Foreground}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RadialDial.Sector"
               TargetType="Path">
            <Setter Property="Fill"
                    Value="{StaticResource RadialDial.SectorBrush}" />
            <Setter Property="Stroke"
                    Value="{StaticResource Brush.Overlay.Border.OnAccent}" />
            <Setter Property="StrokeThickness" Value="2" />
            <Setter Property="Effect"
                    Value="{StaticResource RadialDial.SectorShadow}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPresent}" Value="False">
                    <Setter Property="Opacity" Value="0.26" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsActionEnabled}" Value="False">
                    <Setter Property="Opacity" Value="0.48" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                    <Setter Property="Fill"
                            Value="{StaticResource RadialDial.SelectedBrush}" />
                    <Setter Property="Stroke"
                            Value="{StaticResource Brush.Overlay.Border.OnAccent}" />
                    <Setter Property="StrokeThickness" Value="3" />
                    <Setter Property="Effect"
                            Value="{StaticResource RadialDial.SelectedGlow}" />
                    <Setter Property="Opacity" Value="1" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RadialDial.Slot"
               TargetType="ContentControl">
            <Setter Property="Width" Value="172" />
            <Setter Property="Height" Value="82" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContentControl">
                        <Grid x:Name="SlotRoot"
                              AutomationProperties.Name="{Binding AccessibleName}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="42" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="GlyphBadge"
                                    Width="34"
                                    Height="34"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Background="{StaticResource Brush.Overlay.Glyph.Fill}"
                                    BorderBrush="{StaticResource Brush.Border.Subtle}"
                                    BorderThickness="1"
                                    CornerRadius="17">
                                <TextBlock x:Name="GlyphText"
                                           Text="{Binding InputGlyph}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource Brush.Text.Secondary}"
                                           FontFamily="{StaticResource Font.Mono}"
                                           FontSize="15"
                                           FontWeight="{StaticResource Font.Weight.Bold}" />
                            </Border>
                            <StackPanel Grid.Column="1"
                                        Margin="4,1,0,0">
                                <TextBlock x:Name="SlotTitle"
                                           Text="{Binding Title}"
                                           Foreground="{StaticResource Brush.Text.Primary}"
                                           FontSize="14"
                                           FontWeight="{StaticResource Font.Weight.Semibold}"
                                           LineHeight="17"
                                           MaxHeight="36"
                                           TextWrapping="Wrap" />
                                <TextBlock x:Name="SlotSubtitle"
                                           Text="{Binding Subtitle}"
                                           Margin="0,4,0,0"
                                           Foreground="{StaticResource Brush.Text.Secondary}"
                                           FontSize="11"
                                           TextTrimming="CharacterEllipsis">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasSubtitle}"
                                                             Value="False">
                                                    <Setter Property="Visibility"
                                                            Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            <ProgressBar Grid.ColumnSpan="2"
                                         Margin="0,0,8,1"
                                         VerticalAlignment="Bottom"
                                         Minimum="0"
                                         Maximum="1"
                                         Value="{Binding ConfirmationProgress, Mode=OneWay}">
                                <ProgressBar.Style>
                                    <Style TargetType="ProgressBar"
                                           BasedOn="{StaticResource RadialDial.Progress}">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasConfirmationProgress}"
                                                         Value="False">
                                                <Setter Property="Visibility"
                                                        Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ProgressBar.Style>
                            </ProgressBar>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsActionEnabled}"
                                         Value="False">
                                <Setter TargetName="SlotRoot"
                                        Property="Opacity"
                                        Value="0.52" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsHighlighted}"
                                         Value="True">
                                <Setter TargetName="GlyphBadge"
                                        Property="Background"
                                        Value="{StaticResource Brush.Overlay.Glyph.Fill}" />
                                <Setter TargetName="GlyphBadge"
                                        Property="BorderBrush"
                                        Value="{StaticResource Brush.Overlay.Border.OnAccent.Strong}" />
                                <Setter TargetName="GlyphText"
                                        Property="Foreground"
                                        Value="{StaticResource Brush.Accent}" />
                                <Setter TargetName="SlotTitle"
                                        Property="Foreground"
                                        Value="{StaticResource Brush.Overlay.OnAccent}" />
                                <Setter TargetName="SlotSubtitle"
                                        Property="Foreground"
                                        Value="{StaticResource Brush.Overlay.OnAccent.Muted}" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPresent}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RadialDial.SourceAnchor"
               TargetType="Border">
            <Setter Property="Width" Value="10" />
            <Setter Property="Height" Value="10" />
            <Setter Property="Background"
                    Value="{StaticResource Brush.Overlay.Anchor.Fill}" />
            <Setter Property="BorderBrush"
                    Value="{StaticResource RadialDial.LineBrush}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="CornerRadius" Value="5" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPresent}" Value="False">
                    <Setter Property="Opacity" Value="0" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsActionEnabled}" Value="False">
                    <Setter Property="Opacity" Value="0.42" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RadialDial.TargetAnchor"
               TargetType="Ellipse">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Fill"
                    Value="{StaticResource Brush.Overlay.Target.Fill}" />
            <Setter Property="Stroke"
                    Value="{StaticResource RadialDial.LineBrush}" />
            <Setter Property="StrokeThickness" Value="3" />
            <Setter Property="Opacity" Value="0" />
        </Style>
    </UserControl.Resources>

    <Grid x:Name="RootGrid"
          Width="980"
          Height="560"
          Background="Transparent">
        <Grid.Style>
            <Style TargetType="Grid">
                <Setter Property="Visibility" Value="Visible" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsVisible}" Value="False">
                        <Setter Property="Visibility" Value="Collapsed" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>

        <Canvas x:Name="DialCanvas"
                Width="980"
                Height="560">
            <Canvas.Style>
                <Style TargetType="Canvas">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsAgentLayer}"
                                     Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Canvas.Style>
            <Ellipse Canvas.Left="214"
                     Canvas.Top="34"
                     Width="552"
                     Height="552"
                     Fill="{StaticResource Brush.Overlay.Halo}"
                     IsHitTestVisible="False">
                <Ellipse.Effect>
                    <BlurEffect Radius="32" />
                </Ellipse.Effect>
            </Ellipse>

            <Path x:Name="TopSector"
                  DataContext="{Binding Top}"
                  Style="{StaticResource RadialDial.Sector}" />
            <Path x:Name="RightSector"
                  DataContext="{Binding Right}"
                  Style="{StaticResource RadialDial.Sector}" />
            <Path x:Name="CenterRightSector"
                  DataContext="{Binding CenterRight}"
                  Style="{StaticResource RadialDial.Sector}" />
            <Path x:Name="BottomSector"
                  DataContext="{Binding Bottom}"
                  Style="{StaticResource RadialDial.Sector}" />
            <Path x:Name="CenterLeftSector"
                  DataContext="{Binding CenterLeft}"
                  Style="{StaticResource RadialDial.Sector}" />
            <Path x:Name="LeftSector"
                  DataContext="{Binding Left}"
                  Style="{StaticResource RadialDial.Sector}" />

            <Ellipse Canvas.Left="344"
                     Canvas.Top="164"
                     Width="292"
                     Height="292"
                     Fill="{StaticResource Brush.Bg.Sunken}"
                     Stroke="{StaticResource Brush.Overlay.Border.OnAccent}"
                     StrokeThickness="3">
                <Ellipse.Effect>
                    <DropShadowEffect BlurRadius="18"
                                      ShadowDepth="3"
                                      Opacity="0.16"
                                      Color="{StaticResource Color.Ink.500}" />
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Canvas.Left="356"
                     Canvas.Top="176"
                     Width="268"
                     Height="268"
                     Fill="{StaticResource Brush.Overlay.Surface.Glass}"
                     Stroke="{StaticResource Brush.Overlay.Border.Frosted}"
                     StrokeThickness="1" />

            <Viewbox Canvas.Left="310"
                     Canvas.Top="195"
                     Width="360"
                     Height="228"
                     Stretch="Uniform">
                <Grid Width="600" Height="380">
                    <Image Source="/AgentController;component/Assets/controller.png"
                           Width="600"
                           Height="380"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Opacity="0.97" />
                </Grid>
            </Viewbox>

            <Canvas x:Name="LeaderCanvas"
                    Width="980"
                    Height="560"
                    IsHitTestVisible="False" />

            <Viewbox Canvas.Left="310"
                     Canvas.Top="195"
                     Width="360"
                     Height="228"
                     Stretch="Uniform"
                     IsHitTestVisible="False">
                <Canvas Width="600" Height="380">
                    <!-- Controller asset calibration: the D-pad silhouette is
                         centered at approximately (249, 221) on this canvas. -->
                    <Ellipse x:Name="DPadUpAnchor"
                             Canvas.Left="240"
                             Canvas.Top="196"
                             Style="{StaticResource RadialDial.TargetAnchor}" />
                    <Ellipse x:Name="DPadRightAnchor"
                             Canvas.Left="256"
                             Canvas.Top="212"
                             Style="{StaticResource RadialDial.TargetAnchor}" />
                    <Ellipse x:Name="DPadDownAnchor"
                             Canvas.Left="240"
                             Canvas.Top="228"
                             Style="{StaticResource RadialDial.TargetAnchor}" />
                    <Ellipse x:Name="DPadLeftAnchor"
                             Canvas.Left="224"
                             Canvas.Top="212"
                             Style="{StaticResource RadialDial.TargetAnchor}" />
                    <Ellipse x:Name="ViewAnchor"
                             Canvas.Left="265"
                             Canvas.Top="147"
                             Style="{StaticResource RadialDial.TargetAnchor}" />
                    <Ellipse x:Name="MenuAnchor"
                             Canvas.Left="320"
                             Canvas.Top="147"
                             Style="{StaticResource RadialDial.TargetAnchor}" />
                    <Ellipse x:Name="FaceNorthAnchor"
                             Canvas.Left="390"
                             Canvas.Top="125"
                             Style="{StaticResource RadialDial.TargetAnchor}" />
                    <Ellipse x:Name="FaceEastAnchor"
                             Canvas.Left="416"
                             Canvas.Top="151"
                             Style="{StaticResource RadialDial.TargetAnchor}" />
                    <Ellipse x:Name="FaceSouthAnchor"
                             Canvas.Left="389"
                             Canvas.Top="177"
                             Style="{StaticResource RadialDial.TargetAnchor}" />
                    <Ellipse x:Name="FaceWestAnchor"
                             Canvas.Left="364"
                             Canvas.Top="151"
                             Style="{StaticResource RadialDial.TargetAnchor}" />
                    <Ellipse x:Name="LeftStickAnchor"
                             Canvas.Left="192"
                             Canvas.Top="152"
                             Style="{StaticResource RadialDial.TargetAnchor}" />
                    <Ellipse x:Name="RightStickAnchor"
                             Canvas.Left="340"
                             Canvas.Top="210"
                             Style="{StaticResource RadialDial.TargetAnchor}" />
                    <Ellipse x:Name="GuideAnchor"
                             Canvas.Left="291"
                             Canvas.Top="104"
                             Style="{StaticResource RadialDial.TargetAnchor}" />
                </Canvas>
            </Viewbox>

            <Border x:Name="TopSourceAnchor"
                    DataContext="{Binding Top}"
                    Style="{StaticResource RadialDial.SourceAnchor}" />
            <Border x:Name="RightSourceAnchor"
                    DataContext="{Binding Right}"
                    Style="{StaticResource RadialDial.SourceAnchor}" />
            <Border x:Name="CenterRightSourceAnchor"
                    DataContext="{Binding CenterRight}"
                    Style="{StaticResource RadialDial.SourceAnchor}" />
            <Border x:Name="BottomSourceAnchor"
                    DataContext="{Binding Bottom}"
                    Style="{StaticResource RadialDial.SourceAnchor}" />
            <Border x:Name="CenterLeftSourceAnchor"
                    DataContext="{Binding CenterLeft}"
                    Style="{StaticResource RadialDial.SourceAnchor}" />
            <Border x:Name="LeftSourceAnchor"
                    DataContext="{Binding Left}"
                    Style="{StaticResource RadialDial.SourceAnchor}" />

            <ContentControl x:Name="TopSlot"
                            Canvas.Left="380"
                            Canvas.Top="96"
                            Width="220"
                            DataContext="{Binding Top}"
                            Style="{StaticResource RadialDial.Slot}" />
            <ContentControl x:Name="RightSlot"
                            Canvas.Left="594"
                            Canvas.Top="174"
                            DataContext="{Binding Right}"
                            Style="{StaticResource RadialDial.Slot}" />
            <ContentControl x:Name="CenterRightSlot"
                            Canvas.Left="594"
                            Canvas.Top="363"
                            DataContext="{Binding CenterRight}"
                            Style="{StaticResource RadialDial.Slot}" />
            <ContentControl x:Name="BottomSlot"
                            Canvas.Left="375"
                            Canvas.Top="452"
                            Width="230"
                            DataContext="{Binding Bottom}"
                            Style="{StaticResource RadialDial.Slot}" />
            <ContentControl x:Name="CenterLeftSlot"
                            Canvas.Left="214"
                            Canvas.Top="363"
                            DataContext="{Binding CenterLeft}"
                            Style="{StaticResource RadialDial.Slot}" />
            <ContentControl x:Name="LeftSlot"
                            Canvas.Left="214"
                            Canvas.Top="174"
                            DataContext="{Binding Left}"
                            Style="{StaticResource RadialDial.Slot}" />

            <Border Canvas.Left="274"
                    Canvas.Top="8"
                    Width="432"
                    Height="88"
                    Background="{StaticResource Brush.Overlay.Surface.Frosted}"
                    BorderBrush="{StaticResource Brush.Border.Subtle}"
                    BorderThickness="1"
                    CornerRadius="18"
                    Effect="{StaticResource Shadow.Overlay}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="78" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Background="{StaticResource RadialDial.SelectedBrush}"
                            CornerRadius="18,0,0,18">
                        <Border Width="42"
                                Height="42"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="{StaticResource Brush.Overlay.Glyph.Fill}"
                                CornerRadius="21">
                            <TextBlock Text="{Binding ModifierGlyph}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource Brush.Accent}"
                                       FontFamily="{StaticResource Font.Mono}"
                                       FontSize="14"
                                       FontWeight="{StaticResource Font.Weight.Bold}" />
                        </Border>
                    </Border>
                    <StackPanel Grid.Column="1"
                                Margin="20,0,18,0"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Binding Title}"
                                   Foreground="{StaticResource Brush.Text.Primary}"
                                   FontSize="21"
                                   FontWeight="{StaticResource Font.Weight.Semibold}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding Subtitle}"
                                   Margin="0,4,0,0"
                                   Foreground="{StaticResource Brush.Text.Secondary}"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasSubtitle}"
                                                     Value="False">
                                            <Setter Property="Visibility"
                                                    Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>
        </Canvas>

        <views:AgentKeypadView Margin="0,0,0,12"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Bottom">
            <views:AgentKeypadView.Style>
                <Style TargetType="views:AgentKeypadView">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsAgentLayer}"
                                     Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </views:AgentKeypadView.Style>
        </views:AgentKeypadView>
    </Grid>
</UserControl>
