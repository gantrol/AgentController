<UserControl x:Class="CodexController.Views.RadialMenuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="430"
             d:DesignWidth="860"
             IsHitTestVisible="False"
             SnapsToDevicePixels="True">
    <UserControl.Resources>
        <Style x:Key="ControllerHint.Progress"
               TargetType="ProgressBar">
            <Setter Property="Height" Value="3" />
            <Setter Property="Foreground"
                    Value="{StaticResource Brush.Accent}" />
            <Setter Property="Background"
                    Value="{StaticResource Brush.Bg.Sunken}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid Height="{TemplateBinding Height}"
                              ClipToBounds="True">
                            <Rectangle Fill="{TemplateBinding Background}" />
                            <Rectangle x:Name="PART_Indicator"
                                       HorizontalAlignment="Left"
                                       Fill="{TemplateBinding Foreground}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ControllerHint.Slot"
               TargetType="ContentControl">
            <Setter Property="Width" Value="182" />
            <Setter Property="Height" Value="62" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContentControl">
                        <Border x:Name="SlotCard"
                                Padding="9,7"
                                Background="{StaticResource Brush.Bg.Surface}"
                                BorderBrush="{StaticResource Brush.Border.Subtle}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource Radius.MD}"
                                Effect="{StaticResource Shadow.Overlay}"
                                AutomationProperties.Name="{Binding AccessibleName}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="38" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="GlyphBadge"
                                        Width="30"
                                        Height="30"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Background="{StaticResource Brush.Bg.Inverse}"
                                        CornerRadius="15">
                                    <TextBlock Text="{Binding InputGlyph}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource Brush.Text.Inverse}"
                                               FontFamily="{StaticResource Font.Mono}"
                                               FontSize="{StaticResource Font.Size.Caption}"
                                               FontWeight="{StaticResource Font.Weight.Bold}" />
                                </Border>
                                <StackPanel Grid.Column="1"
                                            VerticalAlignment="Center">
                                    <TextBlock x:Name="SlotTitle"
                                               Text="{Binding Title}"
                                               Foreground="{StaticResource Brush.Text.Primary}"
                                               FontSize="{StaticResource Font.Size.Body}"
                                               FontWeight="{StaticResource Font.Weight.Semibold}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Subtitle}"
                                               Margin="0,2,0,0"
                                               Foreground="{StaticResource Brush.Text.Secondary}"
                                               FontSize="{StaticResource Font.Size.Caption}"
                                               TextTrimming="CharacterEllipsis">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility"
                                                        Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasSubtitle}"
                                                                 Value="False">
                                                        <Setter Property="Visibility"
                                                                Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                                <ProgressBar Grid.ColumnSpan="2"
                                             Margin="0,0,0,-7"
                                             VerticalAlignment="Bottom"
                                             Minimum="0"
                                             Maximum="1"
                                             Value="{Binding ConfirmationProgress, Mode=OneWay}">
                                    <ProgressBar.Style>
                                        <Style TargetType="ProgressBar"
                                               BasedOn="{StaticResource ControllerHint.Progress}">
                                            <Setter Property="Visibility"
                                                    Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasConfirmationProgress}"
                                                             Value="False">
                                                    <Setter Property="Visibility"
                                                            Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ProgressBar.Style>
                                </ProgressBar>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsActionEnabled}"
                                         Value="False">
                                <Setter TargetName="SlotCard"
                                        Property="Opacity"
                                        Value="0.45" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsHighlighted}"
                                         Value="True">
                                <Setter TargetName="SlotCard"
                                        Property="Background"
                                        Value="{StaticResource Brush.Accent.Soft}" />
                                <Setter TargetName="SlotCard"
                                        Property="BorderBrush"
                                        Value="{StaticResource Brush.Accent}" />
                                <Setter TargetName="SlotCard"
                                        Property="BorderThickness"
                                        Value="2" />
                                <Setter TargetName="GlyphBadge"
                                        Property="Background"
                                        Value="{StaticResource Brush.Accent}" />
                                <Setter TargetName="SlotTitle"
                                        Property="Foreground"
                                        Value="{StaticResource Brush.Text.Accent}" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPresent}"
                             Value="False">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Width="860"
          Height="430"
          Background="Transparent">
        <Grid.Style>
            <Style TargetType="Grid">
                <Setter Property="Visibility" Value="Visible" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsVisible}"
                                 Value="False">
                        <Setter Property="Visibility"
                                Value="Collapsed" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>

        <Border Margin="194,48,194,45"
                Background="#F7F7F3"
                BorderBrush="{StaticResource Brush.Border.Subtle}"
                BorderThickness="1"
                CornerRadius="28"
                Effect="{StaticResource Shadow.Overlay}" />

        <Image Margin="190,58,190,48"
               Source="/Assets/controller.png"
               Stretch="Uniform"
               RenderOptions.BitmapScalingMode="HighQuality"
               Opacity="0.96" />

        <Border Width="310"
                Height="70"
                Margin="0,86,0,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Padding="12,9"
                Background="{StaticResource Brush.Bg.Panel}"
                BorderBrush="{StaticResource Brush.Border.Strong}"
                BorderThickness="1"
                CornerRadius="{StaticResource Radius.LG}"
                Effect="{StaticResource Shadow.Overlay}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="42" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Width="34"
                        Height="34"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Background="{StaticResource Brush.Bg.Inverse}"
                        CornerRadius="17">
                    <TextBlock Text="{Binding ModifierGlyph}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource Brush.Text.Inverse}"
                               FontFamily="{StaticResource Font.Mono}"
                               FontSize="{StaticResource Font.Size.Label}"
                               FontWeight="{StaticResource Font.Weight.Bold}" />
                </Border>
                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding Title}"
                               Foreground="{StaticResource Brush.Text.Primary}"
                               FontSize="{StaticResource Font.Size.Title}"
                               FontWeight="{StaticResource Font.Weight.Semibold}"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding Subtitle}"
                               Margin="0,3,0,0"
                               Foreground="{StaticResource Brush.Text.Secondary}"
                               FontSize="{StaticResource Font.Size.Caption}"
                               TextTrimming="CharacterEllipsis">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility"
                                        Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSubtitle}"
                                                 Value="False">
                                        <Setter Property="Visibility"
                                                Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <Canvas>
            <ContentControl Canvas.Left="339"
                            Canvas.Top="8"
                            DataContext="{Binding Top}"
                            Style="{StaticResource ControllerHint.Slot}" />
            <ContentControl Canvas.Left="670"
                            Canvas.Top="126"
                            DataContext="{Binding Right}"
                            Style="{StaticResource ControllerHint.Slot}" />
            <ContentControl Canvas.Left="339"
                            Canvas.Top="360"
                            DataContext="{Binding Bottom}"
                            Style="{StaticResource ControllerHint.Slot}" />
            <ContentControl Canvas.Left="8"
                            Canvas.Top="126"
                            DataContext="{Binding Left}"
                            Style="{StaticResource ControllerHint.Slot}" />
            <ContentControl Canvas.Left="80"
                            Canvas.Top="290"
                            DataContext="{Binding CenterLeft}"
                            Style="{StaticResource ControllerHint.Slot}" />
            <ContentControl Canvas.Left="598"
                            Canvas.Top="290"
                            DataContext="{Binding CenterRight}"
                            Style="{StaticResource ControllerHint.Slot}" />
        </Canvas>
    </Grid>
</UserControl>
