<UserControl x:Class="CodexController.Views.SettingsPageView"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="680"
             d:DesignWidth="900">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="900">
            <Grid Margin="4,0,4,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding Strings.SettingsTitle, ElementName=Root}"
                               VerticalAlignment="Center"
                               FontSize="{StaticResource Font.Size.Display}"
                               FontWeight="SemiBold" />
                    <Button Margin="7,0,0,0"
                            Style="{StaticResource Shell.HelpButton}"
                            ToolTip="{Binding Strings.SettingsDescription, ElementName=Root}"
                            AutomationProperties.Name="{Binding Strings.SettingsDescription, ElementName=Root}" />
                </StackPanel>
                <Button x:Name="RestoreDefaultsButton"
                        Grid.Column="1"
                        Style="{StaticResource Button.CrystalKey.Icon}"
                        Content="↺"
                        ToolTip="{Binding Strings.SettingsRestoreDefaults, ElementName=Root}"
                        AutomationProperties.Name="{Binding Strings.SettingsRestoreDefaults, ElementName=Root}"
                        Command="{Binding ResetCommand}" />
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.82*" />
                    <ColumnDefinition Width="1.18*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource Card.Divider.Right}">
                    <StackPanel>
                        <TextBlock Text="{Binding Strings.SettingsBehavior, ElementName=Root}"
                                   FontSize="{StaticResource Font.Size.Title}"
                                   FontWeight="SemiBold" />

                        <Grid Margin="0,20,0,0"
                              Background="Transparent"
                              Style="{StaticResource Tooltip.HitRegion}"
                              ToolTip="{Binding OnlyForegroundDescription}">
                            <TextBlock Text="{Binding OnlyForegroundText}"
                                       VerticalAlignment="Center"
                                       FontSize="{StaticResource Font.Size.Body}" />
                            <CheckBox HorizontalAlignment="Right"
                                      Style="{StaticResource Shell.Toggle}"
                                      IsChecked="{Binding OnlyWhenAgentForeground}" />
                        </Grid>
                        <Grid Margin="0,17,0,0">
                            <TextBlock Text="{Binding Strings.SettingsHaptic, ElementName=Root}"
                                       VerticalAlignment="Center"
                                       FontSize="{StaticResource Font.Size.Body}" />
                            <CheckBox HorizontalAlignment="Right"
                                      Style="{StaticResource Shell.Toggle}"
                                      IsChecked="{Binding HapticFeedback}" />
                        </Grid>
                        <Grid Margin="0,17,0,0">
                            <TextBlock Text="{Binding Strings.SettingsOverlay, ElementName=Root}"
                                       VerticalAlignment="Center"
                                       FontSize="{StaticResource Font.Size.Body}" />
                            <CheckBox HorizontalAlignment="Right"
                                      Style="{StaticResource Shell.Toggle}"
                                      IsChecked="{Binding ShowOverlay}" />
                        </Grid>
                        <Grid Margin="0,17,0,0"
                              Background="Transparent"
                              Style="{StaticResource Tooltip.HitRegion}"
                              ToolTip="{Binding Strings.SettingsRadialMenuDescription, ElementName=Root}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="142" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Strings.SettingsRadialMenu, ElementName=Root}"
                                       VerticalAlignment="Center"
                                       FontSize="{StaticResource Font.Size.Body}" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding RadialMenuOptions}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Value"
                                      SelectedValue="{Binding RadialMenuMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Style="{StaticResource Card.Plain}"
                        ToolTip="{Binding Strings.SettingsStickDescription, ElementName=Root}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Strings.SettingsStick, ElementName=Root}"
                                       VerticalAlignment="Center"
                                       FontSize="{StaticResource Font.Size.Title}"
                                       FontWeight="SemiBold" />
                            <Button Margin="7,0,0,0"
                                    Style="{StaticResource Shell.HelpButton}"
                                    ToolTip="{Binding Strings.SettingsStickDescription, ElementName=Root}"
                                    AutomationProperties.Name="{Binding Strings.SettingsStickDescription, ElementName=Root}" />
                        </StackPanel>

                        <Grid Margin="0,20,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="102" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="48" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Strings.SettingsDeadZone, ElementName=Root}"
                                       VerticalAlignment="Center"
                                       FontSize="{StaticResource Font.Size.Caption}" />
                            <Slider Grid.Column="1"
                                    Minimum="0.35"
                                    Maximum="0.80"
                                    TickFrequency="0.01"
                                    Value="{Binding DeadZone}" />
                            <TextBlock Grid.Column="2"
                                       Text="{Binding DeadZoneDisplay}"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontFamily="{StaticResource Font.Mono}"
                                       FontSize="{StaticResource Font.Size.Caption}" />
                        </Grid>
                        <Grid Margin="0,17,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="102" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="56" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Strings.SettingsInitialRepeat, ElementName=Root}"
                                       VerticalAlignment="Center"
                                       FontSize="{StaticResource Font.Size.Caption}" />
                            <Slider Grid.Column="1"
                                    Minimum="220"
                                    Maximum="600"
                                    TickFrequency="10"
                                    Value="{Binding RepeatDelayMs}" />
                            <TextBlock Grid.Column="2"
                                       Text="{Binding RepeatDelayDisplay}"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontFamily="{StaticResource Font.Mono}"
                                       FontSize="{StaticResource Font.Size.Caption}" />
                        </Grid>
                        <Grid Margin="0,17,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="102" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="56" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Strings.SettingsRepeatInterval, ElementName=Root}"
                                       VerticalAlignment="Center"
                                       FontSize="{StaticResource Font.Size.Caption}" />
                            <Slider Grid.Column="1"
                                    Minimum="140"
                                    Maximum="300"
                                    TickFrequency="5"
                                    Value="{Binding RepeatIntervalMs}" />
                            <TextBlock Grid.Column="2"
                                       Text="{Binding RepeatIntervalDisplay}"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontFamily="{StaticResource Font.Mono}"
                                       FontSize="{StaticResource Font.Size.Caption}" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource Card.Divider.Top}"
                    Margin="0,14,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.1*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding Strings.SettingsSystem, ElementName=Root}"
                                   FontSize="{StaticResource Font.Size.Title}"
                                   FontWeight="SemiBold" />
                        <Grid Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="190" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Strings.SettingsLanguage, ElementName=Root}"
                                       VerticalAlignment="Center"
                                       FontSize="{StaticResource Font.Size.Body}" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding Localization.LanguageOptions, ElementName=Root}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="SettingValue"
                                      SelectedValue="{Binding LanguageSetting, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="190" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Strings.SettingsTextSize, ElementName=Root}"
                                       VerticalAlignment="Center"
                                       FontSize="{StaticResource Font.Size.Body}" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding TextSizeOptions}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Value"
                                      SelectedValue="{Binding TextSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Margin="24,0,0,0"
                                VerticalAlignment="Bottom">
                        <Grid>
                            <TextBlock Text="{Binding Strings.SettingsStartWithWindows, ElementName=Root}"
                                       VerticalAlignment="Center"
                                       FontSize="{StaticResource Font.Size.Body}" />
                            <CheckBox HorizontalAlignment="Right"
                                      Style="{StaticResource Shell.Toggle}"
                                      IsChecked="{Binding StartWithWindows}" />
                        </Grid>
                        <Grid Margin="0,17,0,0">
                            <TextBlock Text="{Binding Strings.SettingsMinimizeToTray, ElementName=Root}"
                                       VerticalAlignment="Center"
                                       FontSize="{StaticResource Font.Size.Body}" />
                            <CheckBox HorizontalAlignment="Right"
                                      Style="{StaticResource Shell.Toggle}"
                                      IsChecked="{Binding MinimizeToTray}" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Margin="24,0,0,0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Orientation="Horizontal">
                        <Button Style="{StaticResource Button.CrystalKey.Icon}"
                                Content="◇"
                                ToolTip="{Binding OpenVendorToolText}"
                                AutomationProperties.Name="{Binding OpenVendorToolText}"
                                IsEnabled="{Binding CanOpenVendorTool}"
                                Command="{Binding OpenVendorToolCommand}" />
                        <Button Style="{StaticResource Button.CrystalKey.Icon}"
                                Margin="8,0,0,0"
                                Content="⚙"
                                ToolTip="{Binding OpenAgentSettingsText}"
                                AutomationProperties.Name="{Binding OpenAgentSettingsText}"
                                IsEnabled="{Binding CanOpenAgentSettings}"
                                Command="{Binding OpenAgentSettingsCommand}" />
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
