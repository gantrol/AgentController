<Window x:Class="CodexController.Views.SidebarNavigationWheelOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="520"
        Height="178"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        ResizeMode="NoResize"
        Focusable="False"
        IsHitTestVisible="False"
        WindowStartupLocation="Manual"
        AutomationProperties.LiveSetting="Polite"
        AutomationProperties.Name="Sidebar navigation wheel">
    <Border Margin="10"
            Padding="12"
            Background="{StaticResource Brush.Bg.Panel}"
            BorderBrush="{StaticResource Brush.Border.Subtle}"
            BorderThickness="1"
            CornerRadius="{StaticResource Radius.XL}"
            Effect="{StaticResource Shadow.Overlay}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38" />
                <RowDefinition Height="58" />
                <RowDefinition Height="38" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Margin="10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding PreviousTitle}"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource Brush.Text.Tertiary}"
                           FontSize="{StaticResource Font.Size.Body}"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="1"
                           Margin="12,0,0,0"
                           Text="{Binding PreviousBoundary}"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource Brush.Text.Accent}"
                           FontSize="{StaticResource Font.Size.Caption}" />
            </Grid>

            <Border Grid.Row="1"
                    Padding="12,8"
                    Background="{StaticResource Brush.Accent.Soft}"
                    BorderBrush="{StaticResource Brush.Border.Accent}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Radius.LG}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentScope}"
                                   Foreground="{StaticResource Brush.Text.Accent}"
                                   FontSize="{StaticResource Font.Size.Caption}"
                                   FontWeight="{StaticResource Font.Weight.Semibold}" />
                        <TextBlock Margin="0,3,0,0"
                                   Text="{Binding CurrentTitle}"
                                   Foreground="{StaticResource Brush.Text.Primary}"
                                   FontSize="{StaticResource Font.Size.Title}"
                                   FontWeight="{StaticResource Font.Weight.Semibold}"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <TextBlock Grid.Column="1"
                               Margin="16,0,0,0"
                               Text="{Binding Position}"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource Brush.Text.Secondary}"
                               FontSize="{StaticResource Font.Size.Caption}" />
                </Grid>
            </Border>

            <Grid Grid.Row="2"
                  Margin="10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding NextTitle}"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource Brush.Text.Tertiary}"
                           FontSize="{StaticResource Font.Size.Body}"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="1"
                           Margin="12,0,0,0"
                           Text="{Binding NextBoundary}"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource Brush.Text.Accent}"
                           FontSize="{StaticResource Font.Size.Caption}" />
            </Grid>
        </Grid>
    </Border>
</Window>
