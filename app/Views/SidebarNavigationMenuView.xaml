<UserControl x:Class="CodexController.Views.SidebarNavigationMenuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="314"
             d:DesignWidth="560"
             Width="560"
             Height="314"
             IsHitTestVisible="False"
             SnapsToDevicePixels="True">
    <UserControl.Resources>
        <Style x:Key="SidebarMenu.NeighborRow"
               TargetType="Border">
            <Setter Property="Height" Value="52" />
            <Setter Property="Background"
                    Value="{StaticResource Brush.Agent.Row.Fill}" />
            <Setter Property="BorderBrush"
                    Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
        </Style>

        <Style x:Key="SidebarMenu.SmallKey"
               TargetType="Border"
               BasedOn="{StaticResource Overlay.PhysicalKey}">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style x:Key="SidebarMenu.HintKey"
               TargetType="Border">
            <Setter Property="MinWidth" Value="30" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Padding" Value="6,0" />
            <Setter Property="Background"
                    Value="{StaticResource Brush.Bg.Surface}" />
            <Setter Property="BorderBrush"
                    Value="{StaticResource Brush.Border.Subtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
    </UserControl.Resources>

    <Grid Width="560"
          Height="314"
          Background="Transparent">
        <Border Width="544"
                Height="298"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Style="{StaticResource Overlay.MicroPanel}">
            <Grid Margin="18,14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="34" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="52" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="64" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="52" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="36" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource Overlay.ModifierBadge}"
                            Margin="0,0,10,0">
                        <TextBlock Text="{Binding NavigateGlyph}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource Brush.Agent.Glyph}"
                                   FontFamily="{StaticResource Font.Mono}"
                                   FontSize="12"
                                   FontWeight="{StaticResource Font.Weight.Bold}" />
                    </Border>
                    <TextBlock Grid.Column="1"
                               Text="{Binding Title}"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource Brush.Text.Secondary}"
                               FontSize="15"
                               FontWeight="{StaticResource Font.Weight.Medium}" />
                    <Border Grid.Column="2"
                            Padding="9,4"
                            VerticalAlignment="Center"
                            Background="{StaticResource Brush.Bg.Sunken}"
                            CornerRadius="8">
                        <TextBlock Text="{Binding Position}"
                                   Foreground="{StaticResource Brush.Text.Tertiary}"
                                   FontFamily="{StaticResource Font.Mono}"
                                   FontSize="11" />
                    </Border>
                </Grid>

                <Border x:Name="PreviousRow"
                        Grid.Row="2"
                        Style="{StaticResource SidebarMenu.NeighborRow}">
                    <Grid Margin="8,5,12,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="48" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border HorizontalAlignment="Left"
                                Style="{StaticResource SidebarMenu.SmallKey}">
                            <TextBlock Text="↑"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource Brush.Text.Secondary}"
                                       FontSize="16" />
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Margin="6,0,0,0"
                                   Text="{Binding PreviousTitle}"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource Brush.Text.Secondary}"
                                   FontSize="14"
                                   TextTrimming="CharacterEllipsis" />
                        <Border Grid.Column="2"
                                Padding="8,3"
                                VerticalAlignment="Center"
                                Background="{StaticResource Brush.Bg.Sunken}"
                                CornerRadius="7">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PreviousBoundary}"
                                                     Value="">
                                            <Setter Property="Visibility"
                                                    Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding PreviousBoundary}"
                                       Foreground="{StaticResource Brush.Text.Tertiary}"
                                       FontSize="10" />
                        </Border>
                    </Grid>
                </Border>

                <Border x:Name="CurrentRow"
                        Grid.Row="4"
                        Height="64"
                        Background="{StaticResource Brush.Agent.Row.Selected}"
                        BorderBrush="{StaticResource Brush.Agent.Row.SelectedBorder}"
                        BorderThickness="2"
                        CornerRadius="16">
                    <Grid Margin="8,6,12,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="48" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border HorizontalAlignment="Left"
                                Style="{StaticResource SidebarMenu.SmallKey}"
                                BorderBrush="{StaticResource Brush.Agent.Row.SelectedBorder}">
                            <Grid>
                                <Ellipse Width="18"
                                         Height="18"
                                         Fill="{StaticResource Brush.Agent.Row.SelectedBorder}"
                                         Opacity="0.3" />
                                <Ellipse Width="9"
                                         Height="9"
                                         Fill="{StaticResource Brush.Agent.Glyph}" />
                            </Grid>
                        </Border>
                        <StackPanel Grid.Column="1"
                                    Margin="6,0,0,0"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding CurrentScope}"
                                       Foreground="{StaticResource Brush.Agent.Glyph}"
                                       FontSize="10"
                                       FontWeight="{StaticResource Font.Weight.Semibold}" />
                            <TextBlock Margin="0,3,0,0"
                                       Text="{Binding CurrentTitle}"
                                       Foreground="{StaticResource Brush.Text.Primary}"
                                       FontSize="15"
                                       FontWeight="{StaticResource Font.Weight.Semibold}"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <TextBlock Grid.Column="2"
                                   Text="✓"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource Brush.Agent.Glyph}"
                                   FontSize="17"
                                   FontWeight="{StaticResource Font.Weight.Semibold}" />
                    </Grid>
                </Border>

                <Border x:Name="NextRow"
                        Grid.Row="6"
                        Style="{StaticResource SidebarMenu.NeighborRow}">
                    <Grid Margin="8,5,12,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="48" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border HorizontalAlignment="Left"
                                Style="{StaticResource SidebarMenu.SmallKey}">
                            <TextBlock Text="↓"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource Brush.Text.Secondary}"
                                       FontSize="16" />
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Margin="6,0,0,0"
                                   Text="{Binding NextTitle}"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource Brush.Text.Secondary}"
                                   FontSize="14"
                                   TextTrimming="CharacterEllipsis" />
                        <Border Grid.Column="2"
                                Padding="8,3"
                                VerticalAlignment="Center"
                                Background="{StaticResource Brush.Bg.Sunken}"
                                CornerRadius="7">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding NextBoundary}"
                                                     Value="">
                                            <Setter Property="Visibility"
                                                    Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding NextBoundary}"
                                       Foreground="{StaticResource Brush.Text.Tertiary}"
                                       FontSize="10" />
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="8"
                        Background="{StaticResource Brush.Bg.Sunken}"
                        BorderBrush="{StaticResource Brush.Border.Subtle}"
                        BorderThickness="1"
                        CornerRadius="10">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                        <Border x:Name="NavigationGlyph"
                                Style="{StaticResource SidebarMenu.HintKey}">
                            <TextBlock Text="{Binding NavigateGlyph}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource Brush.Text.Primary}"
                                       FontFamily="{StaticResource Font.Mono}"
                                       FontSize="10"
                                       FontWeight="{StaticResource Font.Weight.Semibold}" />
                        </Border>
                        <TextBlock Margin="6,0,16,0"
                                   Text="{Binding NavigateHint}"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource Brush.Text.Secondary}"
                                   FontSize="11" />
                        <Border x:Name="ScopeGlyph"
                                Style="{StaticResource SidebarMenu.HintKey}">
                            <TextBlock Text="{Binding CycleScopeGlyph}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource Brush.Text.Primary}"
                                       FontFamily="{StaticResource Font.Mono}"
                                       FontSize="10"
                                       FontWeight="{StaticResource Font.Weight.Semibold}" />
                        </Border>
                        <TextBlock Margin="6,0,16,0"
                                   Text="{Binding CycleScopeHint}"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource Brush.Text.Secondary}"
                                   FontSize="11" />
                        <Border x:Name="OpenGlyph"
                                Style="{StaticResource SidebarMenu.HintKey}">
                            <TextBlock Text="{Binding OpenGlyph}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource Brush.Text.Primary}"
                                       FontFamily="{StaticResource Font.Mono}"
                                       FontSize="10"
                                       FontWeight="{StaticResource Font.Weight.Semibold}" />
                        </Border>
                        <TextBlock Margin="6,0,0,0"
                                   Text="{Binding OpenHint}"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource Brush.Text.Secondary}"
                                   FontSize="11" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
