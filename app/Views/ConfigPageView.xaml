<UserControl x:Class="CodexController.Views.ConfigPageView"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="1060">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="1060">
            <StackPanel Margin="0,4,0,18">
                <TextBlock Text="{Binding Strings.ConfigTitle,
                                          ElementName=Root}"
                           FontSize="{StaticResource Font.Size.Hero}"
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding Description}"
                           Margin="0,5,0,0"
                           Foreground="{StaticResource MutedBrush}"
                           FontSize="{StaticResource Font.Size.Label}" />
            </StackPanel>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource CardStyle}"
                        Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="{Binding LeftStickSidebarTitle}"
                                   FontSize="{StaticResource Font.Size.Title}"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="↑↓"
                                   Margin="0,20,0,0"
                                   Foreground="{StaticResource SageBrush}"
                                   FontSize="{StaticResource Font.Size.TitleLg}"
                                   FontWeight="Bold" />
                        <TextBlock Text="{Binding MoveFocusDescription}"
                                   Margin="0,4,0,0"
                                   FontSize="{StaticResource Font.Size.Label}" />
                        <Separator Margin="0,16"
                                   Background="{StaticResource LineBrush}" />
                        <TextBlock Text="{Binding Strings.ConfigEnterBack,
                                                ElementName=Root}"
                                   Foreground="{StaticResource SageBrush}"
                                   FontSize="{StaticResource Font.Size.TitleLg}"
                                   FontWeight="Bold" />
                        <TextBlock Text="{Binding Strings.ConfigEnterBackDescription,
                                                ElementName=Root}"
                                   Margin="0,4,0,0"
                                   FontSize="{StaticResource Font.Size.Label}" />
                        <Separator Margin="0,16"
                                   Background="{StaticResource LineBrush}" />
                        <TextBlock Text="{Binding RootProjectGlyphs}"
                                   Foreground="{StaticResource SageBrush}"
                                   FontSize="{StaticResource Font.Size.TitleLg}"
                                   FontWeight="Bold" />
                        <TextBlock Text="{Binding RootProjectDescription}"
                                   Margin="0,4,0,0"
                                   FontSize="{StaticResource Font.Size.Label}"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding SidebarBehavior}"
                                   Margin="0,18,0,0"
                                   Foreground="{StaticResource Brush.Text.Secondary}"
                                   FontSize="{StaticResource Font.Size.Label}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Style="{StaticResource CardStyle}"
                        Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="{Binding Strings.ConfigRightStickComposer,
                                                ElementName=Root}"
                                   FontSize="{StaticResource Font.Size.Title}"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="←→ / ↑↓"
                                   Margin="0,20,0,0"
                                   Foreground="{StaticResource SageBrush}"
                                   FontSize="{StaticResource Font.Size.TitleLg}"
                                   FontWeight="Bold" />
                        <TextBlock Text="{Binding Strings.ConfigIncreaseDecreaseDescription,
                                                ElementName=Root}"
                                   Margin="0,4,0,0"
                                   FontSize="{StaticResource Font.Size.Label}" />
                        <Separator Margin="0,16"
                                   Background="{StaticResource LineBrush}" />
                        <TextBlock Text="{Binding ModeSwitchGlyphs}"
                                   Foreground="{StaticResource SageBrush}"
                                   FontSize="{StaticResource Font.Size.TitleLg}"
                                   FontWeight="Bold" />
                        <TextBlock Text="{Binding Strings.ConfigModeSwitchDescription,
                                                ElementName=Root}"
                                   Margin="0,4,0,0"
                                   FontSize="{StaticResource Font.Size.Label}" />
                        <TextBlock Text="{Binding SelectionBehavior}"
                                   Margin="0,18,0,0"
                                   Foreground="{StaticResource Brush.Text.Secondary}"
                                   FontSize="{StaticResource Font.Size.Label}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource CardStyle}"
                    Margin="0,16,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0"
                                Margin="0,0,24,0">
                        <TextBlock Text="{Binding AgentShortcutsTitle}"
                                   FontSize="{StaticResource Font.Size.Title}"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding AgentShortcutsDescription}"
                                   Margin="0,7,0,0"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="{StaticResource Font.Size.Caption}"
                                   TextWrapping="Wrap" />
                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,16,0,0"
                                HorizontalAlignment="Left"
                                Content="{Binding OpenAgentShortcutsText}"
                                IsEnabled="{Binding CanOpenAgentShortcuts}"
                                Command="{Binding OpenAgentShortcutsCommand}" />
                    </StackPanel>

                    <Grid Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0">
                            <TextBlock Text="{Binding Strings.ConfigLowerReasoning,
                                                    ElementName=Root}"
                                       FontSize="{StaticResource Font.Size.Label}"
                                       Foreground="{StaticResource MutedBrush}" />
                            <TextBox Margin="0,5,0,0"
                                     Text="{Binding ReasoningDownShortcut,
                                                    UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="2">
                            <TextBlock Text="{Binding Strings.ConfigRaiseReasoning,
                                                    ElementName=Root}"
                                       FontSize="{StaticResource Font.Size.Label}"
                                       Foreground="{StaticResource MutedBrush}" />
                            <TextBox Margin="0,5,0,0"
                                     Text="{Binding ReasoningUpShortcut,
                                                    UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="0">
                            <TextBlock Text="{Binding Strings.ConfigToggleFast,
                                                    ElementName=Root}"
                                       FontSize="{StaticResource Font.Size.Label}"
                                       Foreground="{StaticResource MutedBrush}" />
                            <TextBox Margin="0,5,0,0"
                                     Text="{Binding FastToggleShortcut,
                                                    UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="2">
                            <TextBlock Text="{Binding Strings.ConfigDictation,
                                                    ElementName=Root}"
                                       FontSize="{StaticResource Font.Size.Label}"
                                       Foreground="{StaticResource MutedBrush}" />
                            <TextBox Margin="0,5,0,0"
                                     Text="{Binding DictationShortcut,
                                                    UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Row="4" Grid.Column="0">
                            <TextBlock Text="{Binding Strings.ConfigModelPicker,
                                                    ElementName=Root}"
                                       FontSize="{StaticResource Font.Size.Label}"
                                       Foreground="{StaticResource MutedBrush}" />
                            <TextBox Margin="0,5,0,0"
                                     Text="{Binding ModelPickerShortcut,
                                                    UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,16,0,8">
                <Button Style="{StaticResource SecondaryButtonStyle}"
                        Content="{Binding Strings.ConfigRestoreRecommended,
                                          ElementName=Root}"
                        Margin="0,0,8,0"
                        Command="{Binding ResetCommand}" />
                <Button Style="{StaticResource PrimaryButtonStyle}"
                        Content="{Binding Strings.ConfigSave,
                                          ElementName=Root}"
                        Command="{Binding SaveCommand}" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
