<Window x:Class="CodexController.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:loc="clr-namespace:CodexController.Localization"
        xmlns:views="clr-namespace:CodexController.Views"
        mc:Ignorable="d"
        Title="Agent Controller"
        Width="1220"
        Height="800"
        MinWidth="1060"
        MinHeight="690"
        Icon="Assets/AgentController.ico"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource CanvasBrush}"
        KeyboardNavigation.TabNavigation="Cycle"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        StateChanged="Window_StateChanged">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="66" />
            <RowDefinition Height="*" />
            <RowDefinition Height="38" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PaperBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Image Width="40"
                           Height="32"
                           Source="Assets/AgentController.png"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <StackPanel Margin="8,0,0,0"
                                VerticalAlignment="Center">
                        <TextBlock Text="{loc:Loc app.title}"
                                   FontSize="{StaticResource Font.Size.Title}"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="AppSubtitleText"
                                   Text="Game Controller → Codex"
                                   Foreground="{StaticResource FaintBrush}"
                                   FontSize="{StaticResource Font.Size.Caption}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <RadioButton x:Name="DeviceNavButton"
                                 GroupName="PrimaryNavigation"
                                 IsChecked="True"
                                 Style="{StaticResource Nav.Segment}"
                                 Content="{loc:Loc nav.device}"
                                 Click="DeviceNavButton_Click" />
                    <RadioButton x:Name="ConfigNavButton"
                                 GroupName="PrimaryNavigation"
                                 Style="{StaticResource Nav.Segment}"
                                 Content="{loc:Loc nav.configuration}"
                                 Click="ConfigNavButton_Click" />
                    <RadioButton x:Name="SettingsNavButton"
                                 GroupName="PrimaryNavigation"
                                 Style="{StaticResource Nav.Segment}"
                                 Content="{loc:Loc nav.settings}"
                                 Click="SettingsNavButton_Click" />
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Ellipse x:Name="ControllerStatusDot"
                             Width="7"
                             Height="7"
                             Fill="{StaticResource FaintBrush}"
                             Margin="0,0,7,0" />
                    <TextBlock x:Name="ControllerStatusText"
                               Text="{loc:Loc device.waiting}"
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="{StaticResource Font.Size.Label}"
                               VerticalAlignment="Center"
                               Margin="0,0,15,0" />
                    <CheckBox x:Name="BridgeEnabledCheckBox"
                              Content="{loc:Loc device.enable-bridge}"
                              IsChecked="True"
                              Checked="BridgeEnabledCheckBox_Changed"
                              Unchecked="BridgeEnabledCheckBox_Changed" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="18">
            <Grid x:Name="DevicePage">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="375" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="0,0,14,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="132" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{loc:Loc device.gamepad-bridge}"
                                               Foreground="{StaticResource Brush.Text.Secondary}"
                                               FontSize="{StaticResource Font.Size.Caption}"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{loc:Loc device.live-input}"
                                               Margin="0,3,0,0"
                                               FontSize="{StaticResource Font.Size.Display}"
                                               FontWeight="SemiBold" />
                                </StackPanel>
                                <Border Grid.Column="1"
                                        Padding="9,5"
                                        BorderBrush="{StaticResource LineBrush}"
                                        BorderThickness="1"
                                        CornerRadius="7"
                                        VerticalAlignment="Top">
                                    <TextBlock x:Name="ControllerLiveBadge"
                                               Text="IDLE"
                                               Foreground="{StaticResource FaintBrush}"
                                               FontFamily="{StaticResource Font.Mono}"
                                               FontSize="{StaticResource Font.Size.Caption}"
                                               FontWeight="Bold" />
                                </Border>
                            </Grid>

                            <Viewbox Grid.Row="1"
                                     Stretch="Uniform"
                                     Margin="12,2">
                                <Grid Width="600" Height="380">
                                    <Image Source="/Assets/controller.png"
                                           Width="600"
                                           Height="380"
                                           Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                    <Canvas Width="600"
                                            Height="380"
                                            IsHitTestVisible="False">
                                        <Border x:Name="LeftTriggerHalo"
                                                Canvas.Left="171"
                                                Canvas.Top="58"
                                                Width="54"
                                                Height="34"
                                                Background="{StaticResource Brush.Accent.Halo}"
                                                BorderBrush="{StaticResource Brush.Accent}"
                                                BorderThickness="2"
                                                CornerRadius="17"
                                                Opacity="0" />
                                        <Border x:Name="LeftShoulderHalo"
                                                Canvas.Left="176"
                                                Canvas.Top="82"
                                                Width="100"
                                                Height="25"
                                                Background="{StaticResource Brush.Accent.Halo}"
                                                BorderBrush="{StaticResource Brush.Accent}"
                                                BorderThickness="2"
                                                CornerRadius="12"
                                                Opacity="0" />
                                        <Border x:Name="RightShoulderHalo"
                                                Canvas.Left="324"
                                                Canvas.Top="82"
                                                Width="100"
                                                Height="25"
                                                Background="{StaticResource Brush.Accent.Halo}"
                                                BorderBrush="{StaticResource Brush.Accent}"
                                                BorderThickness="2"
                                                CornerRadius="12"
                                                Opacity="0" />
                                        <Border x:Name="RightTriggerHalo"
                                                Canvas.Left="375"
                                                Canvas.Top="58"
                                                Width="54"
                                                Height="34"
                                                Background="{StaticResource Brush.Accent.Halo}"
                                                BorderBrush="{StaticResource Brush.Accent}"
                                                BorderThickness="2"
                                                CornerRadius="17"
                                                Opacity="0" />
                                        <Ellipse x:Name="LeftStickHalo"
                                                 Canvas.Left="178"
                                                 Canvas.Top="138"
                                                 Width="46"
                                                 Height="46"
                                                 Stroke="{StaticResource SageBrush}"
                                                 StrokeThickness="2"
                                                 Opacity="0.0">
                                            <Ellipse.RenderTransform>
                                                <TranslateTransform x:Name="LeftStickTransform" />
                                            </Ellipse.RenderTransform>
                                        </Ellipse>
                                        <Ellipse x:Name="RightStickHalo"
                                                 Canvas.Left="326"
                                                 Canvas.Top="196"
                                                 Width="46"
                                                 Height="46"
                                                 Stroke="{StaticResource SageBrush}"
                                                 StrokeThickness="2"
                                                 Opacity="0.0">
                                            <Ellipse.RenderTransform>
                                                <TranslateTransform x:Name="RightStickTransform" />
                                            </Ellipse.RenderTransform>
                                        </Ellipse>
                                        <Ellipse x:Name="ButtonAHalo"
                                                 Canvas.Left="384"
                                                 Canvas.Top="172"
                                                 Width="28"
                                                 Height="28"
                                                 Fill="{StaticResource Brush.Accent.Halo}"
                                                 Stroke="{StaticResource Brush.Accent}"
                                                 StrokeThickness="2"
                                                 Opacity="0" />
                                        <Ellipse x:Name="ButtonXHalo"
                                                 Canvas.Left="359"
                                                 Canvas.Top="146"
                                                 Width="28"
                                                 Height="28"
                                                 Fill="{StaticResource Brush.Accent.Halo}"
                                                 Stroke="{StaticResource Brush.Accent}"
                                                 StrokeThickness="2"
                                                 Opacity="0" />
                                        <Ellipse x:Name="ButtonBHalo"
                                                 Canvas.Left="411"
                                                 Canvas.Top="146"
                                                 Width="28"
                                                 Height="28"
                                                 Fill="{StaticResource Brush.Status.Danger.Halo}"
                                                 Stroke="{StaticResource Brush.Status.Danger}"
                                                 StrokeThickness="2"
                                                 Opacity="0" />
                                        <Ellipse x:Name="ButtonYHalo"
                                                 Canvas.Left="385"
                                                 Canvas.Top="120"
                                                 Width="28"
                                                 Height="28"
                                                 Fill="{StaticResource Brush.Accent.Halo}"
                                                 Stroke="{StaticResource Brush.Accent}"
                                                 StrokeThickness="2"
                                                 Opacity="0" />
                                        <Ellipse x:Name="MenuButtonHalo"
                                                 Canvas.Left="316"
                                                 Canvas.Top="150"
                                                 Width="24"
                                                 Height="24"
                                                 Fill="{StaticResource Brush.Accent.Halo}"
                                                 Stroke="{StaticResource Brush.Accent}"
                                                 StrokeThickness="2"
                                                 Opacity="0" />
                                        <Border Canvas.Left="158"
                                                Canvas.Top="46"
                                                Padding="6,2"
                                                Background="{StaticResource Brush.Bg.Inverse}"
                                                CornerRadius="8">
                                            <TextBlock x:Name="LeftTriggerGlyphText"
                                                       Text="LT"
                                                       Foreground="{StaticResource Brush.Text.Inverse}"
                                                       FontFamily="{StaticResource Font.Mono}"
                                                       FontSize="{StaticResource Font.Size.Caption}"
                                                       FontWeight="Bold" />
                                        </Border>
                                        <Border Canvas.Left="238"
                                                Canvas.Top="72"
                                                Padding="6,2"
                                                Background="{StaticResource Brush.Bg.Inverse}"
                                                CornerRadius="8">
                                            <TextBlock x:Name="LeftShoulderGlyphText"
                                                       Text="LB"
                                                       Foreground="{StaticResource Brush.Text.Inverse}"
                                                       FontFamily="{StaticResource Font.Mono}"
                                                       FontSize="{StaticResource Font.Size.Caption}"
                                                       FontWeight="Bold" />
                                        </Border>
                                        <Border Canvas.Left="338"
                                                Canvas.Top="72"
                                                Padding="6,2"
                                                Background="{StaticResource Brush.Bg.Inverse}"
                                                CornerRadius="8">
                                            <TextBlock x:Name="RightShoulderGlyphText"
                                                       Text="RB"
                                                       Foreground="{StaticResource Brush.Text.Inverse}"
                                                       FontFamily="{StaticResource Font.Mono}"
                                                       FontSize="{StaticResource Font.Size.Caption}"
                                                       FontWeight="Bold" />
                                        </Border>
                                        <Border Canvas.Left="414"
                                                Canvas.Top="46"
                                                Padding="6,2"
                                                Background="{StaticResource Brush.Bg.Inverse}"
                                                CornerRadius="8">
                                            <TextBlock x:Name="RightTriggerGlyphText"
                                                       Text="RT"
                                                       Foreground="{StaticResource Brush.Text.Inverse}"
                                                       FontFamily="{StaticResource Font.Mono}"
                                                       FontSize="{StaticResource Font.Size.Caption}"
                                                       FontWeight="Bold" />
                                        </Border>
                                    </Canvas>
                                </Grid>
                            </Viewbox>

                            <Grid Grid.Row="2" Margin="2,2,2,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{loc:Loc control.left-stick}"
                                               FontSize="{StaticResource Font.Size.Label}"
                                               FontWeight="SemiBold" />
                                    <TextBlock x:Name="LeftStickHintText"
                                               Text="{loc:Loc control.left-stick-hint, Arg0=LS}"
                                               Margin="0,4,0,0"
                                               Foreground="{StaticResource MutedBrush}"
                                               FontSize="{StaticResource Font.Size.Caption}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{loc:Loc control.right-stick}"
                                               FontSize="{StaticResource Font.Size.Label}"
                                               FontWeight="SemiBold" />
                                    <TextBlock x:Name="RightStickHintText"
                                               Text="{loc:Loc control.right-stick-hint, Arg0=RS}"
                                               Margin="0,4,0,0"
                                               Foreground="{StaticResource MutedBrush}"
                                               FontSize="{StaticResource Font.Size.Caption}" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0"
                                Style="{StaticResource Card.Dense}"
                                Margin="0,0,5,0">
                            <StackPanel>
                                <TextBlock x:Name="VoiceGlyphText"
                                           Text="A"
                                           Foreground="{StaticResource Brush.Text.Accent}"
                                           FontSize="{StaticResource Font.Size.TitleLg}"
                                           FontWeight="Bold" />
                                <TextBlock x:Name="VoiceActionTitle"
                                           Text="{loc:Loc control.hold-to-talk, Arg0=A}"
                                           Margin="0,4,0,0"
                                           FontSize="{StaticResource Font.Size.Body}"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{loc:Loc control.hold-to-talk-description}"
                                           Margin="0,3,0,0"
                                           Foreground="{StaticResource Brush.Text.Secondary}"
                                           FontSize="{StaticResource Font.Size.Caption}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1"
                                Style="{StaticResource Card.Dense}"
                                Margin="3,0">
                            <StackPanel>
                                <TextBlock x:Name="SendGlyphText"
                                           Text="X"
                                           FontSize="{StaticResource Font.Size.TitleLg}"
                                           FontWeight="Bold" />
                                <TextBlock x:Name="SendActionTitle"
                                           Text="{loc:Loc control.send, Arg0=X}"
                                           Margin="0,4,0,0"
                                           FontSize="{StaticResource Font.Size.Body}"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{loc:Loc control.send-description}"
                                           Margin="0,3,0,0"
                                           Foreground="{StaticResource Brush.Text.Secondary}"
                                           FontSize="{StaticResource Font.Size.Caption}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2"
                                Style="{StaticResource Card.Dense}"
                                Margin="3,0">
                            <StackPanel>
                                <TextBlock x:Name="CancelGlyphText"
                                           Text="B"
                                           Foreground="{StaticResource Brush.Status.Danger}"
                                           FontSize="{StaticResource Font.Size.TitleLg}"
                                           FontWeight="Bold" />
                                <TextBlock x:Name="CancelActionTitle"
                                           Text="{loc:Loc control.cancel-undo, Arg0=B}"
                                           Margin="0,4,0,0"
                                           FontSize="{StaticResource Font.Size.Body}"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{loc:Loc control.cancel-undo-description}"
                                           Margin="0,3,0,0"
                                           Foreground="{StaticResource Brush.Text.Secondary}"
                                           FontSize="{StaticResource Font.Size.Caption}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="3"
                                Style="{StaticResource Card.Dense}"
                                Margin="3,0">
                            <StackPanel>
                                <TextBlock x:Name="ProjectGlyphText"
                                           Text="Y"
                                           Foreground="{StaticResource Brush.Text.Accent}"
                                           FontSize="{StaticResource Font.Size.TitleLg}"
                                           FontWeight="Bold" />
                                <TextBlock x:Name="ProjectActionTitle"
                                           Text="{loc:Loc control.project-context, Arg0=Y}"
                                           Margin="0,4,0,0"
                                           FontSize="{StaticResource Font.Size.Body}"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{loc:Loc control.project-context-description}"
                                           Margin="0,3,0,0"
                                           Foreground="{StaticResource Brush.Text.Secondary}"
                                           FontSize="{StaticResource Font.Size.Caption}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="4"
                                Style="{StaticResource Card.Dense}"
                                Margin="5,0,0,0">
                            <StackPanel>
                                <TextBlock x:Name="WakeGlyphText"
                                           Text="MENU"
                                           Foreground="{StaticResource Brush.Text.Accent}"
                                           FontSize="{StaticResource Font.Size.Title}"
                                           FontWeight="Bold" />
                                <TextBlock x:Name="WakeActionTitle"
                                           Text="{loc:Loc control.wake-agent, Arg0=MENU, Arg1=Codex}"
                                           Margin="0,4,0,0"
                                           FontSize="{StaticResource Font.Size.Body}"
                                           FontWeight="SemiBold" />
                                <TextBlock x:Name="WakeActionDescription"
                                           Text="{loc:Loc control.wake-agent-description, Arg0=Codex}"
                                           Margin="0,3,0,0"
                                           Foreground="{StaticResource Brush.Text.Secondary}"
                                           FontSize="{StaticResource Font.Size.Caption}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="205" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="132" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid>
                                <TextBlock Text="{loc:Loc composer.right-stick-adjustment}"
                                           FontSize="{StaticResource Font.Size.BodyLg}"
                                           FontWeight="SemiBold" />
                                <TextBlock x:Name="CodexForegroundText"
                                           Text="{loc:Loc composer.agent-not-foreground, Arg0=Codex}"
                                           HorizontalAlignment="Right"
                                           Foreground="{StaticResource Brush.Text.Secondary}"
                                           FontSize="{StaticResource Font.Size.Caption}" />
                            </Grid>
                            <Grid Grid.Row="1" Margin="0,13,0,11">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <RadioButton x:Name="ReasoningModeTab"
                                             Grid.Column="0"
                                             GroupName="ComposerMode"
                                             IsChecked="True"
                                             IsHitTestVisible="False"
                                             Style="{StaticResource Tab.Segment}"
                                             Content="{loc:Loc term.reasoning-effort}"
                                             Margin="0,0,3,0" />
                                <RadioButton x:Name="ModelModeTab"
                                             Grid.Column="1"
                                             GroupName="ComposerMode"
                                             IsHitTestVisible="False"
                                             Style="{StaticResource Tab.Segment}"
                                             Content="{loc:Loc term.model}"
                                             Margin="2,0" />
                                <RadioButton x:Name="SpeedModeTab"
                                             Grid.Column="2"
                                             GroupName="ComposerMode"
                                             IsHitTestVisible="False"
                                             Style="{StaticResource Tab.Segment}"
                                             Content="{loc:Loc term.speed}"
                                             Margin="3,0,0,0" />
                            </Grid>
                            <Border Grid.Row="2"
                                    Background="{StaticResource Brush.Bg.Panel}"
                                    BorderBrush="{StaticResource Brush.Border.Subtle}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource Radius.MD}"
                                    Padding="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="30" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="↓"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource MutedBrush}"
                                               FontSize="{StaticResource Font.Size.Title}" />
                                    <StackPanel Grid.Column="1"
                                                HorizontalAlignment="Center">
                                        <TextBlock x:Name="RightModeLabel"
                                                   Text="{loc:Loc term.reasoning-effort}"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{StaticResource Brush.Text.Secondary}"
                                                   FontSize="{StaticResource Font.Size.Caption}" />
                                        <TextBlock x:Name="RightModeValue"
                                                   Text="High"
                                                   Margin="0,4,0,0"
                                                   HorizontalAlignment="Center"
                                                   FontSize="{StaticResource Font.Size.TitleLg}"
                                                   FontWeight="SemiBold" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="2"
                                               Text="↑"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource MutedBrush}"
                                               FontSize="{StaticResource Font.Size.Title}" />
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Style="{StaticResource CardStyle}"
                            Margin="0,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid>
                                <StackPanel>
                                    <TextBlock x:Name="SidebarTitleText"
                                               Text="{loc:Loc sidebar.agent, Arg0=Codex}"
                                               FontSize="{StaticResource Font.Size.BodyLg}"
                                               FontWeight="SemiBold" />
                                    <TextBlock x:Name="SelectedProjectText"
                                               Text="{loc:Loc sidebar.current-project}"
                                               Margin="0,3,0,0"
                                               Foreground="{StaticResource Brush.Text.Secondary}"
                                               FontSize="{StaticResource Font.Size.Caption}" />
                                </StackPanel>
                                <Button HorizontalAlignment="Right"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Height="28"
                                        Padding="9,0"
                                        Content="{loc:Loc sidebar.refresh}"
                                        Click="RefreshDataButton_Click" />
                            </Grid>
                            <Grid Grid.Row="1" Margin="0,12,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <RadioButton x:Name="PinnedLayerButton"
                                             Grid.Column="0"
                                             GroupName="SidebarRoot"
                                             Style="{StaticResource Tab.Segment}"
                                             Content="{loc:Loc sidebar.pinned-tasks}"
                                             Click="PinnedLayerButton_Click" />
                                <RadioButton x:Name="PinnedProjectsLayerButton"
                                             Grid.Column="1"
                                             GroupName="SidebarRoot"
                                             Style="{StaticResource Tab.Segment}"
                                             Content="{loc:Loc sidebar.pinned-projects}"
                                             Click="PinnedProjectsLayerButton_Click" />
                                <RadioButton x:Name="ProjectsLayerButton"
                                             Grid.Column="2"
                                             GroupName="SidebarRoot"
                                             IsChecked="True"
                                             Style="{StaticResource Tab.Segment}"
                                             Content="{loc:Loc sidebar.projects}"
                                             Click="ProjectsLayerButton_Click" />
                                <RadioButton x:Name="TasksLayerButton"
                                             Grid.Column="3"
                                             GroupName="SidebarRoot"
                                             Style="{StaticResource Tab.Segment}"
                                             Content="{loc:Loc sidebar.projectless-tasks}"
                                             Click="TasksLayerButton_Click" />
                            </Grid>
                            <ListBox x:Name="SidebarList"
                                     Grid.Row="2"
                                     Style="{StaticResource ListBox.Sidebar}"
                                     SelectionChanged="SidebarList_SelectionChanged"
                                     MouseDoubleClick="SidebarList_MouseDoubleClick"
                                     PreviewKeyDown="SidebarList_PreviewKeyDown">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="18" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding KindGlyph}"
                                                       Foreground="{StaticResource Brush.Text.Accent}"
                                                       FontSize="{StaticResource Font.Size.Title}"
                                                       VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="1"
                                                        Margin="8,0,8,0">
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="{StaticResource Font.Size.Body}"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding Subtitle}"
                                                           Margin="0,3,0,0"
                                                           Foreground="{StaticResource Brush.Text.Secondary}"
                                                           FontSize="{StaticResource Font.Size.Caption}" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding PinBadge}"
                                                       Margin="0,0,8,0"
                                                       Foreground="{StaticResource Brush.Text.Accent}"
                                                       FontSize="{StaticResource Font.Size.Caption}"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding ActionHint}"
                                                       Foreground="{StaticResource Brush.Text.Secondary}"
                                                       FontSize="{StaticResource Font.Size.Caption}"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid>
                                <TextBlock Text="{loc:Loc sidebar.recent-events}"
                                           FontSize="{StaticResource Font.Size.Body}"
                                           FontWeight="SemiBold" />
                                <Ellipse x:Name="EventPulse"
                                         Width="6"
                                         Height="6"
                                         HorizontalAlignment="Right"
                                         Fill="{StaticResource SageBrush}" />
                            </Grid>
                            <ItemsControl x:Name="EventList"
                                          Grid.Row="1"
                                          Margin="0,8,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="50" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Time}"
                                                       Foreground="{StaticResource Brush.Text.Secondary}"
                                                       FontFamily="{StaticResource Font.Mono}"
                                                       FontSize="{StaticResource Font.Size.Caption}" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Text}"
                                                       Foreground="{StaticResource Brush.Text.Secondary}"
                                                       FontSize="{StaticResource Font.Size.Caption}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <views:ConfigPageView x:Name="ConfigPage"
                                  Visibility="Collapsed" />

            <views:SettingsPageView x:Name="SettingsPage"
                                    Visibility="Collapsed" />
        </Grid>

        <Border Grid.Row="2"
                Background="{StaticResource PaperBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="20,0">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Ellipse x:Name="FooterPulse"
                             Width="6"
                             Height="6"
                             Fill="{StaticResource SageBrush}"
                             Margin="0,0,8,0" />
                    <TextBlock x:Name="FooterStatusText"
                               Text="{loc:Loc status.loading-agent-data, Arg0=Codex}"
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="{StaticResource Font.Size.Caption}" />
                </StackPanel>
                <TextBlock x:Name="FooterVersionText"
                           Text="v0.3"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource Brush.Text.Secondary}"
                           FontSize="{StaticResource Font.Size.Caption}" />
            </Grid>
        </Border>
    </Grid>
</Window>
