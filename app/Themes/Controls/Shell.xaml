<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Static crystal baseplate: bright bevel, cool wall depth, quiet frost. -->
    <LinearGradientBrush x:Key="Brush.Shell.OuterCrystal"
                         StartPoint="0,1"
                         EndPoint="1,0">
        <GradientStop Offset="0" Color="#F9F2F8F5" />
        <GradientStop Offset="0.42" Color="#F5F7FAF8" />
        <GradientStop Offset="0.76" Color="#F4F4F7F5" />
        <GradientStop Offset="1" Color="#F5F7FAF8" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush.Shell.Wall"
                         StartPoint="0,1"
                         EndPoint="1,0">
        <GradientStop Offset="0" Color="#F6F2F9F6" />
        <GradientStop Offset="0.48" Color="#ECECF3F0" />
        <GradientStop Offset="0.82" Color="#E9DDE8E4" />
        <GradientStop Offset="1" Color="#E4C9DBD4" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush.Shell.WorkSurface"
                         StartPoint="0,0"
                         EndPoint="0,1">
        <GradientStop Offset="0" Color="#FDFDFEFE" />
        <GradientStop Offset="0.72" Color="#FCF7FAF9" />
        <GradientStop Offset="0.94" Color="#FAF1F6F4" />
        <GradientStop Offset="1" Color="#F8E8F2EE" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush.Shell.InnerRim"
                         StartPoint="0,0"
                         EndPoint="0,1">
        <GradientStop Offset="0" Color="#FFFFFFFF" />
        <GradientStop Offset="0.62" Color="#B9E0E7E4" />
        <GradientStop Offset="1" Color="#7FA8BBB5" />
    </LinearGradientBrush>

    <DropShadowEffect x:Key="Shadow.Window"
                      BlurRadius="34"
                      ShadowDepth="8"
                      Opacity="0.18"
                      Color="#344743" />

    <Style x:Key="Shell.NavIcon" TargetType="RadioButton">
        <Setter Property="Width" Value="42" />
        <Setter Property="Height" Value="38" />
        <Setter Property="Margin" Value="2,0" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Tertiary}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource Focus.Ring}" />
        <Setter Property="ToolTipService.InitialShowDelay" Value="180" />
        <Setter Property="ToolTipService.BetweenShowDelay" Value="0" />
        <Setter Property="ToolTipService.ShowDuration" Value="30000" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="12">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#BFFFFFFF" />
                            <Setter TargetName="Root" Property="BorderBrush" Value="#C7FFFFFF" />
                            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource Brush.Accent.Soft}" />
                            <Setter TargetName="Root" Property="BorderBrush" Value="#E8FFFFFF" />
                            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Accent}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Shell.CaptionButton" TargetType="Button">
        <Setter Property="Width" Value="38" />
        <Setter Property="Height" Value="34" />
        <Setter Property="Margin" Value="1,0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}" />
        <Setter Property="FontFamily" Value="Segoe UI Symbol" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource Focus.Ring}" />
        <Setter Property="ToolTipService.InitialShowDelay" Value="180" />
        <Setter Property="ToolTipService.BetweenShowDelay" Value="0" />
        <Setter Property="ToolTipService.ShowDuration" Value="30000" />
        <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            CornerRadius="10">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#AFFFFFFF" />
                            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#D9E6EBE8" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Shell.CaptionButton.Close"
           TargetType="Button"
           BasedOn="{StaticResource Shell.CaptionButton}">
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource Brush.Status.Danger.Halo}" />
                <Setter Property="Foreground" Value="{StaticResource Brush.Status.Danger}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="Shell.IconButton"
           TargetType="Button"
           BasedOn="{StaticResource Shell.CaptionButton}">
        <Setter Property="Width" Value="34" />
        <Setter Property="Height" Value="34" />
        <Setter Property="FontSize" Value="17" />
    </Style>

    <Style x:Key="Shell.Toggle" TargetType="CheckBox">
        <Setter Property="Width" Value="34" />
        <Setter Property="Height" Value="20" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource Focus.Ring}" />
        <Setter Property="ToolTipService.InitialShowDelay" Value="180" />
        <Setter Property="ToolTipService.BetweenShowDelay" Value="0" />
        <Setter Property="ToolTipService.ShowDuration" Value="30000" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid Width="34" Height="20">
                        <Border x:Name="Track"
                                Background="#6F9AA1A0"
                                BorderBrush="#72FFFFFF"
                                BorderThickness="1"
                                CornerRadius="10" />
                        <Ellipse x:Name="Thumb"
                                 Width="14"
                                 Height="14"
                                 Margin="3"
                                 HorizontalAlignment="Left"
                                 Fill="#F7FFFFFF">
                            <Ellipse.Effect>
                                <DropShadowEffect BlurRadius="4"
                                                  ShadowDepth="1"
                                                  Opacity="0.18" />
                            </Ellipse.Effect>
                        </Ellipse>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Track" Property="Background" Value="{StaticResource Brush.Accent}" />
                            <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Track" Property="BorderBrush" Value="#F2FFFFFF" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Button.CrystalKey" TargetType="Button">
        <Setter Property="Height" Value="36" />
        <Setter Property="MinWidth" Value="38" />
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="Background" Value="{StaticResource Brush.Overlay.MicroKey}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Overlay.KeyRim}" />
        <Setter Property="BorderThickness" Value="1,1,1,2" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource Focus.Ring}" />
        <Setter Property="ToolTipService.InitialShowDelay" Value="180" />
        <Setter Property="ToolTipService.BetweenShowDelay" Value="0" />
        <Setter Property="ToolTipService.ShowDuration" Value="30000" />
        <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Keycap"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Keycap" Property="BorderBrush" Value="#FFFFFFFF" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Keycap" Property="Opacity" Value="0.78" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Keycap" Property="Opacity" Value="0.42" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Button.CrystalKey.Icon"
           TargetType="Button"
           BasedOn="{StaticResource Button.CrystalKey}">
        <Setter Property="Width" Value="38" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="FontFamily" Value="Segoe UI Symbol" />
        <Setter Property="FontSize" Value="16" />
    </Style>

    <Style x:Key="Shell.HelpButton" TargetType="Button" BasedOn="{StaticResource Button.CrystalKey.Icon}">
        <Setter Property="Content" Value="?" />
        <Setter Property="FontFamily" Value="{StaticResource Font.Ui}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
</ResourceDictionary>
