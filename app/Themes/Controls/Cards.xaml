<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <LinearGradientBrush x:Key="Brush.Card.CrystalFrost"
                         StartPoint="0,0"
                         EndPoint="0,1">
        <GradientStop Offset="0" Color="#FFFFFFFF" />
        <GradientStop Offset="0.74" Color="#FFF9FAF9" />
        <GradientStop Offset="1" Color="#FFF1F5F3" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush.Card.CrystalRim"
                         StartPoint="0,0"
                         EndPoint="0,1">
        <GradientStop Offset="0" Color="#FFFFFFFF" />
        <GradientStop Offset="1" Color="#C5D7DEDC" />
    </LinearGradientBrush>

    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Brush.Card.CrystalFrost}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Card.CrystalRim}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource Radius.LG}" />
        <Setter Property="Padding" Value="{StaticResource Pad.Card}" />
        <Setter Property="Effect" Value="{StaticResource Shadow.Card}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="Card.Dense"
           TargetType="Border"
           BasedOn="{StaticResource Card}">
        <Setter Property="Padding" Value="{StaticResource Pad.CardDense}" />
    </Style>

    <Style x:Key="CardStyle"
           TargetType="Border"
           BasedOn="{StaticResource Card}" />
</ResourceDictionary>
