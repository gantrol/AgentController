<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <LinearGradientBrush x:Key="Brush.Overlay.MicroPanel"
                         StartPoint="0,0"
                         EndPoint="0,1">
        <GradientStop Offset="0" Color="#FEFFFFFF" />
        <GradientStop Offset="1" Color="#F8F1F1EC" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush.Overlay.MicroKey"
                         StartPoint="0,0"
                         EndPoint="0,1">
        <GradientStop Offset="0" Color="#FFFFFFFF" />
        <GradientStop Offset="0.58" Color="#FFF8F8F5" />
        <GradientStop Offset="1" Color="#FFEAEAE5" />
    </LinearGradientBrush>

    <Style x:Key="Overlay.MicroPanel" TargetType="Border">
        <Setter Property="Background"
                Value="{StaticResource Brush.Overlay.MicroPanel}" />
        <Setter Property="BorderBrush"
                Value="{StaticResource Brush.Overlay.Border.Frosted}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="24" />
        <Setter Property="Effect" Value="{StaticResource Shadow.Overlay}" />
    </Style>

    <Style x:Key="Overlay.PhysicalKey" TargetType="Border">
        <Setter Property="Width" Value="58" />
        <Setter Property="Height" Value="58" />
        <Setter Property="Background"
                Value="{StaticResource Brush.Overlay.MicroKey}" />
        <Setter Property="BorderBrush"
                Value="{StaticResource Brush.Border.Subtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="13" />
        <Setter Property="Effect" Value="{StaticResource Shadow.OverlayKey}" />
    </Style>

    <Style x:Key="Overlay.ModifierBadge" TargetType="Border">
        <Setter Property="Width" Value="42" />
        <Setter Property="Height" Value="26" />
        <Setter Property="Background"
                Value="{StaticResource Brush.Bg.Surface}" />
        <Setter Property="BorderBrush"
                Value="{StaticResource Brush.Border.Subtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>

    <Style x:Key="Overlay.Progress" TargetType="ProgressBar">
        <Setter Property="Height" Value="3" />
        <Setter Property="Foreground"
                Value="{StaticResource Brush.Agent.Glyph}" />
        <Setter Property="Background"
                Value="{StaticResource Brush.Bg.Sunken}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Grid Height="{TemplateBinding Height}"
                          ClipToBounds="True">
                        <Rectangle Fill="{TemplateBinding Background}"
                                   RadiusX="1.5"
                                   RadiusY="1.5" />
                        <Rectangle x:Name="PART_Indicator"
                                   HorizontalAlignment="Left"
                                   Fill="{TemplateBinding Foreground}"
                                   RadiusX="1.5"
                                   RadiusY="1.5" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Overlay.Toast" TargetType="Border">
        <Setter Property="Padding" Value="{StaticResource Pad.CardDense}" />
        <Setter Property="Background" Value="{StaticResource Brush.Bg.Panel}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource Radius.LG}" />
        <Setter Property="Effect" Value="{StaticResource Shadow.Overlay}" />
    </Style>
</ResourceDictionary>
