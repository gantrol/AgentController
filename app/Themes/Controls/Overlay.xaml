<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Large overlay panels use a quiet frosted face with refraction held at
         the material edges. The mint band sits inside the lower edge rather
         than being painted across the content surface. -->
    <LinearGradientBrush x:Key="Brush.Overlay.CrystalFace"
                         StartPoint="0,0"
                         EndPoint="0,1">
        <GradientStop Offset="0" Color="#FAFFFFFF" />
        <GradientStop Offset="0.62" Color="#F7FBFCFB" />
        <GradientStop Offset="1" Color="#F1F3F9F7" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush.Overlay.CrystalUnderlight"
                         StartPoint="0,0"
                         EndPoint="0,1">
        <GradientStop Offset="0" Color="#00C8E4DA" />
        <GradientStop Offset="0.56" Color="#30B8DDCF" />
        <GradientStop Offset="1" Color="#72A8D3C3" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush.Overlay.CrystalTopRefraction"
                         StartPoint="0,0"
                         EndPoint="1,0">
        <GradientStop Offset="0" Color="#00FFFFFF" />
        <GradientStop Offset="0.18" Color="#86FFFFFF" />
        <GradientStop Offset="0.50" Color="#C8FFFFFF" />
        <GradientStop Offset="0.82" Color="#86FFFFFF" />
        <GradientStop Offset="1" Color="#00FFFFFF" />
    </LinearGradientBrush>

    <DrawingBrush x:Key="Brush.Overlay.MicroPanel"
                  Stretch="Fill">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="{StaticResource Brush.Overlay.CrystalFace}"
                                 Geometry="M 0,0 L 1,0 1,1 0,1 Z" />
                <GeometryDrawing Brush="{StaticResource Brush.Overlay.CrystalUnderlight}"
                                 Geometry="M 0,0.88 L 1,0.88 1,1 0,1 Z" />
                <GeometryDrawing Brush="{StaticResource Brush.Overlay.CrystalTopRefraction}"
                                 Geometry="M 0.04,0 L 0.96,0 0.96,0.012 0.04,0.012 Z" />
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>

    <LinearGradientBrush x:Key="Brush.Overlay.CrystalRim"
                         StartPoint="0,0"
                         EndPoint="0,1">
        <GradientStop Offset="0" Color="#FFFFFFFF" />
        <GradientStop Offset="0.16" Color="#EDF7FAF8" />
        <GradientStop Offset="0.66" Color="#C9E1E9E5" />
        <GradientStop Offset="0.92" Color="#B2BCD9D0" />
        <GradientStop Offset="1" Color="#91A8CABD" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush.Overlay.MicroKey"
                         StartPoint="0,0"
                         EndPoint="0,1">
        <GradientStop Offset="0" Color="#FFFFFFFF" />
        <GradientStop Offset="0.54" Color="#FFFAF9F5" />
        <GradientStop Offset="0.84" Color="#FFF0F3F2" />
        <GradientStop Offset="1" Color="#FFD7E0E1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush.Overlay.KeyRim"
                         StartPoint="0,0"
                         EndPoint="0,1">
        <GradientStop Offset="0" Color="#FFFFFFFF" />
        <GradientStop Offset="0.68" Color="#D8E3E7E6" />
        <GradientStop Offset="1" Color="#9EABB8B9" />
    </LinearGradientBrush>

    <!-- The toast is a small crystal backplate, not an oversized keycap. -->
    <LinearGradientBrush x:Key="Brush.Overlay.ToastCrystalFace"
                         StartPoint="0,0"
                         EndPoint="0,1">
        <GradientStop Offset="0" Color="#F9FFFFFF" />
        <GradientStop Offset="0.62" Color="#F4FAFCFB" />
        <GradientStop Offset="1" Color="#EDF0F8F5" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush.Overlay.ToastCrystalEdge"
                         StartPoint="0,1"
                         EndPoint="1,0">
        <GradientStop Offset="0" Color="#EDE9F5F1" />
        <GradientStop Offset="0.46" Color="#FAFFFFFF" />
        <GradientStop Offset="1" Color="#F2F4FAF7" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush.Overlay.ToastRefraction"
                         StartPoint="0,0"
                         EndPoint="1,0">
        <GradientStop Offset="0" Color="#00FFFFFF" />
        <GradientStop Offset="0.18" Color="#74FFFFFF" />
        <GradientStop Offset="0.50" Color="#B8FFFFFF" />
        <GradientStop Offset="0.82" Color="#74FFFFFF" />
        <GradientStop Offset="1" Color="#00FFFFFF" />
    </LinearGradientBrush>

    <DropShadowEffect x:Key="Shadow.Overlay.ToastCrystal"
                      BlurRadius="30"
                      ShadowDepth="7"
                      Opacity="0.15"
                      Color="#3D514B" />

    <DropShadowEffect x:Key="Shadow.Overlay.CrystalPanel"
                      BlurRadius="30"
                      ShadowDepth="7"
                      Opacity="0.13"
                      Color="#3D514B" />

    <Style x:Key="Overlay.CrystalPanel" TargetType="Border">
        <Setter Property="Background"
                Value="{StaticResource Brush.Overlay.MicroPanel}" />
        <Setter Property="BorderBrush"
                Value="{StaticResource Brush.Overlay.CrystalRim}" />
        <Setter Property="BorderThickness" Value="4" />
        <Setter Property="CornerRadius" Value="24" />
        <Setter Property="Effect"
                Value="{StaticResource Shadow.Overlay.CrystalPanel}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="Overlay.MicroPanel"
           TargetType="Border"
           BasedOn="{StaticResource Overlay.CrystalPanel}" />

    <Style x:Key="Overlay.PhysicalKey" TargetType="Border">
        <Setter Property="Width" Value="58" />
        <Setter Property="Height" Value="58" />
        <Setter Property="Background"
                Value="{StaticResource Brush.Overlay.MicroKey}" />
        <Setter Property="BorderBrush"
                Value="{StaticResource Brush.Overlay.KeyRim}" />
        <Setter Property="BorderThickness" Value="1,1,1,2" />
        <Setter Property="CornerRadius" Value="13" />
        <Setter Property="Effect" Value="{StaticResource Shadow.OverlayKey}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="ToolTipService.InitialShowDelay" Value="180" />
        <Setter Property="ToolTipService.BetweenShowDelay" Value="0" />
        <Setter Property="ToolTipService.ShowDuration" Value="30000" />
        <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
    </Style>

    <Style x:Key="Overlay.PhysicalKey.Compact"
           TargetType="Border"
           BasedOn="{StaticResource Overlay.PhysicalKey}">
        <Setter Property="MinWidth" Value="32" />
        <Setter Property="Width" Value="Auto" />
        <Setter Property="Height" Value="25" />
        <Setter Property="Padding" Value="6,0" />
        <Setter Property="CornerRadius" Value="7" />
        <Setter Property="BorderThickness" Value="1,1,1,2" />
    </Style>

    <Style x:Key="Overlay.PhysicalKey.Chip"
           TargetType="Border"
           BasedOn="{StaticResource Overlay.PhysicalKey}">
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="32" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="BorderThickness" Value="1,1,1,2" />
    </Style>

    <Style x:Key="Overlay.ModifierBadge"
           TargetType="Border"
           BasedOn="{StaticResource Overlay.PhysicalKey}">
        <Setter Property="Width" Value="42" />
        <Setter Property="Height" Value="26" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>

    <Style x:Key="Overlay.Progress" TargetType="ProgressBar">
        <Setter Property="Height" Value="3" />
        <Setter Property="Foreground"
                Value="{StaticResource Brush.Agent.Glyph}" />
        <Setter Property="Background"
                Value="{StaticResource Brush.Bg.Sunken}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Grid Height="{TemplateBinding Height}"
                          ClipToBounds="True">
                        <Rectangle Fill="{TemplateBinding Background}"
                                   RadiusX="1.5"
                                   RadiusY="1.5" />
                        <Rectangle x:Name="PART_Indicator"
                                   HorizontalAlignment="Left"
                                   Fill="{TemplateBinding Foreground}"
                                   RadiusX="1.5"
                                   RadiusY="1.5" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Overlay.Toast"
           TargetType="Border">
        <Setter Property="MinHeight" Value="72" />
        <Setter Property="Padding" Value="16,13,20,15" />
        <Setter Property="Background"
                Value="{StaticResource Brush.Overlay.ToastCrystalFace}" />
        <Setter Property="BorderBrush"
                Value="{StaticResource Brush.Overlay.ToastCrystalEdge}" />
        <Setter Property="BorderThickness" Value="4" />
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="Effect"
                Value="{StaticResource Shadow.Overlay.ToastCrystal}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>
</ResourceDictionary>
