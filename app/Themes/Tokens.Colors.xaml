<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options">

    <Color x:Key="Color.Sand.0">#FFFFFF</Color>
    <Color x:Key="Color.Sand.50">#FBFBF8</Color>
    <Color x:Key="Color.Sand.100">#F6F6F2</Color>
    <Color x:Key="Color.Sand.150">#F1F1EC</Color>
    <Color x:Key="Color.Sand.200">#ECECE7</Color>
    <Color x:Key="Color.Sand.300">#DEDDD7</Color>
    <Color x:Key="Color.Sand.400">#C9C9C2</Color>
    <Color x:Key="Color.Sand.500">#A4A59F</Color>
    <Color x:Key="Color.Sand.600">#73746E</Color>
    <Color x:Key="Color.Canvas.0">#F2F1EC</Color>
    <Color x:Key="Color.Ink.500">#4F504C</Color>
    <Color x:Key="Color.Ink.700">#363733</Color>
    <Color x:Key="Color.Ink.900">#1B1C19</Color>
    <Color x:Key="Color.Sage.100">#E6EBE6</Color>
    <Color x:Key="Color.Sage.200">#CFD9D1</Color>
    <Color x:Key="Color.Sage.300">#91A397</Color>
    <Color x:Key="Color.Sage.600">#53675A</Color>
    <Color x:Key="Color.Blue.600">#347FC4</Color>
    <Color x:Key="Color.Green.600">#2F6A45</Color>
    <Color x:Key="Color.Amber.600">#A56A1C</Color>
    <Color x:Key="Color.Red.600">#9E4A43</Color>
    <Color x:Key="Color.Red.100">#F1E6E4</Color>
    <Color x:Key="Color.Lavender.100">#F0F1FF</Color>
    <Color x:Key="Color.Lavender.300">#C7CCFA</Color>
    <Color x:Key="Color.Lavender.600">#6873C7</Color>

    <SolidColorBrush x:Key="Brush.Bg.Canvas"
                     Color="{StaticResource Color.Canvas.0}"
                     po:Freeze="True" />
    <SolidColorBrush x:Key="Brush.Bg.Panel"
                     Color="{StaticResource Color.Sand.50}"
                     po:Freeze="True" />
    <SolidColorBrush x:Key="Brush.Bg.Surface"
                     Color="{StaticResource Color.Sand.0}"
                     po:Freeze="True" />
    <SolidColorBrush x:Key="Brush.Bg.Sunken"
                     Color="{StaticResource Color.Sand.150}"
                     po:Freeze="True" />
    <SolidColorBrush x:Key="Brush.Bg.Hover"
                     Color="{StaticResource Color.Sand.100}"
                     po:Freeze="True" />
    <SolidColorBrush x:Key="Brush.Bg.Inverse"
                     Color="{StaticResource Color.Ink.900}"
                     po:Freeze="True" />
    <SolidColorBrush x:Key="Brush.Text.Primary"
                     Color="{StaticResource Color.Ink.900}"
                     po:Freeze="True" />
    <SolidColorBrush x:Key="Brush.Text.Secondary"
                     Color="{StaticResource Color.Sand.600}"
                     po:Freeze="True" />
    <SolidColorBrush x:Key="Brush.Text.Tertiary"
                     Color="{StaticResource Color.Sand.500}"
                     po:Freeze="True" />
    <SolidColorBrush x:Key="Brush.Text.Inverse"
                     Color="{StaticResource Color.Sand.0}"
                     po:Freeze="True" />
    <SolidColorBrush x:Key="Brush.Text.Accent"
                     Color="{StaticResource Color.Sage.600}"
                     po:Freeze="True" />
    <SolidColorBrush x:Key="Brush.Border.Subtle"
                     Color="{StaticResource Color.Sand.300}"
                     po:Freeze="True" />
    <SolidColorBrush x:Key="Brush.Border.Strong"
                     Color="{StaticResource Color.Sand.400}"
                     po:Freeze="True" />
    <SolidColorBrush x:Key="Brush.Border.Accent"
                     Color="{StaticResource Color.Sage.200}"
                     po:Freeze="True" />
    <SolidColorBrush x:Key="Brush.Accent"
                     Color="{StaticResource Color.Sage.600}"
                     po:Freeze="True" />
    <SolidColorBrush x:Key="Brush.Accent.Soft"
                     Color="{StaticResource Color.Sage.100}"
                     po:Freeze="True" />
    <SolidColorBrush x:Key="Brush.Accent.Halo"
                     Color="#3A53675A"
                     po:Freeze="True" />
    <SolidColorBrush x:Key="Brush.Status.Idle"
                     Color="{StaticResource Color.Sand.500}"
                     po:Freeze="True" />
    <SolidColorBrush x:Key="Brush.Status.Busy"
                     Color="{StaticResource Color.Sand.600}"
                     po:Freeze="True" />
    <SolidColorBrush x:Key="Brush.Status.Success"
                     Color="{StaticResource Color.Green.600}"
                     po:Freeze="True" />
    <SolidColorBrush x:Key="Brush.Status.Warning"
                     Color="{StaticResource Color.Amber.600}"
                     po:Freeze="True" />
    <SolidColorBrush x:Key="Brush.Status.Danger"
                     Color="{StaticResource Color.Red.600}"
                     po:Freeze="True" />
    <SolidColorBrush x:Key="Brush.Status.Danger.Halo"
                     Color="#339E4A43"
                     po:Freeze="True" />
    <SolidColorBrush x:Key="Brush.Focus.Ring"
                     Color="#4753675A"
                     po:Freeze="True" />

    <!-- Overlay surfaces stay warm and legible above both light and dark apps. -->
    <SolidColorBrush x:Key="Brush.Overlay.Surface.Frosted"
                     Color="#F7FBFBF8"
                     po:Freeze="True" />
    <SolidColorBrush x:Key="Brush.Overlay.Surface.Glass"
                     Color="#26FBFBF8"
                     po:Freeze="True" />
    <SolidColorBrush x:Key="Brush.Overlay.Glyph.Fill"
                     Color="#F4FBFBF8"
                     po:Freeze="True" />
    <SolidColorBrush x:Key="Brush.Overlay.Anchor.Fill"
                     Color="#F8FBFBF8"
                     po:Freeze="True" />
    <SolidColorBrush x:Key="Brush.Overlay.Target.Fill"
                     Color="#D9FBFBF8"
                     po:Freeze="True" />
    <SolidColorBrush x:Key="Brush.Overlay.Halo"
                     Color="#6BCFD9D1"
                     po:Freeze="True" />
    <SolidColorBrush x:Key="Brush.Overlay.Border.Frosted"
                     Color="#B9DEDDD7"
                     po:Freeze="True" />
    <SolidColorBrush x:Key="Brush.Overlay.Border.OnAccent"
                     Color="#DFFFFFFF"
                     po:Freeze="True" />
    <SolidColorBrush x:Key="Brush.Overlay.Border.OnAccent.Strong"
                     Color="#FFFFFFFF"
                     po:Freeze="True" />
    <SolidColorBrush x:Key="Brush.Overlay.OnAccent"
                     Color="#FFFFFFFF"
                     po:Freeze="True" />
    <SolidColorBrush x:Key="Brush.Overlay.OnAccent.Muted"
                     Color="#DFFFFFFF"
                     po:Freeze="True" />
    <SolidColorBrush x:Key="Brush.Overlay.Progress.Track"
                     Color="#55FFFFFF"
                     po:Freeze="True" />

    <!-- Micro-inspired Agent panel. Status colors remain independent from selection. -->
    <SolidColorBrush x:Key="Brush.Agent.Row.Fill"
                     Color="#DFFFFFFF"
                     po:Freeze="True" />
    <SolidColorBrush x:Key="Brush.Agent.Row.Selected"
                     Color="{StaticResource Color.Lavender.100}"
                     po:Freeze="True" />
    <SolidColorBrush x:Key="Brush.Agent.Row.SelectedBorder"
                     Color="{StaticResource Color.Lavender.300}"
                     po:Freeze="True" />
    <SolidColorBrush x:Key="Brush.Agent.Glyph"
                     Color="{StaticResource Color.Lavender.600}"
                     po:Freeze="True" />

    <!-- Codex Micro-compatible task status lights. -->
    <SolidColorBrush x:Key="Brush.Led.Idle"
                     Color="{StaticResource Color.Sand.400}"
                     po:Freeze="True" />
    <SolidColorBrush x:Key="Brush.Led.Unknown"
                     Color="{StaticResource Color.Sand.500}"
                     po:Freeze="True" />
    <SolidColorBrush x:Key="Brush.Led.Working"
                     Color="{StaticResource Color.Blue.600}"
                     po:Freeze="True" />
    <SolidColorBrush x:Key="Brush.Led.CompleteUnread"
                     Color="#78B64D"
                     po:Freeze="True" />
    <SolidColorBrush x:Key="Brush.Led.RequiresInput"
                     Color="#F09A22"
                     po:Freeze="True" />
    <SolidColorBrush x:Key="Brush.Led.Error"
                     Color="#E24B4B"
                     po:Freeze="True" />
    <SolidColorBrush x:Key="Brush.Led.Off"
                     Color="#00FFFFFF"
                     po:Freeze="True" />

    <!-- Transitional aliases used by existing views while they move to tokens. -->
    <SolidColorBrush x:Key="CanvasBrush"
                     Color="{StaticResource Color.Canvas.0}" />
    <SolidColorBrush x:Key="PanelBrush"
                     Color="{StaticResource Color.Sand.50}" />
    <SolidColorBrush x:Key="PaperBrush"
                     Color="{StaticResource Color.Sand.0}" />
    <SolidColorBrush x:Key="InkBrush"
                     Color="{StaticResource Color.Ink.900}" />
    <SolidColorBrush x:Key="MutedBrush"
                     Color="{StaticResource Color.Sand.600}" />
    <SolidColorBrush x:Key="FaintBrush"
                     Color="{StaticResource Color.Sand.500}" />
    <SolidColorBrush x:Key="LineBrush"
                     Color="{StaticResource Color.Sand.300}" />
    <SolidColorBrush x:Key="StrongLineBrush"
                     Color="{StaticResource Color.Sand.400}" />
    <SolidColorBrush x:Key="SageBrush"
                     Color="{StaticResource Color.Sage.600}" />
    <SolidColorBrush x:Key="SageSoftBrush"
                     Color="{StaticResource Color.Sage.100}" />
    <SolidColorBrush x:Key="GreenBrush"
                     Color="{StaticResource Color.Green.600}" />
    <SolidColorBrush x:Key="AmberBrush"
                     Color="{StaticResource Color.Amber.600}" />
    <SolidColorBrush x:Key="RedBrush"
                     Color="{StaticResource Color.Red.600}" />
</ResourceDictionary>
