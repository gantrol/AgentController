<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Hairline borders carry structure; shadows stay soft and neutral. -->
    <DropShadowEffect x:Key="Shadow.Overlay"
                      BlurRadius="18"
                      ShadowDepth="4"
                      Opacity="0.12"
                      Color="#1A1C1D" />
    <DropShadowEffect x:Key="Shadow.Card"
                      BlurRadius="8"
                      ShadowDepth="1"
                      Opacity="0.05"
                      Color="#1A1C1D" />
    <DropShadowEffect x:Key="Shadow.OverlayKey"
                      BlurRadius="8"
                      ShadowDepth="2"
                      Opacity="0.10"
                      Color="#515455" />
</ResourceDictionary>
