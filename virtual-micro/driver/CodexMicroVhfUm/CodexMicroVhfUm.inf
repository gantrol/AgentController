[Version]
Signature="$WINDOWS NT$"
Class=HIDClass
ClassGuid={745a17a0-74d3-11d0-b6fe-00a0c90f57da}
Provider=%ProviderName%
DriverVer=07/18/2026,1.0.0.5
CatalogFile=CodexMicroVhfUm.cat
PnpLockdown=1

[DestinationDirs]
DriverCopyFiles=12,UMDF

[SourceDisksNames]
1=%DiskName%,,,

[SourceDisksFiles]
CodexMicroVhfUm.dll=1

[Manufacturer]
%ManufacturerName%=Standard,NTamd64.10.0...19041

[Standard.NTamd64.10.0...19041]
%DeviceName%=Device_Install,Root\CodexMicroHidUm

[Device_Install.NT]
CopyFiles=DriverCopyFiles
Include=wudfrd.inf
Needs=WUDFRD.NT

[Device_Install.NT.HW]
AddReg=VhfUserMode
Include=wudfrd.inf
Needs=WUDFRD.NT.HW

[VhfUserMode]
HKR,,LowerFilters,0x00010000,"vhf"
HKR,,VhfMode,0x00010001,0x1
HKR,,Security,,"D:P(A;;GA;;;SY)(A;;GA;;;BA)(A;;GRGW;;;IU)"

[Device_Install.NT.Services]
Include=wudfrd.inf
Needs=WUDFRD.NT.Services

[Device_Install.NT.Wdf]
UmdfService=CodexMicroVhfUm105,CodexMicroVhfUm105_Service
UmdfServiceOrder=CodexMicroVhfUm105

[CodexMicroVhfUm105_Service]
UmdfLibraryVersion=2.23.0
ServiceBinary=%12%\UMDF\CodexMicroVhfUm.dll

[DriverCopyFiles]
CodexMicroVhfUm.dll

[Strings]
ProviderName="Codex Micro Simulator"
ManufacturerName="Codex Micro Simulator"
DeviceName="Codex Micro Simulator UMDF2 Virtual HID"
DiskName="Codex Micro VHF User-Mode Driver Package"
