<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
        <SolidColorBrush x:Key="InkBrush" Color="#2F3438" />
        <SolidColorBrush x:Key="MutedInkBrush" Color="#737C82" />
        <SolidColorBrush x:Key="KeyEdgeBrush" Color="#F7FFFFFF" />
        <SolidColorBrush x:Key="CrystalShadowBrush" Color="#44343B40" />
        <LinearGradientBrush x:Key="CrystalKeySideBrush"
                             StartPoint="0,0"
                             EndPoint="0,1">
            <GradientStop Color="#E8FFFFFF" Offset="0" />
            <GradientStop Color="#CDE8F0EF" Offset="0.48" />
            <GradientStop Color="#9DAAB8BA" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="CrystalKeyTopBrush"
                             StartPoint="0,0"
                             EndPoint="0,1">
            <GradientStop Color="#FFFFFFFF" Offset="0" />
            <GradientStop Color="#FFF9F8F4" Offset="0.52" />
            <GradientStop Color="#F3E8EEEE" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="PaperAgentKeyBaseBrush"
                             StartPoint="0,0"
                             EndPoint="1,1">
            <GradientStop Color="#B8F3F6F4" Offset="0" />
            <GradientStop Color="#A3DCE2DF" Offset="0.48" />
            <GradientStop Color="#8FC8D0CC" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="PaperCommandKeyBaseBrush"
                             StartPoint="0,0"
                             EndPoint="1,1">
            <GradientStop Color="#FFFFFFFF" Offset="0" />
            <GradientStop Color="#FFF9FAF9" Offset="0.48" />
            <GradientStop Color="#FFE8EBE9" Offset="1" />
        </LinearGradientBrush>
        <RadialGradientBrush x:Key="PaperAgentWellBrush"
                             Center="0.42,0.34"
                             GradientOrigin="0.42,0.34"
                             RadiusX="0.76"
                             RadiusY="0.76">
            <GradientStop Color="#57FFFFFF" Offset="0" />
            <GradientStop Color="#14FFFFFF" Offset="0.46" />
            <GradientStop Color="#1F606663" Offset="1" />
        </RadialGradientBrush>
        <RadialGradientBrush x:Key="PaperCommandWellBrush"
                             Center="0.43,0.35"
                             GradientOrigin="0.43,0.35"
                             RadiusX="0.76"
                             RadiusY="0.76">
            <GradientStop Color="#EBFFFFFF" Offset="0" />
            <GradientStop Color="#D1F7F8F7" Offset="0.48" />
            <GradientStop Color="#7AD7DCDA" Offset="1" />
        </RadialGradientBrush>
        <LinearGradientBrush x:Key="PaperKeyWellEdgeBrush"
                             StartPoint="0,0"
                             EndPoint="1,1">
            <GradientStop Color="#70FFFFFF" Offset="0" />
            <GradientStop Color="#24FFFFFF" Offset="0.45" />
            <GradientStop Color="#264B514E" Offset="1" />
        </LinearGradientBrush>
        <Geometry x:Key="JoystickChevronGeometry">M 1,7 L 6,2 L 11,7</Geometry>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI Variable Text" />
        </Style>

        <Style TargetType="{x:Type ToolTip}">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Placement" Value="MousePoint" />
            <Setter Property="HorizontalOffset" Value="14" />
            <Setter Property="VerticalOffset" Value="14" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToolTip}">
                        <Border Padding="11,9"
                                MaxWidth="330"
                                Background="#F7F7F5F1"
                                BorderBrush="#E8FFFFFF"
                                BorderThickness="1"
                                CornerRadius="10">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12"
                                                  Direction="270"
                                                  ShadowDepth="3"
                                                  Opacity="0.26"
                                                  Color="#4A5358" />
                            </Border.Effect>
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CommandKey" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PaperCommandKeyBaseBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource KeyEdgeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Margin="0.5">
                            <Border x:Name="FarShadow"
                                    Margin="4,7,4,-1"
                                    Background="#33363C39"
                                    CornerRadius="14"
                                    Opacity="1">
                                <Border.Effect>
                                    <BlurEffect Radius="8" />
                                </Border.Effect>
                            </Border>
                            <Border x:Name="SwitchShadow"
                                    Margin="1,3,1,0"
                                    Background="#B8ADB4B0"
                                    CornerRadius="14"
                                    Opacity="1" />
                            <Border x:Name="CrystalSide"
                                    Margin="1,3,1,0"
                                    Background="#D9E7EAE8"
                                    BorderBrush="#8CFFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="14" />
                            <Border x:Name="Cap"
                                    Margin="1,0,1,3"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="#F2FFFFFF"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="14">
                                <Grid>
                                    <Border Margin="2,2,1,1"
                                            BorderBrush="#295F6662"
                                            BorderThickness="0,0,1,1"
                                            CornerRadius="13" />
                                    <Border Margin="1,1,2,2"
                                            BorderBrush="#F2FFFFFF"
                                            BorderThickness="1,1,0,0"
                                            CornerRadius="13" />
                                    <Border x:Name="KeyWellDark"
                                            Width="78"
                                            Height="78"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Background="#14747B77"
                                            CornerRadius="39">
                                        <Border.RenderTransform>
                                            <TranslateTransform X="1" Y="1" />
                                        </Border.RenderTransform>
                                    </Border>
                                    <Border x:Name="KeyWell"
                                            Width="76"
                                            Height="76"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Background="{StaticResource PaperCommandWellBrush}"
                                            BorderBrush="#8CFFFFFF"
                                            BorderThickness="1"
                                            CornerRadius="38" />
                                    <Border x:Name="KeyWellHighlight"
                                            Width="74"
                                            Height="74"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Background="Transparent"
                                            BorderBrush="{StaticResource PaperKeyWellEdgeBrush}"
                                            BorderThickness="1"
                                            CornerRadius="37" />
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                </Grid>
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="2"
                                                      Direction="270"
                                                      ShadowDepth="1"
                                                      Opacity="0.12"
                                                      Color="#5F6662" />
                                </Border.Effect>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag" Value="ACT10_ACT11">
                                <Setter TargetName="KeyWellDark" Property="Width" Value="162" />
                                <Setter TargetName="KeyWell" Property="Width" Value="160" />
                                <Setter TargetName="KeyWellHighlight" Property="Width" Value="158" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Cap" Property="BorderBrush" Value="#FFFFFFFF" />
                                <Setter TargetName="KeyWellHighlight" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ThicknessAnimation Storyboard.TargetName="Cap"
                                                                Storyboard.TargetProperty="Margin"
                                                                To="1,2,1,1"
                                                                Duration="0:0:0.08" />
                                            <DoubleAnimation Storyboard.TargetName="CrystalSide"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.42"
                                                             Duration="0:0:0.08" />
                                            <DoubleAnimation Storyboard.TargetName="SwitchShadow"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.35"
                                                             Duration="0:0:0.08" />
                                            <DoubleAnimation Storyboard.TargetName="FarShadow"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.45"
                                                             Duration="0:0:0.08" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ThicknessAnimation Storyboard.TargetName="Cap"
                                                                Storyboard.TargetProperty="Margin"
                                                                To="1,0,1,3"
                                                                Duration="0:0:0.11">
                                                <ThicknessAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </ThicknessAnimation.EasingFunction>
                                            </ThicknessAnimation>
                                            <DoubleAnimation Storyboard.TargetName="CrystalSide"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="0:0:0.11" />
                                            <DoubleAnimation Storyboard.TargetName="SwitchShadow"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="0:0:0.11" />
                                            <DoubleAnimation Storyboard.TargetName="FarShadow"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="0:0:0.11" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AgentKey" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PaperAgentKeyBaseBrush}" />
            <Setter Property="BorderBrush" Value="#008DB5FF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Margin="0.5">
                            <Border x:Name="FarShadow"
                                    Margin="4,7,4,-1"
                                    Background="#243A403D"
                                    CornerRadius="14"
                                    Opacity="1">
                                <Border.Effect>
                                    <BlurEffect Radius="8" />
                                </Border.Effect>
                            </Border>
                            <Border x:Name="SwitchShadow"
                                    Margin="2,3,2,0"
                                    Background="#3D3A403D"
                                    CornerRadius="14"
                                    Opacity="1">
                                <Border.Effect>
                                    <BlurEffect Radius="3" />
                                </Border.Effect>
                            </Border>
                            <Border x:Name="Glow"
                                    Margin="-4,-4,-4,-4"
                                    Background="{TemplateBinding BorderBrush}"
                                    CornerRadius="14"
                                    Opacity="0.28">
                                <Border.Effect>
                                    <BlurEffect Radius="5.3" />
                                </Border.Effect>
                            </Border>
                            <Border x:Name="CrystalSide"
                                    Margin="1,3,1,0"
                                    Background="#B8D4DAD7"
                                    BorderBrush="#99FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Opacity="0.86" />
                            <Border x:Name="Cap"
                                    Margin="1,0,1,3"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="#99FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="14">
                                <Grid>
                                    <Border Margin="2,2,1,1"
                                            BorderBrush="#295F6662"
                                            BorderThickness="0,0,1,1"
                                            CornerRadius="13" />
                                    <Border Margin="1,1,2,2"
                                            BorderBrush="#F2FFFFFF"
                                            BorderThickness="1,1,0,0"
                                            CornerRadius="13" />
                                    <Ellipse x:Name="StatusLightField"
                                             Width="80"
                                             Height="80"
                                             Fill="{TemplateBinding BorderBrush}"
                                             Opacity="0.12">
                                        <Ellipse.Effect>
                                            <BlurEffect Radius="3" />
                                        </Ellipse.Effect>
                                    </Ellipse>
                                    <Ellipse x:Name="AgentWell"
                                             Width="78"
                                             Height="78"
                                             Fill="{StaticResource PaperAgentWellBrush}" />
                                    <Ellipse x:Name="AgentWellHighlight"
                                             Width="76"
                                             Height="76"
                                             Fill="Transparent"
                                             Stroke="{StaticResource PaperKeyWellEdgeBrush}"
                                             StrokeThickness="1" />
                                    <Ellipse x:Name="StatusLightRing"
                                             Width="72"
                                             Height="72"
                                             Fill="Transparent"
                                             Stroke="{TemplateBinding BorderBrush}"
                                             StrokeThickness="1.8"
                                             Opacity="0.52" />
                                    <Grid x:Name="AgentGlyph"
                                          Width="18"
                                          Height="18"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Opacity="0.66">
                                        <Grid.Effect>
                                            <DropShadowEffect BlurRadius="4"
                                                              ShadowDepth="0"
                                                              Opacity="0.38"
                                                              Color="#685FAE" />
                                        </Grid.Effect>
                                        <Border Width="18"
                                                Height="5"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Background="#FF685FAE"
                                                CornerRadius="2.5" />
                                        <Border Width="5"
                                                Height="18"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Background="#FF685FAE"
                                                CornerRadius="2.5" />
                                    </Grid>
                                </Grid>
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="3"
                                                      Direction="270"
                                                      ShadowDepth="3"
                                                      Opacity="0.24"
                                                      Color="#3A403D" />
                                </Border.Effect>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Glow" Property="Opacity" Value="0.36" />
                                <Setter TargetName="Cap" Property="BorderBrush" Value="#F7FFFFFF" />
                                <Setter TargetName="AgentWellHighlight" Property="Opacity" Value="0.86" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ThicknessAnimation Storyboard.TargetName="Cap"
                                                                Storyboard.TargetProperty="Margin"
                                                                To="1,2,1,1"
                                                                Duration="0:0:0.08" />
                                            <DoubleAnimation Storyboard.TargetName="CrystalSide"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.42"
                                                             Duration="0:0:0.08" />
                                            <DoubleAnimation Storyboard.TargetName="SwitchShadow"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.35"
                                                             Duration="0:0:0.08" />
                                            <DoubleAnimation Storyboard.TargetName="FarShadow"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.45"
                                                             Duration="0:0:0.08" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ThicknessAnimation Storyboard.TargetName="Cap"
                                                                Storyboard.TargetProperty="Margin"
                                                                To="1,0,1,3"
                                                                Duration="0:0:0.11">
                                                <ThicknessAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </ThicknessAnimation.EasingFunction>
                                            </ThicknessAnimation>
                                            <DoubleAnimation Storyboard.TargetName="CrystalSide"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.86"
                                                             Duration="0:0:0.11" />
                                            <DoubleAnimation Storyboard.TargetName="SwitchShadow"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="0:0:0.11" />
                                            <DoubleAnimation Storyboard.TargetName="FarShadow"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="0:0:0.11" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse Margin="3,9,3,0" Fill="#8B8E9DA3" />
                            <Ellipse Margin="5,4,5,4"
                                     Stroke="#8AFFFFFF"
                                     StrokeThickness="1"
                                     Fill="#55DDE9EC" />
                            <Ellipse x:Name="DialFace" Margin="3,0,3,7">
                                <Ellipse.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#FFFFFFFF" Offset="0" />
                                        <GradientStop Color="#FFF4F9F9" Offset="0.38" />
                                        <GradientStop Color="#FFE3EDF0" Offset="0.7" />
                                        <GradientStop Color="#FFB4C2C8" Offset="1" />
                                    </LinearGradientBrush>
                                </Ellipse.Fill>
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="8" Direction="285" ShadowDepth="3" Opacity="0.3" />
                                </Ellipse.Effect>
                            </Ellipse>
                            <Border x:Name="DialIndicator"
                                    Width="6"
                                    Height="30"
                                    Margin="0,9,0,0"
                                    Background="#FF6A7379"
                                    CornerRadius="3"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Top"
                                    RenderTransformOrigin="0.5,1">
                                <Border.RenderTransform>
                                    <RotateTransform Angle="42" />
                                </Border.RenderTransform>
                            </Border>
                            <ContentPresenter />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="DialFace" Property="Stroke" Value="#99BDEFF2" />
                                <Setter TargetName="DialFace" Property="StrokeThickness" Value="2" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="DialFace" Property="Margin" Value="3,4,3,3" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkKnobButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse Width="64"
                                     Height="64"
                                     Margin="0,4,1,0"
                                     HorizontalAlignment="Right"
                                     VerticalAlignment="Center"
                                     Fill="#4AFFFFFF"
                                     Stroke="#72C9D8DC"
                                     StrokeThickness="1" />
                            <Ellipse x:Name="KnobFace"
                                     Width="58"
                                     Height="58"
                                     Margin="0,0,5,0"
                                     HorizontalAlignment="Right"
                                     VerticalAlignment="Center"
                                     Fill="#FF2D2925">
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="4"
                                                      Direction="270"
                                                      ShadowDepth="1"
                                                      Opacity="0.24"
                                                      Color="#4F483F" />
                                </Ellipse.Effect>
                            </Ellipse>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="KnobFace" Property="Fill" Value="#FF38322E" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="KnobFace" Property="Margin" Value="0,2,5,-2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="JoystickDirectionButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="Transparent">
                            <Grid x:Name="DirectionGlyph"
                                  Width="12"
                                  Height="9"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  IsHitTestVisible="False"
                                  Opacity="0.72">
                                <Path Data="{StaticResource JoystickChevronGeometry}"
                                      Stretch="Uniform"
                                      Stroke="#A6FFFFFF"
                                      StrokeThickness="1.8"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round">
                                    <Path.RenderTransform>
                                        <TranslateTransform Y="1" />
                                    </Path.RenderTransform>
                                </Path>
                                <Path Data="{StaticResource JoystickChevronGeometry}"
                                      Stretch="Uniform"
                                      Stroke="#A6554E47"
                                      StrokeThickness="1.65"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round" />
                            </Grid>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="DirectionGlyph"
                                        Property="Opacity"
                                        Value="0.94" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="DirectionGlyph"
                                        Property="Margin"
                                        Value="0,1,0,-1" />
                                <Setter TargetName="DirectionGlyph"
                                        Property="Opacity"
                                        Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

</ResourceDictionary>
