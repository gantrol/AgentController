<Application x:Class="CodexMicro.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="InkBrush" Color="#2F3438" />
        <SolidColorBrush x:Key="MutedInkBrush" Color="#737C82" />
        <SolidColorBrush x:Key="KeyEdgeBrush" Color="#F7FFFFFF" />
        <SolidColorBrush x:Key="CrystalShadowBrush" Color="#44343B40" />
        <LinearGradientBrush x:Key="CrystalKeySideBrush"
                             StartPoint="0,0"
                             EndPoint="0,1">
            <GradientStop Color="#E8FFFFFF" Offset="0" />
            <GradientStop Color="#CDE8F0EF" Offset="0.48" />
            <GradientStop Color="#9DAAB8BA" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="CrystalKeyTopBrush"
                             StartPoint="0,0"
                             EndPoint="0,1">
            <GradientStop Color="#FFFFFFFF" Offset="0" />
            <GradientStop Color="#FFF9F8F4" Offset="0.52" />
            <GradientStop Color="#F3E8EEEE" Offset="1" />
        </LinearGradientBrush>
        <Geometry x:Key="JoystickChevronGeometry">M 1,7 L 6,2 L 11,7</Geometry>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI Variable Text" />
        </Style>

        <Style TargetType="{x:Type ToolTip}">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Placement" Value="MousePoint" />
            <Setter Property="HorizontalOffset" Value="14" />
            <Setter Property="VerticalOffset" Value="14" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToolTip}">
                        <Border Padding="11,9"
                                MaxWidth="330"
                                Background="#F7F7F5F1"
                                BorderBrush="#E8FFFFFF"
                                BorderThickness="1"
                                CornerRadius="10">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12"
                                                  Direction="270"
                                                  ShadowDepth="3"
                                                  Opacity="0.26"
                                                  Color="#4A5358" />
                            </Border.Effect>
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CommandKey" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource CrystalKeyTopBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource KeyEdgeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Margin="2">
                            <Border x:Name="SwitchShadow"
                                    Margin="8,78,8,2"
                                    Background="{StaticResource CrystalShadowBrush}"
                                    CornerRadius="8"
                                    Opacity="0.34">
                                <Border.Effect>
                                    <BlurEffect Radius="5" />
                                </Border.Effect>
                            </Border>
                            <Border x:Name="CrystalSide"
                                    Margin="1,4,1,0"
                                    Background="{StaticResource CrystalKeySideBrush}"
                                    BorderBrush="#B4FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="18" />
                            <Border x:Name="Cap"
                                    Margin="1,0,1,4"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="18">
                                <Grid>
                                    <Border Margin="1"
                                            BorderBrush="#ADE4E4E4"
                                            BorderThickness="1"
                                            CornerRadius="17" />
                                    <Border Margin="2"
                                            BorderBrush="#70FFFFFF"
                                            BorderThickness="1,1,0,0"
                                            CornerRadius="16" />
                                    <Border Margin="5,4,5,0"
                                            Height="18"
                                            VerticalAlignment="Top"
                                            CornerRadius="12"
                                            Opacity="0.45">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#BFFFFFFF" Offset="0" />
                                                <GradientStop Color="#00FFFFFF" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                </Grid>
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="4"
                                                      Direction="270"
                                                      ShadowDepth="1"
                                                      Opacity="0.18"
                                                      Color="#4F483F" />
                                </Border.Effect>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Cap" Property="BorderBrush" Value="#FFFFFFFF" />
                                <Setter TargetName="Cap" Property="Background" Value="#FFFCFAF7" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ThicknessAnimation Storyboard.TargetName="Cap"
                                                                Storyboard.TargetProperty="Margin"
                                                                To="1,3,1,1"
                                                                Duration="0:0:0.08" />
                                            <DoubleAnimation Storyboard.TargetName="CrystalSide"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.5"
                                                             Duration="0:0:0.08" />
                                            <DoubleAnimation Storyboard.TargetName="SwitchShadow"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.2"
                                                             Duration="0:0:0.08" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ThicknessAnimation Storyboard.TargetName="Cap"
                                                                Storyboard.TargetProperty="Margin"
                                                                To="1,0,1,4"
                                                                Duration="0:0:0.11">
                                                <ThicknessAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </ThicknessAnimation.EasingFunction>
                                            </ThicknessAnimation>
                                            <DoubleAnimation Storyboard.TargetName="CrystalSide"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="0:0:0.11" />
                                            <DoubleAnimation Storyboard.TargetName="SwitchShadow"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.34"
                                                             Duration="0:0:0.11" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AgentKey" TargetType="Button">
            <Setter Property="Background" Value="#75FFFFFF" />
            <Setter Property="BorderBrush" Value="#008DB5FF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Margin="2">
                            <Border x:Name="SwitchShadow"
                                    Margin="8,78,8,2"
                                    Background="{StaticResource CrystalShadowBrush}"
                                    CornerRadius="8"
                                    Opacity="0.32">
                                <Border.Effect>
                                    <BlurEffect Radius="5" />
                                </Border.Effect>
                            </Border>
                            <Border x:Name="Glow"
                                    Margin="-2,2,-2,-4"
                                    Background="{TemplateBinding BorderBrush}"
                                    CornerRadius="20"
                                    Opacity="0.28">
                                <Border.Effect>
                                    <BlurEffect Radius="8" />
                                </Border.Effect>
                            </Border>
                            <Border x:Name="CrystalSide"
                                    Margin="1,4,1,0"
                                    Background="{StaticResource CrystalKeySideBrush}"
                                    BorderBrush="#C9FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="18"
                                    Opacity="0.86" />
                            <Border x:Name="Cap"
                                    Margin="1,0,1,4"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="#D1FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="18">
                                <Grid>
                                    <Ellipse x:Name="StatusLightField"
                                             Margin="7"
                                             Fill="{TemplateBinding BorderBrush}"
                                             Opacity="0.58">
                                        <Ellipse.OpacityMask>
                                            <RadialGradientBrush>
                                                <GradientStop Color="#FFFFFFFF" Offset="0" />
                                                <GradientStop Color="#B8FFFFFF" Offset="0.3" />
                                                <GradientStop Color="#46FFFFFF" Offset="0.66" />
                                                <GradientStop Color="#00FFFFFF" Offset="1" />
                                            </RadialGradientBrush>
                                        </Ellipse.OpacityMask>
                                    </Ellipse>
                                    <Border Margin="1" CornerRadius="17">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#A8FFFFFF" Offset="0" />
                                                <GradientStop Color="#36FFFFFF" Offset="0.52" />
                                                <GradientStop Color="#0AE9FFFF" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <Border Margin="1"
                                            BorderBrush="#66E4E4E4"
                                            BorderThickness="1"
                                            CornerRadius="17" />
                                    <Ellipse x:Name="StatusDot"
                                             Width="20"
                                             Height="20"
                                             Fill="#D9685FAE"
                                             Stroke="#334F477F"
                                             StrokeThickness="1">
                                        <Ellipse.Effect>
                                            <DropShadowEffect BlurRadius="5"
                                                              ShadowDepth="0"
                                                              Opacity="0.42"
                                                              Color="#574C97" />
                                        </Ellipse.Effect>
                                    </Ellipse>
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Bottom"
                                                      Margin="0,0,0,4"
                                                      Opacity="0" />
                                </Grid>
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="4"
                                                      Direction="270"
                                                      ShadowDepth="1"
                                                      Opacity="0.16"
                                                      Color="#4F483F" />
                                </Border.Effect>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Glow" Property="Opacity" Value="0.38" />
                                <Setter TargetName="Cap" Property="Background" Value="#8FFFFFFF" />
                                <Setter TargetName="Cap" Property="BorderBrush" Value="#F7FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ThicknessAnimation Storyboard.TargetName="Cap"
                                                                Storyboard.TargetProperty="Margin"
                                                                To="1,3,1,1"
                                                                Duration="0:0:0.08" />
                                            <DoubleAnimation Storyboard.TargetName="CrystalSide"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.52"
                                                             Duration="0:0:0.08" />
                                            <DoubleAnimation Storyboard.TargetName="SwitchShadow"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.18"
                                                             Duration="0:0:0.08" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ThicknessAnimation Storyboard.TargetName="Cap"
                                                                Storyboard.TargetProperty="Margin"
                                                                To="1,0,1,4"
                                                                Duration="0:0:0.11">
                                                <ThicknessAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </ThicknessAnimation.EasingFunction>
                                            </ThicknessAnimation>
                                            <DoubleAnimation Storyboard.TargetName="CrystalSide"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.86"
                                                             Duration="0:0:0.11" />
                                            <DoubleAnimation Storyboard.TargetName="SwitchShadow"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.32"
                                                             Duration="0:0:0.11" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse Margin="3,9,3,0" Fill="#8B8E9DA3" />
                            <Ellipse Margin="5,4,5,4"
                                     Stroke="#8AFFFFFF"
                                     StrokeThickness="1"
                                     Fill="#55DDE9EC" />
                            <Ellipse x:Name="DialFace" Margin="3,0,3,7">
                                <Ellipse.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#FFFFFFFF" Offset="0" />
                                        <GradientStop Color="#FFF4F9F9" Offset="0.38" />
                                        <GradientStop Color="#FFE3EDF0" Offset="0.7" />
                                        <GradientStop Color="#FFB4C2C8" Offset="1" />
                                    </LinearGradientBrush>
                                </Ellipse.Fill>
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="8" Direction="285" ShadowDepth="3" Opacity="0.3" />
                                </Ellipse.Effect>
                            </Ellipse>
                            <Border x:Name="DialIndicator"
                                    Width="6"
                                    Height="30"
                                    Margin="0,9,0,0"
                                    Background="#FF6A7379"
                                    CornerRadius="3"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Top"
                                    RenderTransformOrigin="0.5,1">
                                <Border.RenderTransform>
                                    <RotateTransform Angle="42" />
                                </Border.RenderTransform>
                            </Border>
                            <ContentPresenter />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="DialFace" Property="Stroke" Value="#99BDEFF2" />
                                <Setter TargetName="DialFace" Property="StrokeThickness" Value="2" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="DialFace" Property="Margin" Value="3,4,3,3" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkKnobButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse Width="64"
                                     Height="64"
                                     Margin="0,4,1,0"
                                     HorizontalAlignment="Right"
                                     VerticalAlignment="Center"
                                     Fill="#4AFFFFFF"
                                     Stroke="#72C9D8DC"
                                     StrokeThickness="1" />
                            <Ellipse x:Name="KnobFace"
                                     Width="58"
                                     Height="58"
                                     Margin="0,0,5,0"
                                     HorizontalAlignment="Right"
                                     VerticalAlignment="Center"
                                     Fill="#FF2D2925">
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="4"
                                                      Direction="270"
                                                      ShadowDepth="1"
                                                      Opacity="0.24"
                                                      Color="#4F483F" />
                                </Ellipse.Effect>
                            </Ellipse>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="KnobFace" Property="Fill" Value="#FF38322E" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="KnobFace" Property="Margin" Value="0,2,5,-2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="JoystickDirectionButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="Transparent">
                            <Grid x:Name="DirectionGlyph"
                                  Width="12"
                                  Height="9"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  IsHitTestVisible="False"
                                  Opacity="0.72">
                                <Path Data="{StaticResource JoystickChevronGeometry}"
                                      Stretch="Uniform"
                                      Stroke="#A6FFFFFF"
                                      StrokeThickness="1.8"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round">
                                    <Path.RenderTransform>
                                        <TranslateTransform Y="1" />
                                    </Path.RenderTransform>
                                </Path>
                                <Path Data="{StaticResource JoystickChevronGeometry}"
                                      Stretch="Uniform"
                                      Stroke="#A6554E47"
                                      StrokeThickness="1.65"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round" />
                            </Grid>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="DirectionGlyph"
                                        Property="Opacity"
                                        Value="0.94" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="DirectionGlyph"
                                        Property="Margin"
                                        Value="0,1,0,-1" />
                                <Setter TargetName="DirectionGlyph"
                                        Property="Opacity"
                                        Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Application.Resources>
</Application>
