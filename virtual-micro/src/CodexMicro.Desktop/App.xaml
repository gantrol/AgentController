<Application x:Class="CodexMicro.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="InkBrush" Color="#2F3438" />
        <SolidColorBrush x:Key="MutedInkBrush" Color="#737C82" />
        <SolidColorBrush x:Key="KeyTopBrush" Color="#FFF7F5F1" />
        <SolidColorBrush x:Key="KeyEdgeBrush" Color="#F0FFFFFF" />
        <Geometry x:Key="JoystickChevronGeometry">M 1,7 L 6,2 L 11,7</Geometry>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI Variable Text" />
        </Style>

        <Style TargetType="{x:Type ToolTip}">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Placement" Value="MousePoint" />
            <Setter Property="HorizontalOffset" Value="14" />
            <Setter Property="VerticalOffset" Value="14" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToolTip}">
                        <Border Padding="11,9"
                                MaxWidth="330"
                                Background="#F7F7F5F1"
                                BorderBrush="#E8FFFFFF"
                                BorderThickness="1"
                                CornerRadius="10">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12"
                                                  Direction="270"
                                                  ShadowDepth="3"
                                                  Opacity="0.26"
                                                  Color="#4A5358" />
                            </Border.Effect>
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CommandKey" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource KeyTopBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource KeyEdgeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Margin="2">
                            <Border x:Name="Cap"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="18">
                                <Grid>
                                    <Border Margin="1"
                                            BorderBrush="#ADE4E4E4"
                                            BorderThickness="1"
                                            CornerRadius="17" />
                                    <Border Margin="2"
                                            BorderBrush="#70FFFFFF"
                                            BorderThickness="1,1,0,0"
                                            CornerRadius="16" />
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                </Grid>
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="4"
                                                      Direction="270"
                                                      ShadowDepth="1"
                                                      Opacity="0.18"
                                                      Color="#4F483F" />
                                </Border.Effect>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Cap" Property="BorderBrush" Value="#FFFFFFFF" />
                                <Setter TargetName="Cap" Property="Background" Value="#FFFCFAF7" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Cap" Property="Margin" Value="0,1,0,-1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AgentKey" TargetType="Button">
            <Setter Property="Background" Value="#75FFFFFF" />
            <Setter Property="BorderBrush" Value="#008DB5FF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Margin="2">
                            <Border x:Name="Glow"
                                    Margin="-2"
                                    Background="{TemplateBinding BorderBrush}"
                                    CornerRadius="20"
                                    Opacity="0.28">
                                <Border.Effect>
                                    <BlurEffect Radius="8" />
                                </Border.Effect>
                            </Border>
                            <Border x:Name="Cap"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="#D1FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="18">
                                <Grid>
                                    <Border Margin="1"
                                            Background="{TemplateBinding BorderBrush}"
                                            CornerRadius="17"
                                            Opacity="0.55" />
                                    <Border Margin="1" CornerRadius="17">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#61FFFFFF" Offset="0" />
                                                <GradientStop Color="#1AFFFFFF" Offset="0.52" />
                                                <GradientStop Color="#00FFFFFF" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <Border Margin="1"
                                            BorderBrush="#66E4E4E4"
                                            BorderThickness="1"
                                            CornerRadius="17" />
                                    <Ellipse x:Name="StatusDot"
                                             Width="20"
                                             Height="20"
                                             Fill="#D9685FAE"
                                             Stroke="#334F477F"
                                             StrokeThickness="1">
                                        <Ellipse.Effect>
                                            <DropShadowEffect BlurRadius="5"
                                                              ShadowDepth="0"
                                                              Opacity="0.42"
                                                              Color="#574C97" />
                                        </Ellipse.Effect>
                                    </Ellipse>
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Bottom"
                                                      Margin="0,0,0,4"
                                                      Opacity="0" />
                                </Grid>
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="4"
                                                      Direction="270"
                                                      ShadowDepth="1"
                                                      Opacity="0.16"
                                                      Color="#4F483F" />
                                </Border.Effect>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Glow" Property="Opacity" Value="0.46" />
                                <Setter TargetName="Cap" Property="Background" Value="#8FFFFFFF" />
                                <Setter TargetName="StatusDot" Property="Width" Value="21" />
                                <Setter TargetName="StatusDot" Property="Height" Value="21" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Cap" Property="Margin" Value="0,1,0,-1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse Margin="3,9,3,0" Fill="#9BA6ABAF" />
                            <Ellipse x:Name="DialFace" Margin="3,0,3,7">
                                <Ellipse.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#FFFFFFFF" Offset="0" />
                                        <GradientStop Color="#FFE8ECEE" Offset="0.58" />
                                        <GradientStop Color="#FFB8C0C5" Offset="1" />
                                    </LinearGradientBrush>
                                </Ellipse.Fill>
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="8" Direction="285" ShadowDepth="3" Opacity="0.3" />
                                </Ellipse.Effect>
                            </Ellipse>
                            <Border x:Name="DialIndicator"
                                    Width="6"
                                    Height="30"
                                    Margin="0,9,0,0"
                                    Background="#FF6A7379"
                                    CornerRadius="3"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Top"
                                    RenderTransformOrigin="0.5,1">
                                <Border.RenderTransform>
                                    <RotateTransform Angle="42" />
                                </Border.RenderTransform>
                            </Border>
                            <ContentPresenter />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="DialFace" Property="Stroke" Value="#99BDEFF2" />
                                <Setter TargetName="DialFace" Property="StrokeThickness" Value="2" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="DialFace" Property="Margin" Value="3,4,3,3" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkKnobButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="KnobFace"
                                     Width="58"
                                     Height="58"
                                     Margin="0,0,5,0"
                                     HorizontalAlignment="Right"
                                     VerticalAlignment="Center"
                                     Fill="#FF2D2925">
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="4"
                                                      Direction="270"
                                                      ShadowDepth="1"
                                                      Opacity="0.24"
                                                      Color="#4F483F" />
                                </Ellipse.Effect>
                            </Ellipse>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="KnobFace" Property="Fill" Value="#FF38322E" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="KnobFace" Property="Margin" Value="0,2,5,-2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="JoystickDirectionButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="Transparent">
                            <Grid x:Name="DirectionGlyph"
                                  Width="12"
                                  Height="9"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  IsHitTestVisible="False"
                                  Opacity="0.72">
                                <Path Data="{StaticResource JoystickChevronGeometry}"
                                      Stretch="Uniform"
                                      Stroke="#A6FFFFFF"
                                      StrokeThickness="1.8"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round">
                                    <Path.RenderTransform>
                                        <TranslateTransform Y="1" />
                                    </Path.RenderTransform>
                                </Path>
                                <Path Data="{StaticResource JoystickChevronGeometry}"
                                      Stretch="Uniform"
                                      Stroke="#A6554E47"
                                      StrokeThickness="1.65"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round" />
                            </Grid>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="DirectionGlyph"
                                        Property="Opacity"
                                        Value="0.94" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="DirectionGlyph"
                                        Property="Margin"
                                        Value="0,1,0,-1" />
                                <Setter TargetName="DirectionGlyph"
                                        Property="Opacity"
                                        Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Application.Resources>
</Application>
