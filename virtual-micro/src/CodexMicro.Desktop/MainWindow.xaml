<Window x:Class="CodexMicro.Desktop.MicroSurfaceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:CodexMicro.Desktop.Controls"
        Title="Agent Controller · Micro Surface"
        Width="442.5"
        Height="457.5"
        MinWidth="354"
        MinHeight="366"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        ShowActivated="False"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        SourceInitialized="Window_SourceInitialized"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        Closed="Window_Closed"
        Deactivated="Window_Deactivated">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="MicroSurfaceResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Background="Transparent">
        <Viewbox x:Name="DeviceViewbox"
                 Stretch="Uniform"
                 StretchDirection="Both"
                 HorizontalAlignment="Stretch"
                 VerticalAlignment="Stretch">
            <Grid x:Name="DesignSurface"
                  Width="590"
                   Height="610"
                   Background="Transparent"
                   ToolTipService.InitialShowDelay="320"
                   ToolTipService.BetweenShowDelay="100"
                   ToolTipService.ShowDuration="16000">
                <Border x:Name="DeviceFrame"
                        Margin="23"
                        CornerRadius="66"
                        BorderBrush="#D9FFFFFF"
                        BorderThickness="2"
                        ContextMenuOpening="DeviceFrame_ContextMenuOpening"
                        MouseLeftButtonDown="DeviceFrame_MouseLeftButtonDown">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#E4FFFFFF" Offset="0" />
                            <GradientStop Color="#D6F7FAF9" Offset="0.48" />
                            <GradientStop Color="#C8E8F0EF" Offset="0.78" />
                            <GradientStop Color="#B8C7D3D3" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.ContextMenu>
                        <ContextMenu x:Name="DeviceContextMenu"
                                     Opened="DeviceContextMenu_Opened">
                            <MenuItem x:Name="TopmostMenuItem"
                                      Header="窗口置顶"
                                      IsCheckable="True"
                                      Click="TopmostMenuItem_Click" />
                            <Separator />
                            <MenuItem Header="重新连接虚拟 HID"
                                      Click="ReconnectMenuItem_Click" />
                            <MenuItem Header="隐藏面板"
                                      Click="ExitMenuItem_Click" />
                        </ContextMenu>
                    </Border.ContextMenu>
                    <Border.Effect>
                        <DropShadowEffect Color="#526E7B80"
                                          BlurRadius="30"
                                          ShadowDepth="7"
                                          Direction="270"
                                          Opacity="0.29" />
                    </Border.Effect>

                    <Grid x:Name="CrystalLightClip"
                          ClipToBounds="True">
                        <Border x:Name="CrystalPrismRim"
                                Margin="4,4,4,5"
                                CornerRadius="61"
                                BorderThickness="2"
                                Opacity="0.94"
                                IsHitTestVisible="False">
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FFFFFFFF" Offset="0" />
                                    <GradientStop Color="#B8DFF8F3" Offset="0.16" />
                                    <GradientStop Color="#76FFFFFF" Offset="0.46" />
                                    <GradientStop Color="#8BC6EEE5" Offset="0.78" />
                                    <GradientStop Color="#D6FFFFFF" Offset="1" />
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                        </Border>
                        <Border x:Name="CrystalDepthPlate"
                                Margin="10"
                                CornerRadius="56"
                                BorderThickness="1"
                                Background="#14748788"
                                IsHitTestVisible="False">
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#78FFFFFF" Offset="0" />
                                    <GradientStop Color="#5EACBDBB" Offset="0.58" />
                                    <GradientStop Color="#75859498" Offset="1" />
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                        </Border>
                        <Border x:Name="PearlLightGuide"
                                Margin="18"
                                CornerRadius="50"
                                BorderBrush="#A8FFFFFF"
                                BorderThickness="1"
                                IsHitTestVisible="False">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#F4FFFFFF" Offset="0" />
                                    <GradientStop Color="#EEF8FAF8" Offset="0.5" />
                                    <GradientStop Color="#E9F1F5F2" Offset="0.82" />
                                    <GradientStop Color="#E3E1EAE8" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <Border x:Name="CrystalLowerRefraction"
                                Height="5"
                                Margin="88,0,88,18"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Bottom"
                                CornerRadius="3"
                                Opacity="0.15"
                                IsHitTestVisible="False">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#0098E8D5" Offset="0" />
                                    <GradientStop Color="#A598E8D5" Offset="0.48" />
                                    <GradientStop Color="#0098E8D5" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <TextBlock x:Name="LeftSilkScreen"
                                   Text="CODEX  /  MICRO  /  CRYSTAL HID"
                                   FontSize="8"
                                   FontWeight="Bold"
                                   Foreground="#6A5A6368"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   Margin="39,0,0,0"
                                   IsHitTestVisible="False"
                                   Panel.ZIndex="2">
                            <TextBlock.LayoutTransform>
                                <RotateTransform Angle="-90" />
                            </TextBlock.LayoutTransform>
                        </TextBlock>
                        <TextBlock x:Name="RightSilkScreen"
                                   Text="OPTICAL INPUT  /  PROJECT 2077"
                                   FontSize="8"
                                   FontWeight="SemiBold"
                                   Foreground="#6A5A6368"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Margin="0,0,39,0"
                                   IsHitTestVisible="False"
                                   Panel.ZIndex="2">
                            <TextBlock.LayoutTransform>
                                <RotateTransform Angle="90" />
                            </TextBlock.LayoutTransform>
                        </TextBlock>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Bottom"
                                    Margin="0,0,0,25"
                                    IsHitTestVisible="False"
                                    Panel.ZIndex="2">
                            <controls:KeycapIcon x:Name="BrandCodexIcon"
                                                 Width="13"
                                                 Height="13"
                                                 Margin="0,0,6,0"
                                                 KeycapId="CODEX"
                                                 IconBrush="#80606A70" />
                            <TextBlock Text="OPENAI  CODEX"
                                       FontSize="8"
                                       FontWeight="Bold"
                                       Foreground="#80606A70"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <Grid x:Name="ControlGrid"
                              Width="424"
                              Height="424"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="106" />
                                <ColumnDefinition Width="106" />
                                <ColumnDefinition Width="106" />
                                <ColumnDefinition Width="106" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="106" />
                                <RowDefinition Height="106" />
                                <RowDefinition Height="106" />
                                <RowDefinition Height="106" />
                            </Grid.RowDefinitions>

                            <Button x:Name="DialButton"
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Width="88"
                                    Height="88"
                                    Margin="4"
                                    Style="{StaticResource DialButton}"
                                    ToolTip="滚轮选择 · 按住左键上下或左右拖动旋转 · 短按确认"
                                    PreviewMouseLeftButtonDown="Dial_PreviewMouseLeftButtonDown"
                                    PreviewMouseLeftButtonUp="Dial_PreviewMouseLeftButtonUp"
                                    PreviewMouseMove="Dial_MouseMove"
                                    LostMouseCapture="Dial_LostMouseCapture"
                                    MouseWheel="Dial_MouseWheel" />

                            <Border x:Name="DialSelectionHud"
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="4"
                                    Width="250"
                                    Height="30"
                                    Margin="96,-36,0,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Background="#F2FBFCFA"
                                    BorderBrush="#D9FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="15"
                                    IsHitTestVisible="False"
                                    Opacity="0"
                                    Visibility="Collapsed"
                                    Panel.ZIndex="20">
                                <Border.Effect>
                                    <DropShadowEffect Color="#625B54"
                                                      BlurRadius="9"
                                                      ShadowDepth="2"
                                                      Direction="270"
                                                      Opacity="0.22" />
                                </Border.Effect>
                                <Grid Margin="10,0,11,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Width="7"
                                             Height="7"
                                             Margin="0,0,8,0"
                                             VerticalAlignment="Center"
                                             Fill="#756BC1" />
                                    <TextBlock x:Name="DialSelectionText"
                                               Grid.Column="1"
                                               VerticalAlignment="Center"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="#403B37"
                                               TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </Border>

                            <Button x:Name="AgentKey0" Grid.Row="0" Grid.Column="1" Width="96" Height="96" Margin="5" Tag="AG00" Style="{StaticResource AgentKey}" BorderBrush="#008DB5FF" Click="Key_Click" ToolTip="Agent slot 1 · AG00" />
                            <Button x:Name="AgentKey1" Grid.Row="0" Grid.Column="2" Width="96" Height="96" Margin="5" Tag="AG01" Style="{StaticResource AgentKey}" BorderBrush="#008DB5FF" Click="Key_Click" ToolTip="Agent slot 2 · AG01" />

                            <Grid x:Name="JoystickSurface"
                                  Grid.Row="0"
                                  Grid.Column="3"
                                  Width="96"
                                  Height="96"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  ToolTip="拖动黑色圆帽模拟摇杆，或单击四周方向键">
                                <Border x:Name="JoystickSeat"
                                        Margin="4"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        CornerRadius="18">
                                    <Grid>
                                        <Grid x:Name="JoystickCap"
                                              Width="67"
                                              Height="67"
                                              Background="Transparent"
                                              Cursor="SizeAll"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              MouseLeftButtonDown="JoystickCap_MouseLeftButtonDown"
                                              MouseMove="JoystickCap_MouseMove"
                                              MouseLeftButtonUp="JoystickCap_MouseLeftButtonUp"
                                              LostMouseCapture="JoystickCap_LostMouseCapture"
                                              ToolTip="按住并向任意方向拖动">
                                            <Grid.Effect>
                                                <DropShadowEffect BlurRadius="5"
                                                                  Direction="270"
                                                                  ShadowDepth="3"
                                                                  Opacity="0.42"
                                                                  Color="#232624" />
                                            </Grid.Effect>
                                            <Grid.RenderTransform>
                                                <TransformGroup>
                                                    <ScaleTransform x:Name="JoystickScale"
                                                                    CenterX="33.5"
                                                                    CenterY="33.5" />
                                                    <TranslateTransform x:Name="JoystickTranslate" />
                                                </TransformGroup>
                                            </Grid.RenderTransform>

                                            <Ellipse Stroke="#CC000000"
                                                     StrokeThickness="1">
                                                <Ellipse.Fill>
                                                    <RadialGradientBrush Center="0.34,0.27"
                                                                         GradientOrigin="0.34,0.27"
                                                                         RadiusX="0.76"
                                                                         RadiusY="0.76">
                                                        <GradientStop Color="#FF50524F" Offset="0" />
                                                        <GradientStop Color="#FF363936" Offset="0.44" />
                                                        <GradientStop Color="#FF222422" Offset="1" />
                                                    </RadialGradientBrush>
                                                </Ellipse.Fill>
                                            </Ellipse>
                                            <Ellipse Margin="1"
                                                     Fill="Transparent"
                                                     Stroke="#1AFFFFFF"
                                                     StrokeThickness="1" />

                                            <Grid IsHitTestVisible="False">
                                                <Path Data="M 15.5,17.8 L 26.9,29.2 M 51.5,17.8 L 40.1,29.2 M 15.5,51.2 L 26.9,39.8 M 51.5,51.2 L 40.1,39.8"
                                                      Stroke="#0DFFFFFF"
                                                      StrokeThickness="2"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round">
                                                    <Path.RenderTransform>
                                                        <TranslateTransform Y="1" />
                                                    </Path.RenderTransform>
                                                </Path>
                                                <Path Data="M 15.5,17.8 L 26.9,29.2 M 51.5,17.8 L 40.1,29.2 M 15.5,51.2 L 26.9,39.8 M 51.5,51.2 L 40.1,39.8"
                                                      Stroke="#B3000000"
                                                      StrokeThickness="2"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round" />
                                            </Grid>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <Button x:Name="JoystickUp"
                                        Width="24"
                                        Height="24"
                                        Margin="0,-6,0,0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Top"
                                        Panel.ZIndex="3"
                                        Style="{StaticResource JoystickDirectionButton}"
                                        Tag="0.75|up"
                                        Click="Joystick_Click" />
                                <Button x:Name="JoystickLeft"
                                        Width="24"
                                        Height="24"
                                        Margin="-6,0,0,0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Panel.ZIndex="3"
                                        Style="{StaticResource JoystickDirectionButton}"
                                        Tag="0.50|left"
                                        Click="Joystick_Click"
                                        RenderTransformOrigin="0.5,0.5">
                                    <Button.RenderTransform>
                                        <RotateTransform Angle="-90" />
                                    </Button.RenderTransform>
                                </Button>
                                <Button x:Name="JoystickRight"
                                        Width="24"
                                        Height="24"
                                        Margin="0,0,-6,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Panel.ZIndex="3"
                                        Style="{StaticResource JoystickDirectionButton}"
                                        Tag="0.00|right"
                                        Click="Joystick_Click"
                                        RenderTransformOrigin="0.5,0.5">
                                    <Button.RenderTransform>
                                        <RotateTransform Angle="90" />
                                    </Button.RenderTransform>
                                </Button>
                                <Button x:Name="JoystickDown"
                                        Width="24"
                                        Height="24"
                                        Margin="0,0,0,-6"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Bottom"
                                        Panel.ZIndex="3"
                                        Style="{StaticResource JoystickDirectionButton}"
                                        Tag="0.25|down"
                                        Click="Joystick_Click"
                                        RenderTransformOrigin="0.5,0.5">
                                    <Button.RenderTransform>
                                        <RotateTransform Angle="180" />
                                    </Button.RenderTransform>
                                </Button>
                            </Grid>

                            <Button x:Name="AgentKey2" Grid.Row="1" Grid.Column="0" Width="96" Height="96" Margin="5" Tag="AG02" Style="{StaticResource AgentKey}" BorderBrush="#008DB5FF" Click="Key_Click" ToolTip="Agent slot 3 · AG02" />
                            <Button x:Name="AgentKey3" Grid.Row="1" Grid.Column="1" Width="96" Height="96" Margin="5" Tag="AG03" Style="{StaticResource AgentKey}" BorderBrush="#008DB5FF" Click="Key_Click" ToolTip="Agent slot 4 · AG03" />
                            <Button x:Name="AgentKey4" Grid.Row="1" Grid.Column="2" Width="96" Height="96" Margin="5" Tag="AG04" Style="{StaticResource AgentKey}" BorderBrush="#008DB5FF" Click="Key_Click" ToolTip="Agent slot 5 · AG04" />
                            <Button x:Name="AgentKey5" Grid.Row="1" Grid.Column="3" Width="96" Height="96" Margin="5" Tag="AG05" Style="{StaticResource AgentKey}" BorderBrush="#008DB5FF" Click="Key_Click" ToolTip="Agent slot 6 · AG05" />

                            <Button x:Name="ActionKey06" Grid.Row="2" Grid.Column="0" Width="96" Height="96" Margin="5" Tag="ACT06" Style="{StaticResource CommandKey}" Click="Key_Click" ToolTip="Fast · ACT06">
                                <controls:KeycapIcon x:Name="ActionIcon06" Width="28" Height="28" KeycapId="FAST" IconBrush="#171717" />
                            </Button>
                            <Button x:Name="ActionKey07" Grid.Row="2" Grid.Column="1" Width="96" Height="96" Margin="5" Tag="ACT07" Style="{StaticResource CommandKey}" Click="Key_Click" ToolTip="Approve · ACT07">
                                <controls:KeycapIcon x:Name="ActionIcon07" Width="28" Height="28" KeycapId="APPR" IconBrush="#171717" />
                            </Button>
                            <Button x:Name="ActionKey08" Grid.Row="2" Grid.Column="2" Width="96" Height="96" Margin="5" Tag="ACT08" Style="{StaticResource CommandKey}" Click="Key_Click" ToolTip="Decline · ACT08">
                                <controls:KeycapIcon x:Name="ActionIcon08" Width="28" Height="28" KeycapId="REJ" IconBrush="#171717" />
                            </Button>
                            <Button x:Name="ActionKey09" Grid.Row="2" Grid.Column="3" Width="96" Height="96" Margin="5" Tag="ACT09" Style="{StaticResource CommandKey}" Click="Key_Click" ToolTip="Fork · ACT09">
                                <controls:KeycapIcon x:Name="ActionIcon09" Width="28" Height="28" KeycapId="SPLIT" IconBrush="#171717" />
                            </Button>

                            <Grid Grid.Row="3"
                                  Grid.Column="0"
                                  Width="96"
                                  Height="96"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center">
                                <StackPanel Orientation="Vertical"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            Margin="10,0,0,0"
                                            Panel.ZIndex="2">
                                    <Ellipse x:Name="RuntimeLed" Width="7" Height="7" Margin="0,0,0,4" Fill="#9EBDFF" ToolTip="Codex 运行时握手" />
                                    <Ellipse x:Name="DriverLed" Width="7" Height="7" Margin="0,0,0,4" Fill="#B8B98B" ToolTip="虚拟 HID 驱动" />
                                    <Ellipse x:Name="ActivityLed" Width="7" Height="7" Fill="#B8B98B" ToolTip="事件状态" />
                                </StackPanel>
                                <Button x:Name="SettingsKey"
                                        Width="96"
                                        Height="96"
                                        Style="{StaticResource DarkKnobButton}"
                                        Click="Settings_Click"
                                        PreviewMouseRightButtonUp="Settings_PreviewMouseRightButtonUp"
                                        ToolTip="打开 Codex Micro 设置 · 右键重新连接虚拟 HID&#x0a;三灯：Codex 运行时握手 / HID 连接 / 最近事件" />
                            </Grid>
                            <Button x:Name="ActionKey10"
                                    Grid.Row="3"
                                    Grid.Column="1"
                                    Grid.ColumnSpan="2"
                                    Width="202"
                                    Height="96"
                                    Margin="5"
                                    Tag="ACT10_ACT11"
                                    Style="{StaticResource CommandKey}"
                                    PreviewMouseLeftButtonDown="Voice_PreviewMouseLeftButtonDown"
                                    PreviewMouseLeftButtonUp="Voice_PreviewMouseLeftButtonUp"
                                    LostMouseCapture="Voice_LostMouseCapture"
                                    PreviewKeyDown="Voice_PreviewKeyDown"
                                    PreviewKeyUp="Voice_PreviewKeyUp"
                                    ToolTip="Push to talk · 按住说话 · ACT10">
                                <Grid Width="160"
                                      Height="76"
                                      IsHitTestVisible="False">
                                    <Border x:Name="VoiceFlowGlow"
                                            Width="154"
                                            Height="70"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            BorderBrush="#705FE4C1"
                                            BorderThickness="1"
                                            CornerRadius="35"
                                            Opacity="0.34"
                                            RenderTransformOrigin="0.5,0.5">
                                        <Border.Background>
                                            <RadialGradientBrush Center="0.5,0.5"
                                                                 GradientOrigin="0.5,0.5"
                                                                 RadiusX="0.72"
                                                                 RadiusY="0.9">
                                                <GradientStop Color="#B05FE4C1" Offset="0" />
                                                <GradientStop Color="#667FE9D1" Offset="0.56" />
                                                <GradientStop Color="#1A5FE4C1" Offset="1" />
                                            </RadialGradientBrush>
                                        </Border.Background>
                                        <Border.Effect>
                                            <DropShadowEffect Color="#5FE4C1"
                                                              BlurRadius="13"
                                                              ShadowDepth="0"
                                                              Opacity="0.62" />
                                        </Border.Effect>
                                        <Border.RenderTransform>
                                            <ScaleTransform x:Name="VoiceFlowScale"
                                                            ScaleX="0.98"
                                                            ScaleY="0.98" />
                                        </Border.RenderTransform>
                                    </Border>

                                    <Border x:Name="VoiceGlassSurface"
                                            Width="154"
                                            Height="70"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            BorderBrush="#D8FFFFFF"
                                            BorderThickness="1.25"
                                            CornerRadius="35">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0"
                                                                 EndPoint="1,1">
                                                <GradientStop Color="#D8FBFFFD" Offset="0" />
                                                <GradientStop Color="#8FC0F3E5" Offset="0.48" />
                                                <GradientStop Color="#B8F4FFFB" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Border.Effect>
                                            <DropShadowEffect Color="#79DCC7"
                                                              BlurRadius="7"
                                                              ShadowDepth="0"
                                                              Opacity="0.34" />
                                        </Border.Effect>
                                    </Border>

                                    <Border Width="148"
                                            Height="64"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Background="Transparent"
                                            BorderBrush="#8CFFFFFF"
                                            BorderThickness="1"
                                            CornerRadius="32" />

                                    <Grid x:Name="VoiceWaveLayer"
                                          Width="160"
                                          Height="76"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Opacity="0.72">
                                        <Path x:Name="VoiceWaveAura"
                                              Data="M 8,38 C 32,14 56,14 80,38 S 128,62 152,38 M 8,38 C 32,62 56,62 80,38 S 128,14 152,38"
                                              Fill="Transparent"
                                              Stroke="#805FE4C1"
                                              StrokeThickness="5.5">
                                            <Path.Effect>
                                                <BlurEffect Radius="4.5" />
                                            </Path.Effect>
                                        </Path>
                                        <Path x:Name="VoiceWaveA"
                                              Data="M 8,38 C 32,14 56,14 80,38 S 128,62 152,38"
                                              Fill="Transparent"
                                              Stroke="#D65FE4C1"
                                              StrokeEndLineCap="Round"
                                              StrokeStartLineCap="Round"
                                              StrokeThickness="1.6" />
                                        <Path x:Name="VoiceWaveB"
                                              Data="M 8,38 C 32,62 56,62 80,38 S 128,14 152,38"
                                              Fill="Transparent"
                                              Stroke="#E8FFFFFF"
                                              StrokeEndLineCap="Round"
                                              StrokeStartLineCap="Round"
                                              StrokeThickness="1.35" />
                                        <Path x:Name="VoiceWaveParticles"
                                              Data="M 8,38 C 32,14 56,14 80,38 S 128,62 152,38 M 8,38 C 32,62 56,62 80,38 S 128,14 152,38"
                                              Fill="Transparent"
                                              Stroke="#F2FFFFFF"
                                              StrokeDashArray="0.1 2.5"
                                              StrokeDashCap="Round"
                                              StrokeThickness="2.35" />
                                        <Path Data="M 12,45 C 38,27 59,27 80,38 S 122,49 148,31"
                                              Fill="Transparent"
                                              Opacity="0.78"
                                              Stroke="#C8FFFFFF"
                                              StrokeDashArray="0.1 3.2"
                                              StrokeDashCap="Round"
                                              StrokeThickness="1.8" />
                                    </Grid>

                                    <Border x:Name="VoiceReadyFlash"
                                            Width="156"
                                            Height="72"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            BorderBrush="#F2FFFFFF"
                                            BorderThickness="1.4"
                                            CornerRadius="36"
                                            Opacity="0">
                                        <Border.Effect>
                                            <BlurEffect Radius="4" />
                                        </Border.Effect>
                                    </Border>

                                    <Ellipse Width="39"
                                             Height="39"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Fill="#28FFFFFF"
                                             Stroke="#72FFFFFF"
                                             StrokeThickness="0.8">
                                        <Ellipse.Effect>
                                            <DropShadowEffect Color="#FFFFFF"
                                                              BlurRadius="5"
                                                              ShadowDepth="0"
                                                              Opacity="0.9" />
                                        </Ellipse.Effect>
                                    </Ellipse>

                                    <controls:KeycapIcon x:Name="ActionIcon10"
                                                         Width="40"
                                                         Height="40"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"
                                                         KeycapId="MIC"
                                                         IconBrush="#17A88F">
